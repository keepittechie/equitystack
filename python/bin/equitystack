}

current_admin_workflow_usage() {
  cat <<EOF
Usage:
  equitystack current-admin workflow <command> [args]

Commands:
  start                      Run normalize, review, and queue for one batch
  review                     Generate a decision template from a review or worklist artifact
  finalize                   Log explicit operator decisions against a canonical review artifact
  resume                     Show the latest current-admin session and recommended next step
EOF
}

current_admin_workflow_subcommand_usage() {
  local subcommand="$1"
  case "$subcommand" in
    start)
      cat <<EOF
Usage:
  equitystack current-admin workflow start [--input <batch-file> | --batch-name <batch-name>] [--review-dry-run] [--prefill-suggestions] [--model <openai-model>] [--verifier-model <name>] [--fallback-model <name>] [--timeout <seconds>] [--senior-timeout <seconds>] [--verifier-timeout <seconds>] [--ollama-url <url>] [--deep-review | --review-mode <standard|deep>]

Runs the existing safe pre-import workflow:
  normalize -> review -> queue

This does not import records or write to the database.

Relative --input paths may be given as data/... or python/data/...
EOF
      ;;
    review|generate-decision-template)
      cat <<EOF
Usage:
  equitystack current-admin workflow review --input <ai-review-or-worklist.json> [--output <decision-template.json>] [filters]

Runs:
  python3 scripts/generate_current_admin_decision_template.py [args]

Relative --input/--output paths may be given as reports/... or python/reports/...
EOF
      ;;
    finalize)
      cat <<EOF
Usage:
  equitystack current-admin workflow finalize --review <ai-review.json> --decision-file <decisions.json> --log-decisions [path] [--feedback-summary]

Reuses the canonical AI review artifact and writes a decision log.
This does not import records or write to the database.

Relative --review and --decision-file paths may be given as reports/... or python/reports/...
EOF
      ;;
    resume)
      cat <<EOF
Usage:
  equitystack current-admin workflow resume

Shows the latest current-admin review session and the likely next operator step.
EOF
      ;;
    *)
      current_admin_workflow_usage
      ;;
  esac
}

current_admin_subcommand_usage() {
  local subcommand="$1"
  case "$subcommand" in
    discover)
      cat <<EOF
Usage:
  equitystack current-admin discover [args]

Runs:
  python3 scripts/discover_current_admin_updates.py [args]

Wrapper defaults:
  --model $DEFAULT_MODEL_VERIFIER
  --timeout $DEFAULT_OLLAMA_TIMEOUT_VERIFIER
  --ollama-url $DEFAULT_OLLAMA_URL  (legacy alias for the configured LLM endpoint)
EOF
      ;;
    export)
      cat <<EOF
Usage:
  equitystack current-admin export [args]

Runs:
  python3 scripts/export_current_admin_discovery_candidates.py [args]
EOF
      ;;
    gen-batch|generate-batch)
      cat <<EOF
Usage:
  equitystack current-admin gen-batch [--input <discovery-report.json>] [selection flags | --all-candidates] [--batch-name <batch-name>] [--output <batch.json>]

Runs:
  python3 scripts/generate_current_admin_batch_from_discovery.py [args]

This generates a canonical current-admin batch ready for workflow start or current-admin run --input.
EOF
      ;;
    normalize)
      cat <<EOF
Usage:
  equitystack current-admin normalize [args]

Runs:
  python3 scripts/normalize_current_admin_batch.py [args]
EOF
      ;;
    review)
      cat <<EOF
Usage:
  equitystack current-admin review [--input <ai-review.json> | --batch-name <batch-name>] [--decision-file <decision-template.json>] [--refresh-template] [--log-decisions [path]] [--feedback-summary]

Generates the canonical decision template when needed and finalizes explicit operator decisions only when the decision file is valid.
The default decision template path is reports/current_admin/<batch-name>.decision-template.json.
EOF
      ;;
    ai-review)
      cat <<EOF
Usage:
  equitystack current-admin ai-review [args]

Runs:
  python3 scripts/review_current_admin_batch_with_openai_batch.py [args]

Wrapper defaults:
  --model $DEFAULT_CURRENT_ADMIN_REVIEW_MODEL
  --verifier-model $DEFAULT_CURRENT_ADMIN_VERIFIER_MODEL
  --fallback-model $DEFAULT_CURRENT_ADMIN_FALLBACK_MODEL
  --senior-timeout $DEFAULT_OLLAMA_TIMEOUT_SENIOR
  --verifier-timeout $DEFAULT_OLLAMA_TIMEOUT_VERIFIER
  --review-mode deep
  --openai-base-url $DEFAULT_CURRENT_ADMIN_OPENAI_BASE_URL

Lifecycle flags:
  --batch-status   Show local Batch metadata and remote status when possible; no resubmit.
  --batch-poll     Poll the existing batch from local metadata; no resubmit.
  --batch-fetch    Download available output/error JSONL files; no resubmit.
  --batch-inspect  Show concise readiness and validation counts.
  --batch-resume   Poll/fetch/rebuild the canonical .ai-review.json when possible; no resubmit.

Evidence packaging:
  --evidence-preview  Build and print the model-facing .evidence-pack.json sidecar without submitting review.

Paired evaluation:
  --paired-experiment        Route to the paired baseline/enriched experiment runner.
  --experiment-name <name>   Stable local experiment name for artifact naming.
  --prep-only                Prepare .paired-eval.meta.json without submitting.
  --poll|--fetch|--resume    Continue both sides without duplicate submission.
  --compare                 Run comparison when both review artifacts are available.
EOF
      ;;
    queue)
      cat <<EOF
Usage:
  equitystack current-admin queue [args]

Runs:
  python3 scripts/apply_current_admin_ai_review.py [args]
EOF
      ;;
    promote-review)
      cat <<EOF
Usage:
  equitystack current-admin promote-review --input <enriched.ai-review.json> [--dry-run]
  equitystack current-admin promote-review --batch-name <batch-name> [--dry-run]

Regenerates the canonical manual-review queue from an enriched review artifact and
auto-approves only impact_pending/import_with_pending_impact items. It also writes
matching promotion decision metadata so pre-commit/import lineage checks remain intact.
EOF
      ;;
    run)
      cat <<EOF
Usage:
  equitystack current-admin run [--input <batch-file> | --batch-name <batch-name>] [--discovery-dry-run] [--discovery-output <report.json>] [--output <batch.json>] [--output-name <batch-name>] [workflow review args]

Default path without --input:
  discover -> gen-batch -> workflow start

Manual path with --input:
  workflow start only
EOF
      ;;
    apply)
      cat <<EOF
Usage:
  equitystack current-admin apply [--input <manual-review-queue.json> | --batch-name <batch-name>] [--apply --yes]

Runs the guarded operator apply path:
  pre-commit -> import dry-run -> optional import apply -> validate

Database writes still require --apply --yes.
EOF
      ;;
    status)
      cat <<EOF
Usage:
  equitystack current-admin status [--input <batch-file> | --batch-name <batch-name>] [--json] [--focus <all|blocked|incomplete|finalize-safe|apply-safe|manual-review|calibration|simulation|evidence-pack|comparison|paired-experiment>]

Shows artifact presence, current workflow state, blocking issues, and the recommended next command.
Use --json for the sidecar-derived OpenAI Batch read model. --focus and the aliases
--blocked, --incomplete, --finalize-safe, and --apply-safe imply JSON output.
Use --manual-review or --focus manual-review for the manual-review read model. Manual-review
filters: --reason <schema|conflicting-sources|weak-evidence|unclear|low-confidence|manual-review-requested|ambiguous-subject|date-uncertain>,
--confidence-bucket <0.00-0.59|0.60-0.74|0.75-0.84|0.85+>, --unresolved-only,
--readiness <needs-artifact-repair|needs-evidence-verification|needs-operator-judgment|ready-for-operator-decision>,
--schema-blocked-only, --judgment-required-only.
Use --calibration or --focus calibration for rule-based calibration diagnostics.
Calibration filters: --quality-focus <all|low-confidence-heavy|weak-evidence-heavy|unclear-heavy|high-manual-review|structurally-valid-but-decision-thin>,
--manual-review-only, --unresolved-only, --all-batches.
Use --simulation or --focus simulation for read-only threshold simulations.
Simulation filters: --preset <strict-current|slightly-relaxed|moderate-relaxed|confidence-only-test>,
--simulation-focus <all|threshold-sensitive|evidence-blocked|flag-blocked|threshold-only-promotions>,
--include-deltas, --manual-review-only, --all-batches.
Simulation overrides: --confidence-auto-approve-threshold <float>, --confidence-manual-review-floor <float>,
--allow-high-confidence-flagged-items-to-stay-blocked <true|false>,
--treat-unclear-as-always-manual-review <true|false>,
--treat-weak-evidence-as-always-manual-review <true|false>,
--treat-conflicting-sources-as-always-manual-review <true|false>,
--treat-date-uncertain-as-always-manual-review <true|false>,
--treat-ambiguous-subject-as-always-manual-review <true|false>,
--treat-model-manual-review-as-always-manual-review <true|false>.
Use --evidence-pack or --focus evidence-pack for evidence-pack/source-grounding diagnostics.
Evidence-pack filters: --evidence-focus <all|single-source-official|outcome-evidence-present|policy-intent-only|weak-outcome-evidence|multi-source-grounding>,
--evidence-quality-label <label>, --source-grounding-label <label>,
--impact-directness-hint <hint>, --item-id <stable-item-id>, --include-items, --all-batches.
Use --compare-review-runs or --focus comparison for baseline-vs-enriched review quality comparison.
Comparison inputs: --baseline <ai-review.json> --enriched <ai-review.json>.
Comparison filters: --batch-name <name>, --include-item-deltas.
Use --paired-experiment or --focus paired-experiment for paired evaluation tracking.
Paired-experiment filters: --batch-name <name>, --experiment-name <name>.

Relative --input paths may be given as data/... or python/data/...
EOF
      ;;
    import)
      cat <<EOF
Usage:
  equitystack current-admin import [args]

Runs:
  python3 scripts/import_curated_current_admin_batch.py [args]

Import stays dry-run by default. Database writes still require --apply --yes.
EOF
      ;;
    pre-commit)
      cat <<EOF
Usage:
  equitystack current-admin pre-commit [args]

Runs:
  python3 scripts/build_current_admin_precommit_review.py [args]
EOF
      ;;
    validate)
      cat <<EOF
Usage:
  equitystack current-admin validate [args]

Runs:
  python3 scripts/validate_current_admin_import.py [args]
EOF
      ;;
    *)
      current_admin_usage
      ;;
  esac
}

case "${1:-}" in
  ""|-h|--help|help)
    main_usage
    ;;
  admin-reset-operational-state)
    shift
    reset_success_message="Operational reset preview complete"
    reset_step_title="Preview Operational Reset"
    if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
      admin_reset_operational_state_usage
      exit 0
    fi
    for arg in "$@"; do
      if [ "$arg" = "--apply" ]; then
        reset_success_message="Operational artifacts archived for a fresh walkthrough"
        reset_step_title="Reset Operational State"
        break
      fi
    done
    run_step "1/1" "$reset_step_title" "$reset_success_message" -- \
      "$VENV_PYTHON" scripts/admin_reset_operational_state.py "$@"
    ;;
  legislative)
    shift
    run_legislative_command "${1:-help}" "${@:2}"
    ;;
  impact)
    shift
    run_impact_command "${1:-help}" "${@:2}"
    ;;
  operator)
    shift
    run_operator_command "${1:-help}" "${@:2}"
    ;;
  current-admin)
    shift
    run_current_admin_command "${1:-help}" "${@:2}"
    ;;
  run|review|apply|import|feedback)
    run_legislative_command "$@"
    ;;
  *)
    echo "Unknown command: ${1:-}" >&2
    main_usage
    exit 1
    ;;
esac
