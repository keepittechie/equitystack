#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
# shellcheck source=bin/lib/equitystack_workflow.sh
source "$SCRIPT_DIR/lib/equitystack_workflow.sh"
# shellcheck source=bin/lib/current_admin_operator_surface.sh
source "$SCRIPT_DIR/lib/current_admin_operator_surface.sh"
initialize_equitystack_environment "$SCRIPT_PATH"
cd "$EQUITYSTACK_PYTHON_DIR"

cli_hint() {
  printf './bin/equitystack'
}

pipeline_report_path() {
  printf '%s/reports/equitystack_pipeline_report.json\n' "$EQUITYSTACK_PYTHON_DIR"
}

review_bundle_path() {
  printf '%s/reports/equitystack_review_bundle.json\n' "$EQUITYSTACK_PYTHON_DIR"
}

apply_report_path() {
  printf '%s/reports/equitystack_apply_report.json\n' "$EQUITYSTACK_PYTHON_DIR"
}

future_bill_ai_review_path() {
  printf '%s/reports/future_bill_link_ai_review.json\n' "$EQUITYSTACK_PYTHON_DIR"
}

future_bill_manual_queue_path() {
  printf '%s/reports/future_bill_link_manual_review_queue.json\n' "$EQUITYSTACK_PYTHON_DIR"
}

future_bill_suggestion_path() {
  printf '%s/reports/future_bill_link_partial_suggestions.json\n' "$EQUITYSTACK_PYTHON_DIR"
}

future_bill_discovery_path() {
  printf '%s/reports/future_bill_candidate_discovery.json\n' "$EQUITYSTACK_PYTHON_DIR"
}

current_admin_reports_dir() {
  printf '%s/reports/current_admin\n' "$EQUITYSTACK_PYTHON_DIR"
}

current_admin_report_path() {
  local batch_name="$1"
  local suffix="$2"
  printf '%s/%s.%s.json\n' "$(current_admin_reports_dir)" "$batch_name" "$suffix"
}

current_admin_decision_log_dir() {
  printf '%s/review_decisions\n' "$(current_admin_reports_dir)"
}

apply_report_has_affected_bills() {
  local report_path
  report_path="$(apply_report_path)"
  if [ ! -f "$report_path" ]; then
    return 1
  fi

  local affected="no"
  affected="$(APPLY_REPORT_PATH="$report_path" "$VENV_PYTHON" - <<'PY'
import json
import os
from pathlib import Path

path = Path(os.environ["APPLY_REPORT_PATH"])
try:
    payload = json.loads(path.read_text())
except Exception:
    print("no")
    raise SystemExit(0)

affected = payload.get("affected_future_bill_ids") or []
print("yes" if affected else "no")
PY
)"
  [ "$affected" = "yes" ]
}

read_precommit_status() {
  local precommit_path="$1"
  if [ ! -f "$precommit_path" ]; then
    printf 'missing\n'
    return 0
  fi

  PRECOMMIT_PATH="$precommit_path" "$VENV_PYTHON" - <<'PY'
import json
import os
from pathlib import Path

path = Path(os.environ["PRECOMMIT_PATH"])
try:
    payload = json.loads(path.read_text())
except Exception:
    print("error")
    raise SystemExit(0)

status = payload.get("readiness_status")
print(status.strip() if isinstance(status, str) and status.strip() else "unknown")
PY
}

resolve_current_admin_context() {
  local input_path="${1:-}"
  local batch_name="${2:-}"
  local -a context_lines=()

  mapfile -t context_lines < <(
    EQUITYSTACK_PYTHON_DIR="$EQUITYSTACK_PYTHON_DIR" \
    CURRENT_ADMIN_INPUT="$input_path" \
    CURRENT_ADMIN_BATCH_NAME="$batch_name" \
    "$VENV_PYTHON" - <<'PY'
import json
import os
from pathlib import Path

python_dir = Path(os.environ["EQUITYSTACK_PYTHON_DIR"]).resolve()
batches_dir = python_dir / "data" / "current_admin_batches"
reports_dir = python_dir / "reports" / "current_admin"
input_arg = os.environ.get("CURRENT_ADMIN_INPUT", "").strip()
batch_name_arg = os.environ.get("CURRENT_ADMIN_BATCH_NAME", "").strip()


def read_batch_name(path: Path) -> str:
    payload = json.loads(path.read_text())
    batch_name = payload.get("batch_name")
    if not isinstance(batch_name, str) or not batch_name.strip():
        raise SystemExit(f"Batch file missing batch_name: {path}")
    return batch_name.strip()


def latest_batch_file() -> Path | None:
    candidates = [path for path in batches_dir.glob("*.json") if path.is_file()]
    if not candidates:
        return None
    return max(candidates, key=lambda path: path.stat().st_mtime)


def find_batch_file_by_name(target: str) -> Path | None:
    for path in sorted(batches_dir.glob("*.json")):
        if not path.is_file():
            continue
        try:
            if read_batch_name(path) == target:
                return path
        except Exception:
            continue
    return None


def infer_batch_path_from_reports(target: str) -> Path | None:
    normalization_report = reports_dir / f"{target}.normalization-report.json"
    if normalization_report.is_file():
        try:
            payload = json.loads(normalization_report.read_text())
            source_path = payload.get("source_path")
            if isinstance(source_path, str) and source_path.strip():
                return resolve_cli_input_path(source_path)
        except Exception:
            pass

    normalized_path = reports_dir / f"{target}.normalized.json"
    if normalized_path.is_file():
        return normalized_path

    queue_path = reports_dir / f"{target}.manual-review-queue.json"
    if queue_path.is_file():
        try:
            payload = json.loads(queue_path.read_text())
            source_batch = payload.get("source_batch_path")
            if isinstance(source_batch, str) and source_batch.strip():
                return resolve_cli_input_path(source_batch)
        except Exception:
            pass

    review_path = reports_dir / f"{target}.ai-review.json"
    if review_path.is_file():
        return review_path

    return None


def resolve_cli_input_path(raw_value: str) -> Path:
    candidate = Path(raw_value)
    if candidate.is_absolute():
        return candidate.resolve()

    candidates = [
        (python_dir / candidate).resolve(),
        (python_dir.parent / candidate).resolve(),
    ]
    for resolved in candidates:
        if resolved.exists():
            return resolved
    return candidates[0]


if input_arg:
    batch_file = resolve_cli_input_path(input_arg)
    if not batch_file.exists():
        raise SystemExit(f"Batch file not found: {batch_file}")
    resolved_batch_name = read_batch_name(batch_file)
elif batch_name_arg:
    batch_file = find_batch_file_by_name(batch_name_arg)
    if batch_file is None:
        batch_file = infer_batch_path_from_reports(batch_name_arg)
    if batch_file is None:
        raise SystemExit(f"Could not find current-admin artifacts for batch_name={batch_name_arg}")
    resolved_batch_name = batch_name_arg
else:
    batch_file = latest_batch_file()
    if batch_file is None:
        raise SystemExit("No current-admin batch files were found under data/current_admin_batches/")
    resolved_batch_name = read_batch_name(batch_file)

print(batch_file)
print(resolved_batch_name)
print(reports_dir / f"{resolved_batch_name}.normalized.json")
print(reports_dir / f"{resolved_batch_name}.ai-review.json")
print(reports_dir / f"{resolved_batch_name}.manual-review-queue.json")
print(reports_dir / f"{resolved_batch_name}.pre-commit-review.json")
print(reports_dir / f"{resolved_batch_name}.import-dry-run.json")
print(reports_dir / f"{resolved_batch_name}.import-apply.json")
print(reports_dir / f"{resolved_batch_name}.import-validation.json")
PY
  )

  if [ "${#context_lines[@]}" -lt 9 ]; then
    echo "Failed to resolve current-admin batch context." >&2
    exit 1
  fi

  CURRENT_ADMIN_INPUT_PATH="${context_lines[0]}"
  CURRENT_ADMIN_BATCH_NAME="${context_lines[1]}"
  CURRENT_ADMIN_NORMALIZED_PATH="${context_lines[2]}"
  CURRENT_ADMIN_REVIEW_PATH="${context_lines[3]}"
  CURRENT_ADMIN_QUEUE_PATH="${context_lines[4]}"
  CURRENT_ADMIN_PRECOMMIT_PATH="${context_lines[5]}"
  CURRENT_ADMIN_IMPORT_DRY_RUN_PATH="${context_lines[6]}"
  CURRENT_ADMIN_IMPORT_APPLY_PATH="${context_lines[7]}"
  CURRENT_ADMIN_VALIDATION_PATH="${context_lines[8]}"
}

resolve_review_artifact_context() {
  local review_path="${1:-}"
  local -a context_lines=()

  mapfile -t context_lines < <(
    EQUITYSTACK_PYTHON_DIR="$EQUITYSTACK_PYTHON_DIR" \
    REVIEW_ARTIFACT_INPUT="$review_path" \
    "$VENV_PYTHON" - <<'PY'
import json
import os
from pathlib import Path

python_dir = Path(os.environ["EQUITYSTACK_PYTHON_DIR"]).resolve()
reports_dir = python_dir / "reports" / "current_admin"
input_arg = os.environ.get("REVIEW_ARTIFACT_INPUT", "").strip()

if not input_arg:
    raise SystemExit("A review artifact path is required.")

def resolve_cli_input_path(raw_value: str) -> Path:
    candidate = Path(raw_value)
    if candidate.is_absolute():
        return candidate.resolve()

    candidates = [
        (python_dir / candidate).resolve(),
        (python_dir.parent / candidate).resolve(),
    ]
    for resolved in candidates:
        if resolved.exists():
            return resolved
    return candidates[0]


review_file = resolve_cli_input_path(input_arg)

if not review_file.exists():
    raise SystemExit(f"Review artifact not found: {review_file}")

payload = json.loads(review_file.read_text())
batch_name = payload.get("batch_name")
if not isinstance(batch_name, str) or not batch_name.strip():
    raise SystemExit(f"Review artifact missing batch_name: {review_file}")
batch_name = batch_name.strip()

normalized_input = payload.get("input_path")
if not isinstance(normalized_input, str) or not normalized_input.strip():
    raise SystemExit(f"Review artifact missing input_path: {review_file}")

normalized_path = resolve_cli_input_path(normalized_input)

print(review_file)
print(batch_name)
print(normalized_path)
print(payload.get("requested_model") or payload.get("model") or "")
print(payload.get("verifier_model") or "")
print(payload.get("fallback_model") or "")
print(payload.get("review_mode") or "standard")
print("true" if payload.get("dry_run") else "false")
print(payload.get("senior_timeout_seconds") or payload.get("timeout_seconds") or "")
print(payload.get("verifier_timeout_seconds") or payload.get("timeout_seconds") or "")
print(reports_dir / f"{batch_name}.manual-review-queue.json")
PY
  )

  if [ "${#context_lines[@]}" -lt 11 ]; then
    echo "Failed to resolve review artifact context." >&2
    exit 1
  fi

  REVIEW_ARTIFACT_PATH="${context_lines[0]}"
  REVIEW_ARTIFACT_BATCH_NAME="${context_lines[1]}"
  REVIEW_ARTIFACT_NORMALIZED_PATH="${context_lines[2]}"
  REVIEW_ARTIFACT_MODEL="${context_lines[3]}"
  REVIEW_ARTIFACT_VERIFIER_MODEL="${context_lines[4]}"
  REVIEW_ARTIFACT_FALLBACK_MODEL="${context_lines[5]}"
  REVIEW_ARTIFACT_MODE="${context_lines[6]}"
  REVIEW_ARTIFACT_DRY_RUN="${context_lines[7]}"
  REVIEW_ARTIFACT_TIMEOUT="${context_lines[8]}"
  REVIEW_ARTIFACT_VERIFIER_TIMEOUT="${context_lines[9]}"
  REVIEW_ARTIFACT_QUEUE_PATH="${context_lines[10]}"
}

detect_current_admin_state() {
  local precommit_status="${1:-missing}"
  local queue_approved_count="0"

  CURRENT_ADMIN_STATE="DISCOVERY_READY"
  CURRENT_ADMIN_NEXT_STEP="Run the next current-admin batch and prepare operator review"
  CURRENT_ADMIN_NEXT_COMMAND="$(cli_hint) current-admin run --input $(repo_relative_path "$CURRENT_ADMIN_INPUT_PATH")"
  CURRENT_ADMIN_BLOCKING_ISSUES=()
  CURRENT_ADMIN_MISSING_ARTIFACTS=()

  if [ -f "$CURRENT_ADMIN_PRECOMMIT_PATH" ] && [ "$precommit_status" = "blocked" ]; then
    CURRENT_ADMIN_STATE="BLOCKED"
    CURRENT_ADMIN_NEXT_STEP="Resolve the blocking issues in the pre-commit review"
    CURRENT_ADMIN_NEXT_COMMAND="$(cli_hint) current-admin apply --input $(repo_relative_path "$CURRENT_ADMIN_QUEUE_PATH")"
    CURRENT_ADMIN_BLOCKING_ISSUES=("pre-commit review is blocked")
    return 0
  fi

  if [ ! -f "$CURRENT_ADMIN_NORMALIZED_PATH" ]; then
    CURRENT_ADMIN_MISSING_ARTIFACTS=("normalized batch")
    return 0
  fi

  if [ ! -f "$CURRENT_ADMIN_REVIEW_PATH" ]; then
    CURRENT_ADMIN_STATE="NORMALIZED"
    CURRENT_ADMIN_NEXT_STEP="Run the operator review against the normalized batch"
    CURRENT_ADMIN_NEXT_COMMAND="$(cli_hint) current-admin ai-review --input $(repo_relative_path "$CURRENT_ADMIN_NORMALIZED_PATH")"
    CURRENT_ADMIN_MISSING_ARTIFACTS=("AI review report")
    return 0
  fi

  if [ ! -f "$CURRENT_ADMIN_QUEUE_PATH" ]; then
    CURRENT_ADMIN_STATE="REVIEW_READY"
    CURRENT_ADMIN_NEXT_STEP="Build the manual review queue"
    CURRENT_ADMIN_NEXT_COMMAND="$(cli_hint) current-admin queue --batch $(repo_relative_path "$CURRENT_ADMIN_NORMALIZED_PATH") --review $(repo_relative_path "$CURRENT_ADMIN_REVIEW_PATH")"
    CURRENT_ADMIN_MISSING_ARTIFACTS=("manual review queue")
    return 0
  fi

  local batch_safety_status="safe"
  batch_safety_status="$(
    EQUITYSTACK_PYTHON_DIR="$EQUITYSTACK_PYTHON_DIR" CURRENT_ADMIN_REVIEW_PATH="$CURRENT_ADMIN_REVIEW_PATH" "$VENV_PYTHON" - <<'PY'
import os
import sys
from pathlib import Path

review_path = Path(os.environ["CURRENT_ADMIN_REVIEW_PATH"])
sys.path.insert(0, str(Path(os.environ["EQUITYSTACK_PYTHON_DIR"]) / "scripts"))
from current_admin_openai_batch_guardrails import evaluate_review_batch_safety

if not review_path.exists():
    print("safe")
    raise SystemExit(0)
safety = evaluate_review_batch_safety(review_path)
if not safety.get("metadata_present"):
    print("safe")
elif safety.get("blocking_issues"):
    print("blocked")
else:
    print("safe")
PY
  )"
  if [ "$batch_safety_status" = "blocked" ]; then
    CURRENT_ADMIN_STATE="BATCH_REVIEW_INCOMPLETE"
    CURRENT_ADMIN_NEXT_STEP="Resume the OpenAI Batch review until output is fetched, validated, and the canonical review artifact is rebuilt"
    CURRENT_ADMIN_NEXT_COMMAND="$(cli_hint) current-admin ai-review --input $(repo_relative_path "$CURRENT_ADMIN_REVIEW_PATH") --batch-resume"
    CURRENT_ADMIN_BLOCKING_ISSUES=("OpenAI Batch review sidecars are incomplete or invalid")
    return 0
  fi

  if [ -f "$CURRENT_ADMIN_QUEUE_PATH" ]; then
    queue_approved_count="$(
      CURRENT_ADMIN_QUEUE_PATH="$CURRENT_ADMIN_QUEUE_PATH" "$VENV_PYTHON" - <<'PY'
import json
import os
from pathlib import Path

queue_path = Path(os.environ["CURRENT_ADMIN_QUEUE_PATH"]).resolve()
payload = json.loads(queue_path.read_text()) if queue_path.exists() else {}
items = payload.get("items") or []
count = sum(
    1
    for item in items
    if isinstance(item, dict) and (item.get("approved") or item.get("operator_status") == "approved")
)
print(count)
PY
    )"
  fi

  if [ ! -f "$CURRENT_ADMIN_PRECOMMIT_PATH" ]; then
    if [ "${queue_approved_count:-0}" -le 0 ]; then
      CURRENT_ADMIN_STATE="BLOCKED"
      CURRENT_ADMIN_NEXT_STEP="No queue items are approved for import. Reopen current-admin review and rerun finalize if import candidates should proceed."
      CURRENT_ADMIN_NEXT_COMMAND="$(cli_hint) current-admin review --input $(repo_relative_path "$CURRENT_ADMIN_REVIEW_PATH")"
      CURRENT_ADMIN_BLOCKING_ISSUES=("no queue items are approved for import")
    else
      CURRENT_ADMIN_STATE="QUEUE_READY"
      CURRENT_ADMIN_NEXT_STEP="Run the guarded apply path starting with pre-commit and dry-run import"
      CURRENT_ADMIN_NEXT_COMMAND="$(cli_hint) current-admin apply --input $(repo_relative_path "$CURRENT_ADMIN_QUEUE_PATH")"
      CURRENT_ADMIN_MISSING_ARTIFACTS=("pre-commit review")
    fi
    return 0
  fi

  if [ ! -f "$CURRENT_ADMIN_IMPORT_APPLY_PATH" ]; then
    CURRENT_ADMIN_STATE="PRECOMMIT_READY"
    CURRENT_ADMIN_NEXT_STEP="Run the guarded apply path. It will rerun pre-commit and then import dry-run before any explicit apply."
    CURRENT_ADMIN_NEXT_COMMAND="$(cli_hint) current-admin apply --input $(repo_relative_path "$CURRENT_ADMIN_QUEUE_PATH")"
    if [ ! -f "$CURRENT_ADMIN_IMPORT_DRY_RUN_PATH" ]; then
      CURRENT_ADMIN_MISSING_ARTIFACTS=("import apply report")
    fi
    return 0
  fi

  if [ ! -f "$CURRENT_ADMIN_VALIDATION_PATH" ]; then
    CURRENT_ADMIN_STATE="IMPORT_READY"
    CURRENT_ADMIN_NEXT_STEP="Validate the applied import"
    CURRENT_ADMIN_NEXT_COMMAND="$(cli_hint) current-admin validate --input $(repo_relative_path "$CURRENT_ADMIN_QUEUE_PATH")"
    CURRENT_ADMIN_MISSING_ARTIFACTS=("validation report")
    return 0
  fi

  CURRENT_ADMIN_STATE="COMPLETE"
  CURRENT_ADMIN_NEXT_STEP="Workflow complete. Start the next discovery or review cycle."
  CURRENT_ADMIN_NEXT_COMMAND="$(cli_hint) current-admin run"
}

print_current_admin_status() {
  local input_path="${1:-}"
  local batch_name="${2:-}"
  local output_json="${3:-false}"
  local focus="${4:-all}"
  local reason="${5:-}"
  local confidence_bucket="${6:-}"
  local unresolved_only="${7:-false}"
  local readiness="${8:-}"
  local schema_blocked_only="${9:-false}"
  local judgment_required_only="${10:-false}"
  local quality_focus="${11:-all}"
  local manual_review_only="${12:-false}"
  local calibration_all_batches="${13:-false}"
  local simulation_preset="${14:-slightly-relaxed}"
  local simulation_focus="${15:-all}"
  local include_deltas="${16:-false}"
  local confidence_auto_approve_threshold="${17:-}"
  local confidence_manual_review_floor="${18:-}"
  local allow_high_confidence_flagged_items_to_stay_blocked="${19:-}"
  local treat_unclear_as_always_manual_review="${20:-}"
  local treat_weak_evidence_as_always_manual_review="${21:-}"
  local treat_conflicting_sources_as_always_manual_review="${22:-}"
  local treat_date_uncertain_as_always_manual_review="${23:-}"
  local treat_ambiguous_subject_as_always_manual_review="${24:-}"
  local treat_model_manual_review_as_always_manual_review="${25:-}"
  local evidence_focus="${26:-all}"
  local evidence_quality_label="${27:-}"
  local source_grounding_label="${28:-}"
  local impact_directness_hint="${29:-}"
  local evidence_item_id="${30:-}"
  local include_items="${31:-false}"
  local comparison_baseline="${32:-}"
  local comparison_enriched="${33:-}"
  local paired_experiment_name="${34:-}"

  if [ "$focus" = "evidence-pack" ]; then
    local -a evidence_args=(--evidence-focus "$evidence_focus" --pretty)
    if [ -n "$batch_name" ]; then
      evidence_args+=(--batch-name "$batch_name")
    elif [ "$calibration_all_batches" != "true" ]; then
      resolve_current_admin_context "$input_path" "$batch_name"
      evidence_args+=(--batch-name "$CURRENT_ADMIN_BATCH_NAME")
    fi
    if [ -n "$evidence_quality_label" ]; then
      evidence_args+=(--evidence-quality-label "$evidence_quality_label")
    fi
    if [ -n "$source_grounding_label" ]; then
      evidence_args+=(--source-grounding-label "$source_grounding_label")
    fi
    if [ -n "$impact_directness_hint" ]; then
      evidence_args+=(--impact-directness-hint "$impact_directness_hint")
    fi
    if [ -n "$evidence_item_id" ]; then
      evidence_args+=(--item-id "$evidence_item_id")
    fi
    if [ "$include_items" = "true" ]; then
      evidence_args+=(--include-items)
    fi
    "$VENV_PYTHON" scripts/current_admin_evidence_pack.py "${evidence_args[@]}"
    return 0
  fi

  if [ "$focus" = "comparison" ]; then
    local -a comparison_args=(--pretty)
    if [ -n "$comparison_baseline" ]; then
      comparison_args+=(--baseline "$comparison_baseline")
    fi
    if [ -n "$comparison_enriched" ]; then
      comparison_args+=(--enriched "$comparison_enriched")
    fi
    if [ -n "$batch_name" ]; then
      comparison_args+=(--batch-name "$batch_name")
    elif [ -z "$comparison_baseline" ] && [ -z "$comparison_enriched" ]; then
      resolve_current_admin_context "$input_path" "$batch_name"
      comparison_args+=(--batch-name "$CURRENT_ADMIN_BATCH_NAME")
    fi
    if [ "$include_deltas" = "true" ]; then
      comparison_args+=(--include-item-deltas)
    fi
    "$VENV_PYTHON" scripts/current_admin_review_comparison_read_model.py "${comparison_args[@]}"
    return 0
  fi

  if [ "$focus" = "paired-experiment" ]; then
    local -a paired_args=(--status --pretty)
    if [ -n "$paired_experiment_name" ]; then
      paired_args+=(--experiment-name "$paired_experiment_name")
    fi
    if [ -n "$batch_name" ]; then
      paired_args+=(--batch-name "$batch_name")
    else
      resolve_current_admin_context "$input_path" "$batch_name"
      paired_args+=(--batch-name "$CURRENT_ADMIN_BATCH_NAME")
    fi
    "$VENV_PYTHON" scripts/current_admin_paired_evaluation.py "${paired_args[@]}"
    return 0
  fi

  if [ "$focus" = "simulation" ]; then
    local -a simulation_args=(--preset "$simulation_preset" --simulation-focus "$simulation_focus" --pretty)
    if [ -n "$batch_name" ]; then
      simulation_args+=(--batch-name "$batch_name")
    elif [ "$calibration_all_batches" != "true" ]; then
      resolve_current_admin_context "$input_path" "$batch_name"
      simulation_args+=(--batch-name "$CURRENT_ADMIN_BATCH_NAME")
    fi
    if [ "$include_deltas" = "true" ]; then
      simulation_args+=(--include-deltas)
    fi
    if [ "$manual_review_only" = "true" ]; then
      simulation_args+=(--manual-review-only)
    fi
    if [ -n "$confidence_auto_approve_threshold" ]; then
      simulation_args+=(--confidence-auto-approve-threshold "$confidence_auto_approve_threshold")
    fi
    if [ -n "$confidence_manual_review_floor" ]; then
      simulation_args+=(--confidence-manual-review-floor "$confidence_manual_review_floor")
    fi
    if [ -n "$allow_high_confidence_flagged_items_to_stay_blocked" ]; then
      simulation_args+=(--allow-high-confidence-flagged-items-to-stay-blocked "$allow_high_confidence_flagged_items_to_stay_blocked")
    fi
    if [ -n "$treat_unclear_as_always_manual_review" ]; then
      simulation_args+=(--treat-unclear-as-always-manual-review "$treat_unclear_as_always_manual_review")
    fi
    if [ -n "$treat_weak_evidence_as_always_manual_review" ]; then
      simulation_args+=(--treat-weak-evidence-as-always-manual-review "$treat_weak_evidence_as_always_manual_review")
    fi
    if [ -n "$treat_conflicting_sources_as_always_manual_review" ]; then
      simulation_args+=(--treat-conflicting-sources-as-always-manual-review "$treat_conflicting_sources_as_always_manual_review")
    fi
    if [ -n "$treat_date_uncertain_as_always_manual_review" ]; then
      simulation_args+=(--treat-date-uncertain-as-always-manual-review "$treat_date_uncertain_as_always_manual_review")
    fi
    if [ -n "$treat_ambiguous_subject_as_always_manual_review" ]; then
      simulation_args+=(--treat-ambiguous-subject-as-always-manual-review "$treat_ambiguous_subject_as_always_manual_review")
    fi
    if [ -n "$treat_model_manual_review_as_always_manual_review" ]; then
      simulation_args+=(--treat-model-manual-review-as-always-manual-review "$treat_model_manual_review_as_always_manual_review")
    fi
    "$VENV_PYTHON" scripts/current_admin_threshold_simulation_read_model.py "${simulation_args[@]}"
    return 0
  fi

  if [ "$focus" = "calibration" ] && [ "$calibration_all_batches" = "true" ]; then
    local -a all_calibration_args=(--quality-focus "$quality_focus" --pretty)
    if [ "$manual_review_only" = "true" ]; then
      all_calibration_args+=(--manual-review-only)
    fi
    if [ "$unresolved_only" = "true" ]; then
      all_calibration_args+=(--unresolved-only)
    fi
    "$VENV_PYTHON" scripts/current_admin_calibration_read_model.py "${all_calibration_args[@]}"
    return 0
  fi

  resolve_current_admin_context "$input_path" "$batch_name"

  if [ "$focus" = "calibration" ]; then
    local -a calibration_args=(--batch-name "$CURRENT_ADMIN_BATCH_NAME" --quality-focus "$quality_focus" --pretty)
    if [ "$manual_review_only" = "true" ]; then
      calibration_args+=(--manual-review-only)
    fi
    if [ "$unresolved_only" = "true" ]; then
      calibration_args+=(--unresolved-only)
    fi
    "$VENV_PYTHON" scripts/current_admin_calibration_read_model.py "${calibration_args[@]}"
    return 0
  fi

  if [ "$focus" = "manual-review" ]; then
    local -a manual_review_args=(--batch-name "$CURRENT_ADMIN_BATCH_NAME" --pretty)
    if [ -n "$reason" ]; then
      manual_review_args+=(--reason "$reason")
    fi
    if [ -n "$confidence_bucket" ]; then
      manual_review_args+=(--confidence-bucket "$confidence_bucket")
    fi
    if [ "$unresolved_only" = "true" ]; then
      manual_review_args+=(--unresolved-only)
    fi
    if [ -n "$readiness" ]; then
      manual_review_args+=(--readiness "$readiness")
    fi
    if [ "$schema_blocked_only" = "true" ]; then
      manual_review_args+=(--schema-blocked-only)
    fi
    if [ "$judgment_required_only" = "true" ]; then
      manual_review_args+=(--judgment-required-only)
    fi
    "$VENV_PYTHON" scripts/current_admin_manual_review_read_model.py "${manual_review_args[@]}"
    return 0
  fi

  if [ "$output_json" = "true" ]; then
    "$VENV_PYTHON" scripts/current_admin_batch_read_model.py \
      --batch-name "$CURRENT_ADMIN_BATCH_NAME" \
      --focus "$focus" \
      --pretty
    return 0
  fi

  local precommit_status="missing"
  precommit_status="$(read_precommit_status "$CURRENT_ADMIN_PRECOMMIT_PATH")"
  detect_current_admin_state "$precommit_status"

  printf 'BATCH: %s\n' "$CURRENT_ADMIN_BATCH_NAME"
  printf 'BATCH FILE: %s\n' "$(repo_relative_path "$CURRENT_ADMIN_INPUT_PATH")"
  printf 'ARTIFACTS:\n'
  printf '  %-18s %s\n' "Normalized:" "$(artifact_status_text "$CURRENT_ADMIN_NORMALIZED_PATH")"
  printf '  %-18s %s\n' "AI review:" "$(artifact_status_text "$CURRENT_ADMIN_REVIEW_PATH")"
  local batch_meta_path="${CURRENT_ADMIN_REVIEW_PATH%.ai-review.json}.openai-batch.meta.json"
  local batch_validation_path="${CURRENT_ADMIN_REVIEW_PATH%.ai-review.json}.openai-batch.validation.json"
  printf '  %-18s %s\n' "Batch metadata:" "$(artifact_status_text "$batch_meta_path")"
  printf '  %-18s %s\n' "Batch validation:" "$(artifact_status_text "$batch_validation_path")"
  printf '  %-18s %s\n' "Manual queue:" "$(artifact_status_text "$CURRENT_ADMIN_QUEUE_PATH")"
  printf '  %-18s %s\n' "Pre-commit:" "$(artifact_status_text "$CURRENT_ADMIN_PRECOMMIT_PATH")"
  printf '  %-18s %s\n' "Pre-commit state:" "$precommit_status"
  printf '  %-18s %s\n' "Import dry-run:" "$(artifact_status_text "$CURRENT_ADMIN_IMPORT_DRY_RUN_PATH")"
  printf '  %-18s %s\n' "Import apply:" "$(artifact_status_text "$CURRENT_ADMIN_IMPORT_APPLY_PATH")"
  printf '  %-18s %s\n' "Validation:" "$(artifact_status_text "$CURRENT_ADMIN_VALIDATION_PATH")"

  if [ -f "$batch_meta_path" ] || [ -f "$batch_validation_path" ]; then
    EQUITYSTACK_PYTHON_DIR="$EQUITYSTACK_PYTHON_DIR" CURRENT_ADMIN_REVIEW_PATH="$CURRENT_ADMIN_REVIEW_PATH" "$VENV_PYTHON" - <<'PY'
import json
import os
import sys
from pathlib import Path

python_dir = Path(os.environ["EQUITYSTACK_PYTHON_DIR"])
sys.path.insert(0, str(python_dir / "scripts"))
from current_admin_openai_batch_guardrails import evaluate_review_batch_safety

safety = evaluate_review_batch_safety(Path(os.environ["CURRENT_ADMIN_REVIEW_PATH"]))
counts = safety.get("validation_counts") or {}
print("OPENAI BATCH:")
print(f"  status: {safety.get('status') or 'unknown'}")
print(f"  batch_id: {safety.get('batch_id') or 'n/a'}")
print(f"  model: {safety.get('model') or 'n/a'}")
print(f"  output_ready: {'yes' if safety.get('output_ready') else 'no'}")
print(f"  validation_valid_items: {counts.get('valid_items', 'unknown')}")
print(f"  validation_malformed_items: {counts.get('malformed_items', 'unknown')}")
print(f"  finalize_apply_safe: {'yes' if safety.get('safe_to_apply') else 'no'}")
PY
  fi

  local -a detail_lines=()
  if [ "${#CURRENT_ADMIN_MISSING_ARTIFACTS[@]}" -gt 0 ]; then
    detail_lines+=("MISSING ARTIFACTS:")
    local missing_artifact=""
    for missing_artifact in "${CURRENT_ADMIN_MISSING_ARTIFACTS[@]}"; do
      detail_lines+=("  - $missing_artifact")
    done
  fi
  if [ "${#CURRENT_ADMIN_BLOCKING_ISSUES[@]}" -gt 0 ]; then
    detail_lines+=("BLOCKING ISSUES:")
    local blocking_issue=""
    for blocking_issue in "${CURRENT_ADMIN_BLOCKING_ISSUES[@]}"; do
      detail_lines+=("  - $blocking_issue")
    done
  fi

  print_system_state "$CURRENT_ADMIN_STATE" "$CURRENT_ADMIN_NEXT_STEP" "$CURRENT_ADMIN_NEXT_COMMAND" "${detail_lines[@]}"
}

run_current_admin_workflow_review() {
  local summary_requested="false"
  local preview_requested="false"
  local -a normalized_args=()
  local -a passthrough=()

  normalize_current_admin_path_args normalized_args "$@"
  set -- "${normalized_args[@]}"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --summary)
        summary_requested="true"
        passthrough+=("$1")
        shift
        ;;
      --preview)
        preview_requested="true"
        passthrough+=("$1")
        shift
        ;;
      -h|--help)
        current_admin_workflow_subcommand_usage review
        exit 0
        ;;
      *)
        passthrough+=("$1")
        shift
        ;;
    esac
  done

  if [ "$summary_requested" = "false" ] && [ "$preview_requested" = "false" ]; then
    passthrough+=(--summary)
  fi

  run_step "1/1" "Generate Decision Template" "Decision template generation complete" -- \
    "$VENV_PYTHON" scripts/generate_current_admin_decision_template.py "${passthrough[@]}"
}

run_current_admin_workflow_finalize() {
  local review_path=""
  local decision_file=""
  local log_decisions_set="false"
  local log_decisions_value=""
  local feedback_summary="false"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --review)
        review_path="${2:-}"
        [ -n "$review_path" ] || { echo "--review requires a value" >&2; exit 1; }
        shift 2
        ;;
      --decision-file)
        decision_file="${2:-}"
        [ -n "$decision_file" ] || { echo "--decision-file requires a value" >&2; exit 1; }
        shift 2
        ;;
      --log-decisions)
        log_decisions_set="true"
        if [ "${2:-}" != "" ] && [[ "${2:-}" != --* ]]; then
          log_decisions_value="${2}"
          shift 2
        else
          log_decisions_value=""
          shift
        fi
        ;;
      --feedback-summary)
        feedback_summary="true"
        shift
        ;;
      -h|--help)
        current_admin_workflow_subcommand_usage finalize
        exit 0
        ;;
      *)
        echo "Unknown argument for current-admin workflow finalize: $1" >&2
        exit 1
        ;;
    esac
  done

  [ -n "$review_path" ] || { echo "--review is required" >&2; exit 1; }
  [ -n "$decision_file" ] || { echo "--decision-file is required" >&2; exit 1; }
  [ "$log_decisions_set" = "true" ] || { echo "--log-decisions is required so decision logging stays explicit" >&2; exit 1; }

  review_path="$(normalize_python_workspace_path "$review_path")"
  decision_file="$(normalize_python_workspace_path "$decision_file")"
  if [ -n "$log_decisions_value" ]; then
    log_decisions_value="$(normalize_python_workspace_path "$log_decisions_value")"
  fi

  resolve_review_artifact_context "$review_path"

  local review_model="$REVIEW_ARTIFACT_MODEL"
  if [ -z "$review_model" ]; then
    review_model="$DEFAULT_CURRENT_ADMIN_REVIEW_MODEL"
  fi
  local verifier_model="$REVIEW_ARTIFACT_VERIFIER_MODEL"
  if [ -z "$verifier_model" ]; then
    verifier_model="$DEFAULT_CURRENT_ADMIN_VERIFIER_MODEL"
  fi
  local fallback_model="$REVIEW_ARTIFACT_FALLBACK_MODEL"
  if [ -z "$fallback_model" ]; then
    fallback_model="$DEFAULT_CURRENT_ADMIN_FALLBACK_MODEL"
  fi
  local senior_timeout="$REVIEW_ARTIFACT_TIMEOUT"
  if [ -z "$senior_timeout" ]; then
    senior_timeout="$DEFAULT_OLLAMA_TIMEOUT_SENIOR"
  fi
  local verifier_timeout="$REVIEW_ARTIFACT_VERIFIER_TIMEOUT"
  if [ -z "$verifier_timeout" ]; then
    verifier_timeout="$DEFAULT_OLLAMA_TIMEOUT_VERIFIER"
  fi
  local total_steps="2"
  if [ "$feedback_summary" = "true" ]; then
    total_steps="3"
  fi

  local -a finalize_args=(
    "$VENV_PYTHON"
    scripts/review_current_admin_batch_with_openai_batch.py
    --input "$REVIEW_ARTIFACT_PATH"
    --decision-file "$decision_file"
    --summary
    --model "$review_model"
    --verifier-model "$verifier_model"
    --fallback-model "$fallback_model"
    --review-mode "$REVIEW_ARTIFACT_MODE"
    --senior-timeout "$senior_timeout"
    --verifier-timeout "$verifier_timeout"
  )
  if [ "$REVIEW_ARTIFACT_DRY_RUN" = "true" ]; then
    finalize_args+=(--dry-run)
  fi
  if [ -n "$log_decisions_value" ]; then
    finalize_args+=(--log-decisions "$log_decisions_value")
  else
    finalize_args+=(--log-decisions)
  fi

  run_step "1/${total_steps}" "Replay Review Decisions" "Decision log written against the canonical review artifact" -- \
    "${finalize_args[@]}"

  local -a sync_queue_args=(
    "$VENV_PYTHON"
    scripts/sync_current_admin_queue_decisions.py
    --queue "$REVIEW_ARTIFACT_QUEUE_PATH"
    --decision-file "$decision_file"
  )
  if [ -n "$log_decisions_value" ]; then
    sync_queue_args+=(--decision-log "$log_decisions_value")
  fi

  run_step "2/${total_steps}" "Sync Manual Review Queue" "Queue approval state refreshed from canonical operator decisions" -- \
    "${sync_queue_args[@]}"

  if [ "$feedback_summary" = "true" ]; then
    run_step "3/${total_steps}" "Export Feedback Summary" "Feedback summary exported" -- \
      node scripts/export_current_admin_feedback_summary.mjs
  fi

  print_system_state \
    "QUEUE_READY" \
    "Generate the pre-commit artifact from the synchronized manual review queue" \
    "$(cli_hint) current-admin pre-commit --input $(repo_relative_path "$REVIEW_ARTIFACT_QUEUE_PATH")" \
    "REVIEW ARTIFACT: $(repo_relative_path "$REVIEW_ARTIFACT_PATH")" \
    "DECISION FILE: $decision_file" \
    "MANUAL QUEUE: $(repo_relative_path "$REVIEW_ARTIFACT_QUEUE_PATH")"
}

print_current_admin_workflow_resume() {
  EQUITYSTACK_PYTHON_DIR="$EQUITYSTACK_PYTHON_DIR" "$VENV_PYTHON" - <<'PY'
import json
import os
from pathlib import Path

python_dir = Path(os.environ["EQUITYSTACK_PYTHON_DIR"]).resolve()
reports_dir = python_dir / "reports" / "current_admin"
decision_dir = reports_dir / "review_decisions"


def newest(paths):
    paths = [path for path in paths if path.is_file()]
    if not paths:
        return None
    return max(paths, key=lambda path: path.stat().st_mtime)


latest_decision = newest(decision_dir.glob("*.json"))
latest_review = newest(reports_dir.glob("*.ai-review.json"))

if latest_decision is not None:
    payload = json.loads(latest_decision.read_text())
    review_path = payload.get("source_review_file") or ""
    session_id = payload.get("session_id") or latest_decision.stem
    session_focus = payload.get("session_focus") or "unspecified"
    generated_at = payload.get("generated_at") or "unknown"
    item_count = len(payload.get("items") or [])
    batch_name = Path(review_path).name.replace(".ai-review.json", "") if review_path else "unknown"
    queue_path = reports_dir / f"{batch_name}.manual-review-queue.json" if batch_name != "unknown" else None
    queue_payload = json.loads(queue_path.read_text()) if queue_path and queue_path.exists() else {}
    queue_items = queue_payload.get("items") or []
    queue_approved = sum(
        1
        for item in queue_items
        if isinstance(item, dict) and (item.get("approved") or item.get("operator_status") == "approved")
    )

    print(f"LATEST SESSION: {session_id}")
    print(f"SESSION FOCUS: {session_focus}")
    print(f"GENERATED: {generated_at}")
    print(f"ITEMS LOGGED: {item_count}")
    print(f"SOURCE REVIEW: {review_path or 'unknown'}")
    if queue_path is not None:
        print(f"QUEUE APPROVED FOR IMPORT: {queue_approved}")
    print()
    if queue_approved > 0:
        print("SYSTEM STATE: QUEUE_READY")
        print("NEXT STEP: Run the guarded apply flow starting with pre-commit")
    else:
        print("SYSTEM STATE: BLOCKED")
        print("NEXT STEP: Review decisions are logged, but no queue items are approved for import yet.")
    if batch_name != "unknown":
        queue_path_text = f"reports/current_admin/{batch_name}.manual-review-queue.json"
        if queue_approved > 0:
            print(f"RECOMMENDED COMMAND: ./bin/equitystack current-admin apply --input {queue_path_text}")
        else:
            print(
                "RECOMMENDED COMMAND: "
                f"./bin/equitystack current-admin review --input reports/current_admin/{Path(review_path).name}"
            )
        print(f"FOLLOW UP: ./bin/equitystack current-admin status --batch-name {batch_name}")
    else:
        print("RECOMMENDED COMMAND: ./bin/equitystack current-admin status")
elif latest_review is not None:
    payload = json.loads(latest_review.read_text())
    batch_name = payload.get("batch_name") or latest_review.name.replace(".ai-review.json", "")
    output_name = latest_review.name.replace(".ai-review.json", ".decision-template.json")

    print(f"LATEST REVIEW ARTIFACT: {latest_review}")
    print(f"BATCH NAME: {batch_name}")
    print()
    print("SYSTEM STATE: REVIEW_READY")
    print("NEXT STEP: Generate or finalize operator decisions for the review artifact")
    print(
        "RECOMMENDED COMMAND: "
        f"./bin/equitystack current-admin review --input reports/current_admin/{latest_review.name}"
    )
else:
    print("SYSTEM STATE: DISCOVERY_READY")
    print("NEXT STEP: Start the next current-admin run")
    print("RECOMMENDED COMMAND: ./bin/equitystack current-admin run")
PY
}

run_current_admin_workflow_start() {
  local input_path=""
  local batch_name=""
  local review_dry_run="false"
  local prefill_suggestions="false"
  local review_model=""
  local verifier_model=""
  local fallback_model=""
  local review_mode=""
  local deep_review="false"
  local ollama_url="$DEFAULT_OLLAMA_URL"
  local timeout=""
  local senior_timeout="$DEFAULT_OLLAMA_TIMEOUT_SENIOR"
  local verifier_timeout="$DEFAULT_OLLAMA_TIMEOUT_VERIFIER"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --input)
        input_path="${2:-}"
        [ -n "$input_path" ] || { echo "--input requires a value" >&2; exit 1; }
        shift 2
        ;;
      --batch-name)
        batch_name="${2:-}"
        [ -n "$batch_name" ] || { echo "--batch-name requires a value" >&2; exit 1; }
        shift 2
        ;;
      --review-dry-run)
        review_dry_run="true"
        shift
        ;;
      --prefill-suggestions)
        prefill_suggestions="true"
        shift
        ;;
      --model)
        review_model="${2:-}"
        [ -n "$review_model" ] || { echo "--model requires a value" >&2; exit 1; }
        shift 2
        ;;
      --verifier-model)
        verifier_model="${2:-}"
        [ -n "$verifier_model" ] || { echo "--verifier-model requires a value" >&2; exit 1; }
        shift 2
        ;;
      --fallback-model)
        fallback_model="${2:-}"
        [ -n "$fallback_model" ] || { echo "--fallback-model requires a value" >&2; exit 1; }
        shift 2
        ;;
      --review-mode)
        review_mode="${2:-}"
        [ -n "$review_mode" ] || { echo "--review-mode requires a value" >&2; exit 1; }
        if [ "$review_mode" != "standard" ] && [ "$review_mode" != "deep" ]; then
          echo "--review-mode must be standard or deep" >&2
          exit 1
        fi
        shift 2
        ;;
      --deep-review)
        deep_review="true"
        shift
        ;;
      --ollama-url)
        ollama_url="${2:-}"
        [ -n "$ollama_url" ] || { echo "--ollama-url requires a value" >&2; exit 1; }
        shift 2
        ;;
      --timeout)
        timeout="${2:-}"
        [ -n "$timeout" ] || { echo "--timeout requires a value" >&2; exit 1; }
        shift 2
        ;;
      --senior-timeout)
        senior_timeout="${2:-}"
        [ -n "$senior_timeout" ] || { echo "--senior-timeout requires a value" >&2; exit 1; }
        shift 2
        ;;
      --verifier-timeout)
        verifier_timeout="${2:-}"
        [ -n "$verifier_timeout" ] || { echo "--verifier-timeout requires a value" >&2; exit 1; }
        shift 2
        ;;
      -h|--help)
        current_admin_workflow_subcommand_usage start
        exit 0
        ;;
      *)
        echo "Unknown argument for current-admin workflow start: $1" >&2
        exit 1
        ;;
    esac
  done

  if [ -n "$input_path" ]; then
    input_path="$(normalize_python_workspace_path "$input_path")"
  fi

  if [ -z "$review_model" ]; then
    review_model="$DEFAULT_CURRENT_ADMIN_REVIEW_MODEL"
  fi
  if [ -z "$verifier_model" ]; then
    verifier_model="$DEFAULT_CURRENT_ADMIN_VERIFIER_MODEL"
  fi
  if [ -z "$fallback_model" ]; then
    fallback_model="$DEFAULT_CURRENT_ADMIN_FALLBACK_MODEL"
  fi
  if [ -z "$review_mode" ]; then
    review_mode="deep"
  fi
  if [ -n "$timeout" ]; then
    senior_timeout="$timeout"
    verifier_timeout="$timeout"
  fi

  resolve_current_admin_context "$input_path" "$batch_name"

  run_step "1/3" "Normalize Batch" "Normalized current-admin batch created" --output "$CURRENT_ADMIN_NORMALIZED_PATH" -- \
    "$VENV_PYTHON" scripts/normalize_current_admin_batch.py --input "$CURRENT_ADMIN_INPUT_PATH"

  local -a review_args=(
    "$VENV_PYTHON"
    scripts/review_current_admin_batch_with_openai_batch.py
    --input "$CURRENT_ADMIN_NORMALIZED_PATH"
    --model "$review_model"
    --verifier-model "$verifier_model"
    --fallback-model "$fallback_model"
    --senior-timeout "$senior_timeout"
    --verifier-timeout "$verifier_timeout"
    --review-mode "$review_mode"
  )
  if [ "$review_dry_run" = "true" ]; then
    review_args+=(--dry-run)
  fi
  if [ "$deep_review" = "true" ]; then
    review_args+=(--deep-review)
  fi

  run_step "2/3" "AI Review" "AI review report created" --output "$CURRENT_ADMIN_REVIEW_PATH" -- \
    "${review_args[@]}"

  local -a queue_args=(
    "$VENV_PYTHON"
    scripts/apply_current_admin_ai_review.py
    --batch "$CURRENT_ADMIN_NORMALIZED_PATH"
    --review "$CURRENT_ADMIN_REVIEW_PATH"
  )
  if [ "$prefill_suggestions" = "true" ]; then
    queue_args+=(--prefill-suggestions)
  fi

  run_step "3/3" "Build Manual Queue" "Manual review queue created" --output "$CURRENT_ADMIN_QUEUE_PATH" -- \
    "${queue_args[@]}"

  print_system_state \
    "REVIEW_READY" \
    "Generate a decision template or inspect batch status" \
    "$(cli_hint) current-admin workflow review --input $(repo_relative_path "$CURRENT_ADMIN_REVIEW_PATH") --output /tmp/${CURRENT_ADMIN_BATCH_NAME}.decision-template.json" \
    "BATCH: $CURRENT_ADMIN_BATCH_NAME" \
    "OPENAI MODEL: $review_model" \
    "VERIFIER MODEL: $verifier_model" \
    "FALLBACK MODEL: $fallback_model" \
    "OPENAI BASE URL: $DEFAULT_CURRENT_ADMIN_OPENAI_BASE_URL"
}

run_current_admin_review_command() {
  local -a normalized_args=()
  local -a passthrough=()
  local has_model="false"
  local has_verifier_model="false"
  local has_fallback_model="false"
  local has_ollama_url="false"
  local has_timeout="false"
  local has_senior_timeout="false"
  local has_verifier_timeout="false"
  local has_review_mode="false"
  local has_paired_experiment="false"

  normalize_current_admin_path_args normalized_args "$@"
  set -- "${normalized_args[@]}"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      -h|--help)
        current_admin_subcommand_usage ai-review
        exit 0
        ;;
      --model|--model=*)
        has_model="true"
        passthrough+=("$1")
        if [ "$1" = "--model" ]; then
          [ -n "${2:-}" ] || { echo "--model requires a value" >&2; exit 1; }
          passthrough+=("$2")
          shift 2
        else
          shift
        fi
        ;;
      --verifier-model|--verifier-model=*)
        has_verifier_model="true"
        passthrough+=("$1")
        if [ "$1" = "--verifier-model" ]; then
          [ -n "${2:-}" ] || { echo "--verifier-model requires a value" >&2; exit 1; }
          passthrough+=("$2")
          shift 2
        else
          shift
        fi
        ;;
      --fallback-model|--fallback-model=*)
        has_fallback_model="true"
        passthrough+=("$1")
        if [ "$1" = "--fallback-model" ]; then
          [ -n "${2:-}" ] || { echo "--fallback-model requires a value" >&2; exit 1; }
          passthrough+=("$2")
          shift 2
        else
          shift
        fi
        ;;
      --ollama-url|--ollama-url=*)
        has_ollama_url="true"
        passthrough+=("$1")
        if [ "$1" = "--ollama-url" ]; then
          [ -n "${2:-}" ] || { echo "--ollama-url requires a value" >&2; exit 1; }
          passthrough+=("$2")
          shift 2
        else
          shift
        fi
        ;;
      --timeout|--timeout=*)
        has_timeout="true"
        passthrough+=("$1")
        if [ "$1" = "--timeout" ]; then
          [ -n "${2:-}" ] || { echo "--timeout requires a value" >&2; exit 1; }
          passthrough+=("$2")
          shift 2
        else
          shift
        fi
        ;;
      --senior-timeout|--senior-timeout=*)
        has_senior_timeout="true"
        passthrough+=("$1")
        if [ "$1" = "--senior-timeout" ]; then
          [ -n "${2:-}" ] || { echo "--senior-timeout requires a value" >&2; exit 1; }
          passthrough+=("$2")
          shift 2
        else
          shift
        fi
        ;;
      --verifier-timeout|--verifier-timeout=*)
        has_verifier_timeout="true"
        passthrough+=("$1")
        if [ "$1" = "--verifier-timeout" ]; then
          [ -n "${2:-}" ] || { echo "--verifier-timeout requires a value" >&2; exit 1; }
          passthrough+=("$2")
          shift 2
        else
          shift
        fi
        ;;
      --review-mode|--review-mode=*|--deep-review)
        has_review_mode="true"
        passthrough+=("$1")
        if [ "$1" = "--review-mode" ]; then
          [ -n "${2:-}" ] || { echo "--review-mode requires a value" >&2; exit 1; }
          passthrough+=("$2")
          shift 2
        else
          shift
        fi
        ;;
      --paired-experiment)
        has_paired_experiment="true"
        passthrough+=("$1")
        shift
        ;;
      *)
        passthrough+=("$1")
        shift
        ;;
    esac
  done

  if [ "$has_model" = "false" ]; then
    passthrough+=(--model "$DEFAULT_CURRENT_ADMIN_REVIEW_MODEL")
  fi
  if [ "$has_verifier_model" = "false" ]; then
    passthrough+=(--verifier-model "$DEFAULT_CURRENT_ADMIN_VERIFIER_MODEL")
  fi
  if [ "$has_fallback_model" = "false" ]; then
    passthrough+=(--fallback-model "$DEFAULT_CURRENT_ADMIN_FALLBACK_MODEL")
  fi
  if [ "$has_timeout" = "true" ]; then
    :
  else
    if [ "$has_senior_timeout" = "false" ]; then
      passthrough+=(--senior-timeout "$DEFAULT_OLLAMA_TIMEOUT_SENIOR")
    fi
    if [ "$has_verifier_timeout" = "false" ]; then
      passthrough+=(--verifier-timeout "$DEFAULT_OLLAMA_TIMEOUT_VERIFIER")
    fi
  fi
  if [ "$has_review_mode" = "false" ]; then
    passthrough+=(--review-mode deep)
  fi

  local review_script="scripts/review_current_admin_batch_with_openai_batch.py"
  local review_step_label="AI Review"
  local review_step_complete="AI review command complete"
  if [ "$has_paired_experiment" = "true" ]; then
    review_script="scripts/current_admin_paired_evaluation.py"
    review_step_label="Paired Review Evaluation"
    review_step_complete="Paired review evaluation command complete"
  fi

  run_step "1/1" "$review_step_label" "$review_step_complete" -- \
    "$VENV_PYTHON" "$review_script" "${passthrough[@]}"
}

run_current_admin_discover_command() {
  local -a passthrough=()
  local has_model="false"
  local has_ollama_url="false"
  local has_timeout="false"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      -h|--help)
        current_admin_subcommand_usage discover
        exit 0
        ;;
      --model|--model=*)
        has_model="true"
        passthrough+=("$1")
        if [ "$1" = "--model" ]; then
          [ -n "${2:-}" ] || { echo "--model requires a value" >&2; exit 1; }
          passthrough+=("$2")
          shift 2
        else
          shift
        fi
        ;;
      --ollama-url|--ollama-url=*)
        has_ollama_url="true"
        passthrough+=("$1")
        if [ "$1" = "--ollama-url" ]; then
          [ -n "${2:-}" ] || { echo "--ollama-url requires a value" >&2; exit 1; }
          passthrough+=("$2")
          shift 2
        else
          shift
        fi
        ;;
      --timeout|--timeout=*)
        has_timeout="true"
        passthrough+=("$1")
        if [ "$1" = "--timeout" ]; then
          [ -n "${2:-}" ] || { echo "--timeout requires a value" >&2; exit 1; }
          passthrough+=("$2")
          shift 2
        else
          shift
        fi
        ;;
      *)
        passthrough+=("$1")
        shift
        ;;
    esac
  done

  if [ "$has_model" = "false" ]; then
    passthrough+=(--model "$DEFAULT_MODEL_CHEAP")
  fi
  if [ "$has_ollama_url" = "false" ]; then
    passthrough+=(--ollama-url "$DEFAULT_OLLAMA_URL")
  fi
  if [ "$has_timeout" = "false" ]; then
    passthrough+=(--timeout "$DEFAULT_OLLAMA_TIMEOUT_VERIFIER")
  fi

  run_step "1/1" "Discover Current-Admin Updates" "Discovery run complete" -- \
    "$VENV_PYTHON" scripts/discover_current_admin_updates.py "${passthrough[@]}"
}

run_current_admin_gen_batch_command() {
  if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
    current_admin_subcommand_usage gen-batch
    exit 0
  fi

  local -a batch_args=()
  normalize_current_admin_path_args batch_args "$@"
  run_step "1/1" "Generate Current-Admin Batch" "Canonical batch generation complete" -- \
    "$VENV_PYTHON" scripts/generate_current_admin_batch_from_discovery.py "${batch_args[@]}"
}

run_current_admin_run_command() {
  local input_path=""
  local batch_name=""
  local discovery_dry_run="false"
  local discovery_output=""
  local batch_output=""
  local output_name=""
  local allow_overwrite="false"
  local -a discovery_args=()
  local -a workflow_args=()

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --input)
        input_path="${2:-}"
        [ -n "$input_path" ] || { echo "--input requires a value" >&2; exit 1; }
        shift 2
        ;;
      --batch-name)
        batch_name="${2:-}"
        [ -n "$batch_name" ] || { echo "--batch-name requires a value" >&2; exit 1; }
        shift 2
        ;;
      --discovery-dry-run)
        discovery_dry_run="true"
        shift
        ;;
      --discovery-output)
        discovery_output="${2:-}"
        [ -n "$discovery_output" ] || { echo "--discovery-output requires a value" >&2; exit 1; }
        shift 2
        ;;
      --output)
        batch_output="${2:-}"
        [ -n "$batch_output" ] || { echo "--output requires a value" >&2; exit 1; }
        shift 2
        ;;
      --output-name)
        output_name="${2:-}"
        [ -n "$output_name" ] || { echo "--output-name requires a value" >&2; exit 1; }
        shift 2
        ;;
      --allow-overwrite)
        allow_overwrite="true"
        shift
        ;;
      --feed-url|--feed-json|--max-promises|--max-feed-items|--lookback-days)
        discovery_args+=("$1" "${2:-}")
        [ -n "${2:-}" ] || { echo "$1 requires a value" >&2; exit 1; }
        shift 2
        ;;
      --model|--verifier-model|--fallback-model|--ollama-url|--timeout|--senior-timeout|--verifier-timeout|--review-mode)
        workflow_args+=("$1" "${2:-}")
        [ -n "${2:-}" ] || { echo "$1 requires a value" >&2; exit 1; }
        shift 2
        ;;
      --review-dry-run|--prefill-suggestions|--deep-review)
        workflow_args+=("$1")
        shift
        ;;
      -h|--help)
        current_admin_subcommand_usage run
        exit 0
        ;;
      *)
        echo "Unknown argument for current-admin run: $1" >&2
        exit 1
        ;;
    esac
  done

  if [ -n "$input_path" ] && [ -n "$batch_name" ]; then
    echo "Use either --input or --batch-name for current-admin run" >&2
    exit 1
  fi

  if [ -n "$input_path" ] || [ -n "$batch_name" ]; then
    if [ -n "$input_path" ]; then
      workflow_args=(--input "$input_path" "${workflow_args[@]}")
    else
      workflow_args=(--batch-name "$batch_name" "${workflow_args[@]}")
    fi
    run_current_admin_workflow_start "${workflow_args[@]}"
    resolve_current_admin_context "$input_path" "$batch_name"
    print_current_admin_run_summary "$CURRENT_ADMIN_INPUT_PATH"
    return 0
  fi

  local discovery_path="${discovery_output:-$(current_admin_reports_dir)/discovery_report.json}"
  discovery_path="$(normalize_python_workspace_path "$discovery_path")"
  if [ "$discovery_dry_run" = "true" ]; then
    discovery_args=(--dry-run "${discovery_args[@]}")
  fi
  discovery_args=(--output "$discovery_path" "${discovery_args[@]}")
  run_current_admin_discover_command "${discovery_args[@]}"

  discovery_path="$(normalize_python_workspace_path "$discovery_path")"
  local discovery_abs="$EQUITYSTACK_PYTHON_DIR/$discovery_path"
  if [ ! -f "$discovery_abs" ]; then
    discovery_abs="$discovery_path"
  fi

  local discovered_count="0"
  discovered_count="$(current_admin_total_discovery_candidates "$discovery_abs")"
  if [ "${discovered_count:-0}" = "0" ]; then
    print_system_state \
      "DISCOVERY_CLEAR" \
      "No current-admin discovery candidates were found. Run discovery again later or provide --input for a manual batch." \
      "$(cli_hint) current-admin discover" \
      "DISCOVERY REPORT: $(repo_relative_path "$discovery_abs")" \
      "DISCOVERED ITEMS: 0"
    return 0
  fi

  local generated_batch_name=""
  if [ -n "$output_name" ]; then
    generated_batch_name="$(normalize_python_workspace_path "$output_name")"
    generated_batch_name="$(basename "$generated_batch_name")"
    generated_batch_name="${generated_batch_name%.json}"
  else
    generated_batch_name="$(current_admin_generate_auto_batch_name "$discovery_abs")"
  fi

  local generated_batch_output="$batch_output"
  if [ -n "$generated_batch_output" ]; then
    generated_batch_output="$(normalize_python_workspace_path "$generated_batch_output")"
  else
    generated_batch_output="data/current_admin_batches/${generated_batch_name}.json"
  fi

  local -a gen_batch_args=(
    --input "$discovery_path"
    --all-candidates
    --batch-name "$generated_batch_name"
    --output "$generated_batch_output"
  )
  if [ "$allow_overwrite" = "true" ]; then
    gen_batch_args+=(--allow-overwrite)
  fi

  run_step "1/1" "Generate Current-Admin Batch" "Canonical batch generation complete" --output "$generated_batch_output" -- \
    "$VENV_PYTHON" scripts/generate_current_admin_batch_from_discovery.py "${gen_batch_args[@]}"

  workflow_args=(--input "$generated_batch_output" "${workflow_args[@]}")
  run_current_admin_workflow_start "${workflow_args[@]}"
  resolve_current_admin_context "$generated_batch_output" ""
  print_current_admin_run_summary "$CURRENT_ADMIN_INPUT_PATH" "$discovery_abs"
}

run_current_admin_operator_review_command() {
  local input_path=""
  local batch_name=""
  local decision_file=""
  local refresh_template="false"
  local feedback_summary="false"
  local log_decisions_path=""

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --input)
        input_path="${2:-}"
        [ -n "$input_path" ] || { echo "--input requires a value" >&2; exit 1; }
        shift 2
        ;;
      --batch-name)
        batch_name="${2:-}"
        [ -n "$batch_name" ] || { echo "--batch-name requires a value" >&2; exit 1; }
        shift 2
        ;;
      --decision-file)
        decision_file="${2:-}"
        [ -n "$decision_file" ] || { echo "--decision-file requires a value" >&2; exit 1; }
        shift 2
        ;;
      --log-decisions)
        if [ -n "${2:-}" ] && [[ "${2:-}" != --* ]]; then
          log_decisions_path="${2:-}"
          shift 2
        else
          log_decisions_path=""
          shift
        fi
        ;;
      --refresh-template)
        refresh_template="true"
        shift
        ;;
      --feedback-summary)
        feedback_summary="true"
        shift
        ;;
      -h|--help)
        current_admin_subcommand_usage review
        exit 0
        ;;
      *)
        echo "Unknown argument for current-admin review: $1" >&2
        exit 1
        ;;
    esac
  done

  if [ -n "$input_path" ] && [ -n "$batch_name" ]; then
    echo "Use either --input or --batch-name for current-admin review" >&2
    exit 1
  fi

  resolve_current_admin_review_target "$input_path" "$batch_name"
  local review_path="$CURRENT_ADMIN_REVIEW_TARGET_PATH"
  if [ -n "$decision_file" ]; then
    decision_file="$(normalize_python_workspace_path "$decision_file")"
  else
    decision_file="$CURRENT_ADMIN_REVIEW_TARGET_DECISION_TEMPLATE"
  fi

  if [ "$refresh_template" = "true" ] || [ ! -f "$decision_file" ]; then
    run_current_admin_workflow_review --input "$review_path" --output "$decision_file" --summary
  fi

  local -a decision_status_lines=()
  mapfile -t decision_status_lines < <(current_admin_decision_file_status "$review_path" "$decision_file")
  local decision_status="${decision_status_lines[0]:-invalid}"
  if [ "$decision_status" = "mismatch" ]; then
    echo "Decision file does not match the selected review artifact. Use --refresh-template or pass the correct --decision-file." >&2
    exit 1
  fi

  if [ "$decision_status" != "ready" ]; then
    print_current_admin_review_summary "$review_path" "$decision_file" "$(current_admin_decision_log_dir)/placeholder.decision-log.json" "false"
    return 0
  fi

  if [ -n "$log_decisions_path" ]; then
    log_decisions_path="$(normalize_python_workspace_path "$log_decisions_path")"
  else
    log_decisions_path="$(current_admin_decision_log_dir)/${CURRENT_ADMIN_REVIEW_TARGET_BATCH_NAME}.$(date -u +%Y%m%dT%H%M%SZ).decision-log.json"
  fi

  local -a finalize_args=(
    --review "$review_path"
    --decision-file "$decision_file"
    --log-decisions "$log_decisions_path"
  )
  if [ "$feedback_summary" = "true" ]; then
    finalize_args+=(--feedback-summary)
  fi

  run_current_admin_workflow_finalize "${finalize_args[@]}"
  print_current_admin_review_summary "$review_path" "$decision_file" "$log_decisions_path" "true"
}

run_current_admin_apply_command() {
  local input_path=""
  local batch_name=""
  local explicit_apply="false"
  local confirmed="false"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --input)
        input_path="${2:-}"
        [ -n "$input_path" ] || { echo "--input requires a value" >&2; exit 1; }
        shift 2
        ;;
      --batch-name)
        batch_name="${2:-}"
        [ -n "$batch_name" ] || { echo "--batch-name requires a value" >&2; exit 1; }
        shift 2
        ;;
      --apply)
        explicit_apply="true"
        shift
        ;;
      --yes)
        confirmed="true"
        shift
        ;;
      -h|--help)
        current_admin_subcommand_usage apply
        exit 0
        ;;
      *)
        echo "Unknown argument for current-admin apply: $1" >&2
        exit 1
        ;;
    esac
  done

  if [ -n "$input_path" ] && [ -n "$batch_name" ]; then
    echo "Use either --input or --batch-name for current-admin apply" >&2
    exit 1
  fi
  if [ "$explicit_apply" = "true" ] && [ "$confirmed" != "true" ]; then
    echo "equitystack current-admin apply --apply requires --yes" >&2
    exit 1
  fi
  if [ "$explicit_apply" != "true" ] && [ "$confirmed" = "true" ]; then
    echo "Use --yes only with --apply for current-admin apply" >&2
    exit 1
  fi

  resolve_current_admin_apply_target "$input_path" "$batch_name"

  run_step "1/4" "Build Pre-Commit Review" "Pre-commit review build complete" --output "$CURRENT_ADMIN_APPLY_PRECOMMIT_PATH" -- \
    "$VENV_PYTHON" scripts/build_current_admin_precommit_review.py --input "$CURRENT_ADMIN_APPLY_QUEUE_PATH"

  local precommit_status="missing"
  precommit_status="$(read_precommit_status "$CURRENT_ADMIN_APPLY_PRECOMMIT_PATH")"
  if [ "$precommit_status" = "blocked" ]; then
    print_current_admin_apply_summary \
      "$CURRENT_ADMIN_APPLY_QUEUE_PATH" \
      "$CURRENT_ADMIN_APPLY_PRECOMMIT_PATH" \
      "$CURRENT_ADMIN_APPLY_DRY_RUN_PATH" \
      "$CURRENT_ADMIN_APPLY_IMPORT_APPLY_PATH" \
      "$CURRENT_ADMIN_APPLY_VALIDATION_PATH" \
      "false"
    return 0
  fi

  run_step "2/4" "Import Dry-Run" "Current-admin import dry-run complete" --output "$CURRENT_ADMIN_APPLY_DRY_RUN_PATH" -- \
    "$VENV_PYTHON" scripts/import_curated_current_admin_batch.py --input "$CURRENT_ADMIN_APPLY_QUEUE_PATH" --output "$CURRENT_ADMIN_APPLY_DRY_RUN_PATH"

  if [ "$explicit_apply" != "true" ]; then
    print_current_admin_apply_summary \
      "$CURRENT_ADMIN_APPLY_QUEUE_PATH" \
      "$CURRENT_ADMIN_APPLY_PRECOMMIT_PATH" \
      "$CURRENT_ADMIN_APPLY_DRY_RUN_PATH" \
      "$CURRENT_ADMIN_APPLY_IMPORT_APPLY_PATH" \
      "$CURRENT_ADMIN_APPLY_VALIDATION_PATH" \
      "false"
    return 0
  fi

  run_step "3/4" "Import Apply" "Current-admin import apply complete" --output "$CURRENT_ADMIN_APPLY_IMPORT_APPLY_PATH" -- \
    "$VENV_PYTHON" scripts/import_curated_current_admin_batch.py --input "$CURRENT_ADMIN_APPLY_QUEUE_PATH" --output "$CURRENT_ADMIN_APPLY_IMPORT_APPLY_PATH" --apply --yes

  run_step "4/4" "Validate Import" "Current-admin validation complete" --output "$CURRENT_ADMIN_APPLY_VALIDATION_PATH" -- \
    "$VENV_PYTHON" scripts/validate_current_admin_import.py --input "$CURRENT_ADMIN_APPLY_QUEUE_PATH" --output "$CURRENT_ADMIN_APPLY_VALIDATION_PATH"

  print_current_admin_apply_summary \
    "$CURRENT_ADMIN_APPLY_QUEUE_PATH" \
    "$CURRENT_ADMIN_APPLY_PRECOMMIT_PATH" \
    "$CURRENT_ADMIN_APPLY_DRY_RUN_PATH" \
    "$CURRENT_ADMIN_APPLY_IMPORT_APPLY_PATH" \
    "$CURRENT_ADMIN_APPLY_VALIDATION_PATH" \
    "true"
}

run_current_admin_workflow_command() {
  local command="${1:-}"
  shift || true

  case "$command" in
    start)
      run_current_admin_workflow_start "$@"
      ;;
    review|generate-decision-template)
      run_current_admin_workflow_review "$@"
      ;;
    finalize)
      run_current_admin_workflow_finalize "$@"
      ;;
    resume)
      if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        current_admin_workflow_subcommand_usage resume
        exit 0
      fi
      print_current_admin_workflow_resume
      ;;
    help|-h|--help|"")
      current_admin_workflow_usage
      ;;
    *)
      echo "Unknown current-admin workflow command: $command" >&2
      current_admin_workflow_usage
      exit 1
      ;;
  esac
}

run_legislative_command() {
  local command="${1:-}"
  shift || true

  case "$command" in
    run)
      local review_model="$DEFAULT_MODEL_REVIEW"
      local verifier_model="$DEFAULT_MODEL_VERIFIER"
      local fallback_model="$DEFAULT_MODEL_FALLBACK"
      local timeout=""
      local senior_timeout="$DEFAULT_OLLAMA_TIMEOUT_SENIOR"
      local verifier_timeout="$DEFAULT_OLLAMA_TIMEOUT_VERIFIER"
      local -a passthrough=()

      while [ "$#" -gt 0 ]; do
        case "$1" in
          --model)
            review_model="${2:-}"
            [ -n "$review_model" ] || { echo "--model requires a value" >&2; exit 1; }
            shift 2
            ;;
          --verifier-model)
            verifier_model="${2:-}"
            [ -n "$verifier_model" ] || { echo "--verifier-model requires a value" >&2; exit 1; }
            shift 2
            ;;
          --fallback-model)
            fallback_model="${2:-}"
            [ -n "$fallback_model" ] || { echo "--fallback-model requires a value" >&2; exit 1; }
            shift 2
            ;;
          --timeout)
            timeout="${2:-}"
            [ -n "$timeout" ] || { echo "--timeout requires a value" >&2; exit 1; }
            shift 2
            ;;
          --senior-timeout)
            senior_timeout="${2:-}"
            [ -n "$senior_timeout" ] || { echo "--senior-timeout requires a value" >&2; exit 1; }
            shift 2
            ;;
          --verifier-timeout)
            verifier_timeout="${2:-}"
            [ -n "$verifier_timeout" ] || { echo "--verifier-timeout requires a value" >&2; exit 1; }
            shift 2
            ;;
          --skip-discovery|--apply-safe-removals|--csv)
            passthrough+=("$1")
            shift
            ;;
          --output-report|--only-future-bill-id)
            passthrough+=("$1" "${2:-}")
            [ -n "${2:-}" ] || { echo "$1 requires a value" >&2; exit 1; }
            shift 2
            ;;
          -h|--help)
            legislative_usage
            exit 0
            ;;
          *)
            echo "Unknown argument for legislative run: $1" >&2
            exit 1
            ;;
        esac
      done

      if [ -n "$timeout" ]; then
        senior_timeout="$timeout"
        verifier_timeout="$timeout"
      fi

      if ! command_has_flag "--csv" "${passthrough[@]}"; then
        passthrough+=(--csv)
      fi
      if ! command_has_flag "--output-report" "${passthrough[@]}"; then
        passthrough+=(--output-report "$(pipeline_report_path)")
      fi

      run_step "1/3" "Daily Review Pipeline" "Legislative pipeline reports refreshed" \
        --output "$(pipeline_report_path)" \
        --output "$(future_bill_ai_review_path)" \
        --output "$(future_bill_manual_queue_path)" \
        --output "$(future_bill_suggestion_path)" \
        -- \
        "$VENV_PYTHON" run_equitystack_pipeline.py \
          --review-model "$review_model" \
          --verifier-model "$verifier_model" \
          --fallback-model "$fallback_model" \
          --senior-timeout "$senior_timeout" \
          --verifier-timeout "$verifier_timeout" \
          "${passthrough[@]}"

      run_step "2/3" "Auto-Triage Review Bundle" "Safe review bundle actions auto-triaged" -- \
        "$VENV_PYTHON" scripts/auto_triage_review_bundle.py --apply --yes --auto-approve-safe-actions

      run_step "3/3" "Rebuild Review Bundle" "Review bundle rebuilt" --output "$(review_bundle_path)" -- \
        "$VENV_PYTHON" scripts/build_review_bundle.py --csv --use-feedback

      print_system_state \
        "REVIEW_READY" \
        "Review the updated bundle and approve or reject actions" \
        "$(cli_hint) legislative review" \
        "SENIOR MODEL: $review_model" \
        "VERIFIER MODEL: $verifier_model" \
        "FALLBACK MODEL: $fallback_model" \
        "SENIOR TIMEOUT: ${senior_timeout}s" \
        "VERIFIER TIMEOUT: ${verifier_timeout}s" \
        "PIPELINE REPORT: $(repo_relative_path "$(pipeline_report_path)")"
      ;;
    review)
      [ "$#" -eq 0 ] || { echo "equitystack legislative review does not accept extra arguments" >&2; exit 1; }
      run_step "1/1" "Review Bundle Actions" "Legislative review session complete" -- \
        "$VENV_PYTHON" scripts/review_bundle_actions.py --non-interactive-summary
      ;;
    apply)
      local dry_run="false"
      local explicit_apply="false"
      local confirmed="false"
      while [ "$#" -gt 0 ]; do
        case "$1" in
          --dry-run)
            dry_run="true"
            shift
            ;;
          --apply)
            explicit_apply="true"
            shift
            ;;
          --yes)
            confirmed="true"
            shift
            ;;
          -h|--help)
            legislative_usage
            exit 0
            ;;
          *)
            echo "Unknown argument for legislative apply: $1" >&2
            exit 1
            ;;
        esac
      done

      if [ "$dry_run" = "true" ] && [ "$explicit_apply" = "true" ]; then
        echo "Use either --dry-run or --apply --yes for legislative apply" >&2
        exit 1
      fi

      if [ "$dry_run" = "true" ]; then
        run_step "1/1" "Dry-Run Apply Review Bundle" "Legislative apply preview complete" --output "$(apply_report_path)" -- \
          "$VENV_PYTHON" scripts/apply_review_bundle.py --csv

        print_system_state \
          "APPLY_READY" \
          "Inspect the dry-run report, then apply approved legislative actions when ready" \
          "$(cli_hint) legislative apply --apply --yes"
      else
        if [ "$explicit_apply" = "true" ] && [ "$confirmed" != "true" ]; then
          echo "equitystack legislative apply --apply requires --yes" >&2
          exit 1
        fi

        run_step "1/3" "Apply Review Bundle" "Approved legislative actions applied" --output "$(apply_report_path)" -- \
          "$VENV_PYTHON" scripts/apply_review_bundle.py --apply --yes --csv

        if apply_report_has_affected_bills; then
          run_step "2/3" "Rerun Affected Future Bills" "Affected future bills rerun" -- \
            "$VENV_PYTHON" scripts/rerun_affected_future_bills.py --from-apply-report "$(apply_report_path)" --csv
        else
          print_step_header "2/3" "Rerun Affected Future Bills"
          printf 'SUCCESS: No affected future bills were recorded. Skipping rerun.\n'
        fi

        run_step "3/3" "Rebuild Review Bundle" "Review bundle rebuilt" --output "$(review_bundle_path)" -- \
          "$VENV_PYTHON" scripts/build_review_bundle.py --csv --use-feedback

        print_system_state \
          "REVIEW_READY" \
          "Inspect the refreshed review bundle" \
          "$(cli_hint) legislative review"
      fi
      ;;
    import)
      local dry_run="false"
      local explicit_apply="false"
      local confirmed="false"
      while [ "$#" -gt 0 ]; do
        case "$1" in
          --dry-run)
            dry_run="true"
            shift
            ;;
          --apply)
            explicit_apply="true"
            shift
            ;;
          --yes)
            confirmed="true"
            shift
            ;;
          -h|--help)
            legislative_usage
            exit 0
            ;;
          *)
            echo "Unknown argument for legislative import: $1" >&2
            exit 1
            ;;
        esac
      done

      if [ "$dry_run" = "true" ] && [ "$explicit_apply" = "true" ]; then
        echo "Use either --dry-run or --apply --yes for legislative import" >&2
        exit 1
      fi

      if [ "$dry_run" = "true" ]; then
        run_step "1/1" "Dry-Run Import Approved Tracked Bills" "Legislative import preview complete" -- \
          "$VENV_PYTHON" scripts/import_approved_tracked_bills.py --link-imported-bills --enrich-metadata --csv

        print_system_state \
          "IMPORT_READY" \
          "Inspect the dry-run import report, then apply the approved tracked-bill import when ready" \
          "$(cli_hint) legislative import --apply --yes"
      else
        if [ "$explicit_apply" = "true" ] && [ "$confirmed" != "true" ]; then
          echo "equitystack legislative import --apply requires --yes" >&2
          exit 1
        fi

        run_step "1/2" "Import Approved Tracked Bills" "Approved tracked bills imported" -- \
          "$VENV_PYTHON" scripts/import_approved_tracked_bills.py --apply --yes --link-imported-bills --enrich-metadata --csv

        run_step "2/2" "Rebuild Review Bundle" "Review bundle rebuilt" --output "$(review_bundle_path)" -- \
          "$VENV_PYTHON" scripts/build_review_bundle.py --csv --use-feedback

        print_system_state \
          "REVIEW_READY" \
          "Review the new bundle after import" \
          "$(cli_hint) legislative review"
      fi
      ;;
    materialize-outcomes)
      run_step "1/1" "Materialize Legislative Outcomes" "Legislative policy_outcomes materialization complete" --output "$EQUITYSTACK_PYTHON_DIR/reports/legislative-policy-outcomes-materialize.dry-run.json" -- \
        "$VENV_PYTHON" scripts/materialize_legislative_policy_outcomes.py "$@"
      ;;
    feedback)
      [ "$#" -eq 0 ] || { echo "equitystack legislative feedback does not accept extra arguments" >&2; exit 1; }
      run_step "1/2" "Analyze Feedback" "Feedback analysis refreshed" -- \
        "$VENV_PYTHON" scripts/analyze_feedback.py

      run_step "2/2" "Rebuild Review Bundle" "Review bundle rebuilt" --output "$(review_bundle_path)" -- \
        "$VENV_PYTHON" scripts/build_review_bundle.py --csv --use-feedback

      print_system_state \
        "REVIEW_READY" \
        "Review the updated feedback-informed bundle" \
        "$(cli_hint) legislative review"
      ;;
    help|-h|--help|"")
      legislative_usage
      ;;
    *)
      echo "Unknown legislative command: $command" >&2
      legislative_usage
      exit 1
      ;;
  esac
}

