run_current_admin_discover_command() {
  local -a passthrough=()
  local has_model="false"
  local has_openai_base_url="false"
  local has_timeout="false"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      -h|--help)
        current_admin_subcommand_usage discover
        exit 0
        ;;
      --model|--model=*)
        has_model="true"
        passthrough+=("$1")
        if [ "$1" = "--model" ]; then
          [ -n "${2:-}" ] || { echo "--model requires a value" >&2; exit 1; }
          passthrough+=("$2")
          shift 2
        else
          shift
        fi
        ;;
      --openai-base-url|--openai-base-url=*)
        has_openai_base_url="true"
        passthrough+=("$1")
        if [ "$1" = "--openai-base-url" ]; then
          [ -n "${2:-}" ] || { echo "--openai-base-url requires a value" >&2; exit 1; }
          passthrough+=("$2")
          shift 2
        else
          shift
        fi
        ;;
      --timeout|--timeout=*)
        has_timeout="true"
        passthrough+=("$1")
        if [ "$1" = "--timeout" ]; then
          [ -n "${2:-}" ] || { echo "--timeout requires a value" >&2; exit 1; }
          passthrough+=("$2")
          shift 2
        else
          shift
        fi
        ;;
      *)
        passthrough+=("$1")
        shift
        ;;
    esac
  done

  if [ "$has_model" = "false" ]; then
    passthrough+=(--model "$DEFAULT_MODEL_CHEAP")
  fi
  if [ "$has_openai_base_url" = "false" ]; then
    passthrough+=(--openai-base-url "$DEFAULT_CURRENT_ADMIN_OPENAI_BASE_URL")
  fi
  if [ "$has_timeout" = "false" ]; then
    passthrough+=(--timeout "$DEFAULT_REVIEW_TIMEOUT_VERIFIER")
  fi

  run_step "1/1" "Discover Current-Admin Updates" "Discovery run complete" -- \
    "$VENV_PYTHON" scripts/discover_current_admin_updates.py "${passthrough[@]}"
}

run_current_admin_gen_batch_command() {
  if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
    current_admin_subcommand_usage gen-batch
    exit 0
  fi

  local -a batch_args=()
  normalize_current_admin_path_args batch_args "$@"
  run_step "1/1" "Generate Current-Admin Batch" "Canonical batch generation complete" -- \
    "$VENV_PYTHON" scripts/generate_current_admin_batch_from_discovery.py "${batch_args[@]}"
}

run_current_admin_run_command() {
  local input_path=""
  local batch_name=""
  local discovery_dry_run="false"
  local discovery_output=""
  local batch_output=""
  local output_name=""
  local allow_overwrite="false"
  local full_auto="true"
  local no_auto_apply="false"
  local no_impact_automation="false"
  local stop_after=""
  local review_dry_run_requested="false"
  local -a discovery_args=()
  local -a workflow_args=()

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --input)
        input_path="${2:-}"
        [ -n "$input_path" ] || { echo "--input requires a value" >&2; exit 1; }
        shift 2
        ;;
      --batch-name)
        batch_name="${2:-}"
        [ -n "$batch_name" ] || { echo "--batch-name requires a value" >&2; exit 1; }
        shift 2
        ;;
      --discovery-dry-run)
        discovery_dry_run="true"
        shift
        ;;
      --discovery-output)
        discovery_output="${2:-}"
        [ -n "$discovery_output" ] || { echo "--discovery-output requires a value" >&2; exit 1; }
        shift 2
        ;;
      --output)
        batch_output="${2:-}"
        [ -n "$batch_output" ] || { echo "--output requires a value" >&2; exit 1; }
        shift 2
        ;;
      --output-name)
        output_name="${2:-}"
        [ -n "$output_name" ] || { echo "--output-name requires a value" >&2; exit 1; }
        shift 2
        ;;
      --allow-overwrite)
        allow_overwrite="true"
        shift
        ;;
      --full-auto)
        full_auto="true"
        shift
        ;;
      --stop-after)
        stop_after="${2:-}"
        [ -n "$stop_after" ] || { echo "--stop-after requires a value" >&2; exit 1; }
        case "$stop_after" in
          review|apply|impact-evaluate|impact-promote|enrichment) ;;
          *)
            echo "--stop-after must be one of: review, apply, impact-evaluate, impact-promote, enrichment" >&2
            exit 1
            ;;
        esac
        shift 2
        ;;
      --no-auto-apply)
        no_auto_apply="true"
        shift
        ;;
      --no-impact-automation)
        no_impact_automation="true"
        shift
        ;;
      --feed-url|--feed-json|--max-promises|--max-feed-items|--lookback-days|--source-config)
        discovery_args+=("$1" "${2:-}")
        [ -n "${2:-}" ] || { echo "$1 requires a value" >&2; exit 1; }
        shift 2
        ;;
      --disable-default-sources)
        discovery_args+=("$1")
        shift
        ;;
      --openai-base-url)
        discovery_args+=("$1" "${2:-}")
        workflow_args+=("$1" "${2:-}")
        [ -n "${2:-}" ] || { echo "$1 requires a value" >&2; exit 1; }
        shift 2
        ;;
      --model|--verifier-model|--fallback-model|--openai-base-url|--timeout|--senior-timeout|--verifier-timeout|--review-mode)
        workflow_args+=("$1" "${2:-}")
        [ -n "${2:-}" ] || { echo "$1 requires a value" >&2; exit 1; }
        shift 2
        ;;
      --review-dry-run)
        workflow_args+=("$1")
        review_dry_run_requested="true"
        shift
        ;;
      --deep-review)
        workflow_args+=("$1")
        shift
        ;;
      -h|--help)
        current_admin_subcommand_usage run
        exit 0
        ;;
      *)
        echo "Unknown argument for current-admin run: $1" >&2
        exit 1
        ;;
    esac
  done

  if [ -n "$input_path" ] && [ -n "$batch_name" ]; then
    echo "Use either --input or --batch-name for current-admin run" >&2
    exit 1
  fi

  if [ -n "$input_path" ] || [ -n "$batch_name" ]; then
    if [ -n "$input_path" ]; then
      workflow_args=(--input "$input_path" "${workflow_args[@]}")
    else
      workflow_args=(--batch-name "$batch_name" "${workflow_args[@]}")
    fi
    CURRENT_ADMIN_PREPARE_SUPPRESS_SUMMARY="true" run_current_admin_prepare_flow "${workflow_args[@]}"
    resolve_current_admin_context "$input_path" "$batch_name"
  else
    local discovery_path="${discovery_output:-$(current_admin_reports_dir)/discovery_report.json}"
    discovery_path="$(normalize_python_workspace_path "$discovery_path")"
    if [ "$discovery_dry_run" = "true" ]; then
      discovery_args=(--dry-run "${discovery_args[@]}")
    fi
    discovery_args=(--output "$discovery_path" "${discovery_args[@]}")
    run_current_admin_discover_command "${discovery_args[@]}"

    discovery_path="$(normalize_python_workspace_path "$discovery_path")"
    local discovery_abs="$EQUITYSTACK_PYTHON_DIR/$discovery_path"
    if [ ! -f "$discovery_abs" ]; then
      discovery_abs="$discovery_path"
    fi

    local discovered_count="0"
    discovered_count="$(current_admin_total_discovery_candidates "$discovery_abs")"
    if [ "${discovered_count:-0}" = "0" ]; then
      print_system_state \
        "DISCOVERY_CLEAR" \
        "No current-admin discovery candidates were found. Run discovery again later or provide --input for a manual batch." \
        "$(cli_hint) current-admin discover" \
        "DISCOVERY REPORT: $(repo_relative_path "$discovery_abs")" \
        "DISCOVERED ITEMS: 0"
      return 0
    fi

    local generated_batch_name=""
    if [ -n "$output_name" ]; then
      generated_batch_name="$(normalize_python_workspace_path "$output_name")"
      generated_batch_name="$(basename "$generated_batch_name")"
      generated_batch_name="${generated_batch_name%.json}"
    else
      generated_batch_name="$(current_admin_generate_auto_batch_name "$discovery_abs")"
    fi

    local generated_batch_output="$batch_output"
    if [ -n "$generated_batch_output" ]; then
      generated_batch_output="$(normalize_python_workspace_path "$generated_batch_output")"
    else
      generated_batch_output="data/current_admin_batches/${generated_batch_name}.json"
    fi

    local -a gen_batch_args=(
      --input "$discovery_path"
      --all-candidates
      --batch-name "$generated_batch_name"
      --output "$generated_batch_output"
    )
    if [ "$allow_overwrite" = "true" ]; then
      gen_batch_args+=(--allow-overwrite)
    fi

    run_step "1/1" "Generate Current-Admin Batch" "Canonical batch generation complete" --output "$generated_batch_output" -- \
      "$VENV_PYTHON" scripts/generate_current_admin_batch_from_discovery.py "${gen_batch_args[@]}"

    workflow_args=(--input "$generated_batch_output" "${workflow_args[@]}")
    CURRENT_ADMIN_PREPARE_SUPPRESS_SUMMARY="true" run_current_admin_prepare_flow "${workflow_args[@]}"
    resolve_current_admin_context "$generated_batch_output" ""
  fi

  resolve_current_admin_automation_artifacts "$CURRENT_ADMIN_BATCH_NAME"

  if [ "$review_dry_run_requested" = "true" ] && [ -z "$stop_after" ]; then
    stop_after="review"
  fi

  if [ "$full_auto" != "true" ]; then
    print_current_admin_run_summary "$CURRENT_ADMIN_INPUT_PATH"
    return 0
  fi

  local -a queue_metrics=()
  mapfile -t queue_metrics < <(current_admin_queue_metrics "$CURRENT_ADMIN_QUEUE_PATH")
  local manual_review_count="${queue_metrics[0]:-0}"
  local auto_approved_count="${queue_metrics[1]:-0}"
  local auto_rejected_count="${queue_metrics[2]:-0}"
  local importable_count="${queue_metrics[3]:-0}"

  if [ "${manual_review_count:-0}" -gt 0 ]; then
    local auto_deep_review_ran="false"
    if [ "$review_dry_run_requested" != "true" ] && [ "$(current_admin_should_auto_deep_review "$CURRENT_ADMIN_QUEUE_PATH")" = "true" ]; then
      local deep_review_experiment="auto-deep-review"
      run_current_admin_deep_review_command --input "$CURRENT_ADMIN_NORMALIZED_PATH" --experiment-name "$deep_review_experiment"
      auto_deep_review_ran="true"
    fi
    local manual_reason="remaining borderline records still require exception handling before apply"
    if [ "$auto_deep_review_ran" = "true" ]; then
      manual_reason="$manual_reason; paired deep-review evidence has also been prepared"
    fi
    write_current_admin_exception_queue \
      "$CURRENT_ADMIN_BATCH_NAME" \
      "manual_review" \
      "$CURRENT_ADMIN_QUEUE_PATH" \
      "Inspect the remaining exception-only manual-review rows." \
      "$(cli_hint) current-admin review --input $(repo_relative_path "$CURRENT_ADMIN_REVIEW_PATH")" \
      "$manual_reason"
    write_current_admin_automation_report \
      "$CURRENT_ADMIN_BATCH_NAME" \
      "exception_queue_ready" \
      "manual_review" \
      "Automation stopped because manual-review exceptions remain."
    print_system_state \
      "EXCEPTION_QUEUE_READY" \
      "Inspect the remaining exception-only manual-review rows." \
      "$(cli_hint) current-admin review --input $(repo_relative_path "$CURRENT_ADMIN_REVIEW_PATH")" \
      "BATCH: $CURRENT_ADMIN_BATCH_NAME" \
      "MANUAL REVIEW ITEMS: $manual_review_count" \
      "AUTO-APPROVED ITEMS: $auto_approved_count" \
      "AUTO-REJECTED ITEMS: $auto_rejected_count" \
      "EXCEPTION QUEUE: $(repo_relative_path "$CURRENT_ADMIN_EXCEPTION_QUEUE_PATH")" \
      "AUTOMATION REPORT: $(repo_relative_path "$CURRENT_ADMIN_AUTOMATION_REPORT_PATH")"
    return 0
  fi

  if [ "$stop_after" = "review" ]; then
    write_current_admin_automation_report \
      "$CURRENT_ADMIN_BATCH_NAME" \
      "stopped" \
      "review" \
      "Automation stopped after the AI-first review split."
    write_current_admin_exception_queue \
      "$CURRENT_ADMIN_BATCH_NAME" \
      "resolved" \
      "$CURRENT_ADMIN_AUTOMATION_REPORT_PATH" \
      "The review split is complete." \
      "$(cli_hint) current-admin apply --input $(repo_relative_path "$CURRENT_ADMIN_QUEUE_PATH")" \
      "review stop requested"
    print_system_state \
      "REVIEW_COMPLETE" \
      "Run the guarded import path or rerun with deeper automation enabled." \
      "$(cli_hint) current-admin apply --input $(repo_relative_path "$CURRENT_ADMIN_QUEUE_PATH")" \
      "BATCH: $CURRENT_ADMIN_BATCH_NAME" \
      "IMPORTABLE ITEMS: $importable_count" \
      "AUTOMATION REPORT: $(repo_relative_path "$CURRENT_ADMIN_AUTOMATION_REPORT_PATH")"
    return 0
  fi

  local apply_message=""
  if [ "${importable_count:-0}" -gt 0 ]; then
    resolve_current_admin_apply_target "" "$CURRENT_ADMIN_BATCH_NAME"
    run_current_admin_guarded_apply_flow "false" "false"
    if [ "$CURRENT_ADMIN_GUARDED_APPLY_STATUS" = "blocked" ]; then
      write_current_admin_exception_queue \
        "$CURRENT_ADMIN_BATCH_NAME" \
        "apply_blocked" \
        "$CURRENT_ADMIN_APPLY_PRECOMMIT_PATH" \
        "Resolve the blocking pre-commit issues before any apply step." \
        "$(cli_hint) current-admin apply --input $(repo_relative_path "$CURRENT_ADMIN_APPLY_QUEUE_PATH")" \
        "guarded pre-commit blocked the import path"
      write_current_admin_automation_report \
        "$CURRENT_ADMIN_BATCH_NAME" \
        "blocked" \
        "apply" \
        "Automation stopped because the guarded pre-commit review is blocked."
      print_system_state \
        "APPLY_BLOCKED" \
        "Resolve the blocking pre-commit issues before any apply step." \
        "$(cli_hint) current-admin apply --input $(repo_relative_path "$CURRENT_ADMIN_APPLY_QUEUE_PATH")" \
        "BATCH: $CURRENT_ADMIN_BATCH_NAME" \
        "PRE-COMMIT REVIEW: $(repo_relative_path "$CURRENT_ADMIN_APPLY_PRECOMMIT_PATH")" \
        "EXCEPTION QUEUE: $(repo_relative_path "$CURRENT_ADMIN_EXCEPTION_QUEUE_PATH")" \
        "AUTOMATION REPORT: $(repo_relative_path "$CURRENT_ADMIN_AUTOMATION_REPORT_PATH")"
      return 0
    fi
    if [ "$no_auto_apply" != "true" ]; then
      run_current_admin_guarded_apply_flow "true" "false"
      apply_message="Guarded import apply and validation completed."
    else
      apply_message="Guarded import apply was skipped because --no-auto-apply was set."
    fi
  else
    apply_message="No importable queue items remained after AI-first review."
  fi

  if [ "$stop_after" = "apply" ] || [ "$no_impact_automation" = "true" ]; then
    write_current_admin_automation_report \
      "$CURRENT_ADMIN_BATCH_NAME" \
      "stopped" \
      "apply" \
      "$apply_message"
    write_current_admin_exception_queue \
      "$CURRENT_ADMIN_BATCH_NAME" \
      "resolved" \
      "$CURRENT_ADMIN_AUTOMATION_REPORT_PATH" \
      "The guarded apply phase is complete." \
      "$(cli_hint) current-admin run --input $(repo_relative_path "$CURRENT_ADMIN_INPUT_PATH") --stop-after impact-evaluate" \
      "apply stop requested"
    print_system_state \
      "APPLY_COMPLETE" \
      "Continue into outcome-evidence and impact automation when ready." \
      "$(cli_hint) current-admin run --input $(repo_relative_path "$CURRENT_ADMIN_INPUT_PATH") --stop-after impact-evaluate" \
      "BATCH: $CURRENT_ADMIN_BATCH_NAME" \
      "MESSAGE: $apply_message" \
      "AUTOMATION REPORT: $(repo_relative_path "$CURRENT_ADMIN_AUTOMATION_REPORT_PATH")"
    return 0
  fi

  run_step "1/5" "Collect Outcome Evidence" "Current-admin outcome evidence collection complete" --output "$CURRENT_ADMIN_OUTCOME_EVIDENCE_PATH" -- \
    "$VENV_PYTHON" scripts/discover_current_admin_outcome_evidence.py \
      --input "$CURRENT_ADMIN_NORMALIZED_PATH" \
      --include-all-statuses \
      --output "$CURRENT_ADMIN_OUTCOME_EVIDENCE_PATH"

  run_step "2/5" "Evaluate Impact Maturation" "Impact maturation review artifact generated" --output "$CURRENT_ADMIN_IMPACT_EVALUATE_PATH" -- \
    "$VENV_PYTHON" scripts/evaluate_impact_maturation.py evaluate \
      --input "$CURRENT_ADMIN_NORMALIZED_PATH" \
      --outcome-evidence "$CURRENT_ADMIN_OUTCOME_EVIDENCE_PATH" \
      --auto-approve-safe-supplemental \
      --dry-run \
      --output "$CURRENT_ADMIN_IMPACT_EVALUATE_PATH"

  local -a impact_counts=()
  mapfile -t impact_counts < <(current_admin_impact_evaluate_counts "$CURRENT_ADMIN_IMPACT_EVALUATE_PATH")
  local impact_auto_approved_count="${impact_counts[0]:-0}"
  local impact_blocked_count="${impact_counts[1]:-0}"
  local exception_stage=""

  if [ "${impact_blocked_count:-0}" -gt 0 ]; then
    exception_stage="impact_blocked"
  fi

  if [ "$stop_after" = "impact-evaluate" ]; then
    write_current_admin_automation_report \
      "$CURRENT_ADMIN_BATCH_NAME" \
      "stopped" \
      "impact_evaluate" \
      "Impact evaluation completed in dry-run mode."
    if [ -n "$exception_stage" ]; then
      write_current_admin_exception_queue \
        "$CURRENT_ADMIN_BATCH_NAME" \
        "$exception_stage" \
        "$CURRENT_ADMIN_IMPACT_EVALUATE_PATH" \
        "Inspect the remaining blocked supplemental-evidence transitions." \
        "$(cli_hint) impact evaluate --input $(repo_relative_path "$CURRENT_ADMIN_NORMALIZED_PATH") --outcome-evidence $(repo_relative_path "$CURRENT_ADMIN_OUTCOME_EVIDENCE_PATH") --auto-approve-safe-supplemental --dry-run" \
        "impact evaluation left blocked supplemental rows"
      print_system_state \
        "EXCEPTION_QUEUE_READY" \
        "Inspect the remaining blocked supplemental-evidence transitions." \
        "$(cli_hint) impact evaluate --input $(repo_relative_path "$CURRENT_ADMIN_NORMALIZED_PATH") --outcome-evidence $(repo_relative_path "$CURRENT_ADMIN_OUTCOME_EVIDENCE_PATH") --auto-approve-safe-supplemental --dry-run" \
        "BATCH: $CURRENT_ADMIN_BATCH_NAME" \
        "IMPACT AUTO-APPROVED: $impact_auto_approved_count" \
        "IMPACT BLOCKED: $impact_blocked_count" \
        "EXCEPTION QUEUE: $(repo_relative_path "$CURRENT_ADMIN_EXCEPTION_QUEUE_PATH")" \
        "AUTOMATION REPORT: $(repo_relative_path "$CURRENT_ADMIN_AUTOMATION_REPORT_PATH")"
      return 0
    fi
    write_current_admin_exception_queue \
      "$CURRENT_ADMIN_BATCH_NAME" \
      "resolved" \
      "$CURRENT_ADMIN_AUTOMATION_REPORT_PATH" \
      "Impact evaluation dry-run is complete." \
      "$(cli_hint) current-admin run --input $(repo_relative_path "$CURRENT_ADMIN_INPUT_PATH") --stop-after impact-promote" \
      "impact evaluation stop requested"
    print_system_state \
      "IMPACT_EVALUATE_COMPLETE" \
      "Continue into impact promotion or rerun with later automation enabled." \
      "$(cli_hint) current-admin run --input $(repo_relative_path "$CURRENT_ADMIN_INPUT_PATH") --stop-after impact-promote" \
      "BATCH: $CURRENT_ADMIN_BATCH_NAME" \
      "IMPACT AUTO-APPROVED: $impact_auto_approved_count" \
      "AUTOMATION REPORT: $(repo_relative_path "$CURRENT_ADMIN_AUTOMATION_REPORT_PATH")"
    return 0
  fi

  if [ "${impact_auto_approved_count:-0}" -gt 0 ]; then
    run_step "3/5" "Promote Impact Maturation Dry-Run" "Impact maturation promotion dry-run complete" --output "$CURRENT_ADMIN_IMPACT_PROMOTE_DRY_RUN_PATH" -- \
      "$VENV_PYTHON" scripts/evaluate_impact_maturation.py promote \
        --input "$CURRENT_ADMIN_IMPACT_EVALUATE_PATH" \
        --dry-run \
        --output "$CURRENT_ADMIN_IMPACT_PROMOTE_DRY_RUN_PATH"
    if [ "$no_auto_apply" != "true" ]; then
      run_step "4/5" "Promote Impact Maturation Apply" "Impact maturation promotion apply complete" --output "$CURRENT_ADMIN_IMPACT_PROMOTE_APPLY_PATH" -- \
        "$VENV_PYTHON" scripts/evaluate_impact_maturation.py promote \
          --input "$CURRENT_ADMIN_IMPACT_EVALUATE_PATH" \
          --apply \
          --yes \
          --output "$CURRENT_ADMIN_IMPACT_PROMOTE_APPLY_PATH"
    fi
  fi

  if [ "$stop_after" = "impact-promote" ]; then
    write_current_admin_automation_report \
      "$CURRENT_ADMIN_BATCH_NAME" \
      "stopped" \
      "impact_promote" \
      "Impact promotion completed for validator-approved rows."
    if [ -n "$exception_stage" ]; then
      write_current_admin_exception_queue \
        "$CURRENT_ADMIN_BATCH_NAME" \
        "$exception_stage" \
        "$CURRENT_ADMIN_IMPACT_EVALUATE_PATH" \
        "Inspect the remaining blocked supplemental-evidence transitions." \
        "$(cli_hint) impact promote --input $(repo_relative_path "$CURRENT_ADMIN_IMPACT_EVALUATE_PATH") --dry-run" \
        "impact promotion left blocked supplemental rows unresolved"
      print_system_state \
        "EXCEPTION_QUEUE_READY" \
        "Inspect the remaining blocked supplemental-evidence transitions." \
        "$(cli_hint) impact promote --input $(repo_relative_path "$CURRENT_ADMIN_IMPACT_EVALUATE_PATH") --dry-run" \
        "BATCH: $CURRENT_ADMIN_BATCH_NAME" \
        "EXCEPTION QUEUE: $(repo_relative_path "$CURRENT_ADMIN_EXCEPTION_QUEUE_PATH")" \
        "AUTOMATION REPORT: $(repo_relative_path "$CURRENT_ADMIN_AUTOMATION_REPORT_PATH")"
      return 0
    fi
    write_current_admin_exception_queue \
      "$CURRENT_ADMIN_BATCH_NAME" \
      "resolved" \
      "$CURRENT_ADMIN_AUTOMATION_REPORT_PATH" \
      "Impact promotion is complete." \
      "$(cli_hint) current-admin run --input $(repo_relative_path "$CURRENT_ADMIN_INPUT_PATH") --stop-after enrichment" \
      "impact promotion stop requested"
    print_system_state \
      "IMPACT_PROMOTE_COMPLETE" \
      "Continue into outcome enrichment when ready." \
      "$(cli_hint) current-admin run --input $(repo_relative_path "$CURRENT_ADMIN_INPUT_PATH") --stop-after enrichment" \
      "BATCH: $CURRENT_ADMIN_BATCH_NAME" \
      "AUTOMATION REPORT: $(repo_relative_path "$CURRENT_ADMIN_AUTOMATION_REPORT_PATH")"
    return 0
  fi

  run_step "5/5" "Preview Outcome Enrichment" "Current-admin policy_outcome enrichment preview complete" --output "$CURRENT_ADMIN_OUTCOME_ENRICHMENT_PREVIEW_PATH" -- \
    "$VENV_PYTHON" scripts/preview_current_admin_policy_outcome_enrichment.py \
      --input "$CURRENT_ADMIN_NORMALIZED_PATH" \
      --outcome-evidence "$CURRENT_ADMIN_OUTCOME_EVIDENCE_PATH" \
      --output "$CURRENT_ADMIN_OUTCOME_ENRICHMENT_PREVIEW_PATH"

  run_step "1/3" "Outcome Enrichment Dry-Run" "Current-admin outcome enrichment dry-run complete" --output "$CURRENT_ADMIN_OUTCOME_ENRICHMENT_DRY_RUN_PATH" -- \
    "$VENV_PYTHON" scripts/apply_current_admin_outcome_enrichment.py \
      --input "$CURRENT_ADMIN_NORMALIZED_PATH" \
      --outcome-evidence "$CURRENT_ADMIN_OUTCOME_EVIDENCE_PATH" \
      --impact-evaluation "$CURRENT_ADMIN_IMPACT_EVALUATE_PATH" \
      --dry-run \
      --output "$CURRENT_ADMIN_OUTCOME_ENRICHMENT_DRY_RUN_PATH"

  local -a enrichment_counts=()
  mapfile -t enrichment_counts < <(current_admin_enrichment_counts "$CURRENT_ADMIN_OUTCOME_ENRICHMENT_DRY_RUN_PATH")
  local enrichment_approved_count="${enrichment_counts[0]:-0}"
  local enrichment_blocked_count="${enrichment_counts[1]:-0}"
  if [ -z "$exception_stage" ] && [ "${enrichment_blocked_count:-0}" -gt 0 ]; then
    exception_stage="enrichment_blocked"
  fi

  if [ "${enrichment_approved_count:-0}" -gt 0 ] && [ "$no_auto_apply" != "true" ]; then
    run_step "2/3" "Outcome Enrichment Apply" "Current-admin outcome enrichment apply complete" --output "$CURRENT_ADMIN_OUTCOME_ENRICHMENT_APPLY_PATH" -- \
      "$VENV_PYTHON" scripts/apply_current_admin_outcome_enrichment.py \
        --input "$CURRENT_ADMIN_NORMALIZED_PATH" \
        --outcome-evidence "$CURRENT_ADMIN_OUTCOME_EVIDENCE_PATH" \
        --impact-evaluation "$CURRENT_ADMIN_IMPACT_EVALUATE_PATH" \
        --apply \
        --yes \
        --output "$CURRENT_ADMIN_OUTCOME_ENRICHMENT_APPLY_PATH"

    mapfile -t enrichment_counts < <(current_admin_enrichment_counts "$CURRENT_ADMIN_OUTCOME_ENRICHMENT_APPLY_PATH")
    local enrichment_applied_count="${enrichment_counts[2]:-0}"
    local touched_outcome_ids_csv="${enrichment_counts[3]:-}"
    if [ "${enrichment_applied_count:-0}" -gt 0 ] && [ -n "$touched_outcome_ids_csv" ]; then
      local -a sync_args=(--apply --yes --output "$CURRENT_ADMIN_OUTCOME_SYNC_APPLY_PATH")
      local touched_id=""
      IFS=',' read -r -a _current_admin_touched_ids <<< "$touched_outcome_ids_csv"
      for touched_id in "${_current_admin_touched_ids[@]}"; do
        if [ -n "$touched_id" ]; then
          sync_args+=(--only-outcome-id "$touched_id")
        fi
      done
      if [ "${#sync_args[@]}" -gt 4 ]; then
        run_step "3/3" "Sync Current-Admin Policy Outcomes" "Current-admin policy_outcomes sync complete" --output "$CURRENT_ADMIN_OUTCOME_SYNC_APPLY_PATH" -- \
          "$VENV_PYTHON" scripts/sync_current_admin_policy_outcomes.py "${sync_args[@]}"
      fi
    fi
  fi

  local final_status="complete"
  local final_stage="enrichment"
  local final_message="Full current-admin automation completed."
  if [ "$no_auto_apply" = "true" ]; then
    final_status="dry_run_complete"
    final_message="Read-only automation completed; guarded apply steps were skipped because --no-auto-apply was set."
  fi
  if [ "$stop_after" = "enrichment" ]; then
    final_status="stopped"
    final_message="Automation stopped after the enrichment phase."
  fi
  write_current_admin_automation_report "$CURRENT_ADMIN_BATCH_NAME" "$final_status" "$final_stage" "$final_message"

  if [ -n "$exception_stage" ]; then
    local exception_source="$CURRENT_ADMIN_IMPACT_EVALUATE_PATH"
    local exception_command="$(cli_hint) impact evaluate --input $(repo_relative_path "$CURRENT_ADMIN_NORMALIZED_PATH") --outcome-evidence $(repo_relative_path "$CURRENT_ADMIN_OUTCOME_EVIDENCE_PATH") --auto-approve-safe-supplemental --dry-run"
    local exception_step="Inspect the remaining blocked impact or enrichment exceptions."
    local exception_reason="validator-blocked supplemental or enrichment rows remain outside the automated write path"
    if [ "$exception_stage" = "enrichment_blocked" ]; then
      exception_source="$CURRENT_ADMIN_OUTCOME_ENRICHMENT_DRY_RUN_PATH"
      exception_command="$(cli_hint) impact apply-current-admin-outcome-enrichment --input $(repo_relative_path "$CURRENT_ADMIN_NORMALIZED_PATH") --outcome-evidence $(repo_relative_path "$CURRENT_ADMIN_OUTCOME_EVIDENCE_PATH") --impact-evaluation $(repo_relative_path "$CURRENT_ADMIN_IMPACT_EVALUATE_PATH") --dry-run"
    fi
    write_current_admin_exception_queue \
      "$CURRENT_ADMIN_BATCH_NAME" \
      "$exception_stage" \
      "$exception_source" \
      "$exception_step" \
      "$exception_command" \
      "$exception_reason"
    print_system_state \
      "EXCEPTION_QUEUE_READY" \
      "$exception_step" \
      "$exception_command" \
      "BATCH: $CURRENT_ADMIN_BATCH_NAME" \
      "OUTCOME EVIDENCE: $(repo_relative_path "$CURRENT_ADMIN_OUTCOME_EVIDENCE_PATH")" \
      "IMPACT EVALUATE: $(repo_relative_path "$CURRENT_ADMIN_IMPACT_EVALUATE_PATH")" \
      "ENRICHMENT DRY-RUN: $(repo_relative_path "$CURRENT_ADMIN_OUTCOME_ENRICHMENT_DRY_RUN_PATH")" \
      "EXCEPTION QUEUE: $(repo_relative_path "$CURRENT_ADMIN_EXCEPTION_QUEUE_PATH")" \
      "AUTOMATION REPORT: $(repo_relative_path "$CURRENT_ADMIN_AUTOMATION_REPORT_PATH")"
    return 0
  fi

  write_current_admin_exception_queue \
    "$CURRENT_ADMIN_BATCH_NAME" \
    "resolved" \
    "$CURRENT_ADMIN_AUTOMATION_REPORT_PATH" \
    "Automation completed without remaining exception-only queue items." \
    "$(cli_hint) current-admin run" \
    "all automatable stages completed"
  print_system_state \
    "COMPLETE" \
    "Start the next current-admin automation cycle when new candidates appear." \
    "$(cli_hint) current-admin run" \
    "BATCH: $CURRENT_ADMIN_BATCH_NAME" \
    "OUTCOME EVIDENCE: $(repo_relative_path "$CURRENT_ADMIN_OUTCOME_EVIDENCE_PATH")" \
    "IMPACT EVALUATE: $(repo_relative_path "$CURRENT_ADMIN_IMPACT_EVALUATE_PATH")" \
    "AUTOMATION REPORT: $(repo_relative_path "$CURRENT_ADMIN_AUTOMATION_REPORT_PATH")"
}

run_current_admin_operator_review_command() {
  local input_path=""
  local batch_name=""
  local decision_file=""
  local refresh_template="false"
  local feedback_summary="false"
  local log_decisions_path=""

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --input)
        input_path="${2:-}"
        [ -n "$input_path" ] || { echo "--input requires a value" >&2; exit 1; }
        shift 2
        ;;
      --batch-name)
        batch_name="${2:-}"
        [ -n "$batch_name" ] || { echo "--batch-name requires a value" >&2; exit 1; }
        shift 2
        ;;
      --decision-file)
        decision_file="${2:-}"
        [ -n "$decision_file" ] || { echo "--decision-file requires a value" >&2; exit 1; }
        shift 2
        ;;
      --log-decisions)
        if [ -n "${2:-}" ] && [[ "${2:-}" != --* ]]; then
          log_decisions_path="${2:-}"
          shift 2
        else
          log_decisions_path=""
          shift
        fi
        ;;
      --refresh-template)
        refresh_template="true"
        shift
        ;;
      --feedback-summary)
        feedback_summary="true"
        shift
        ;;
      -h|--help)
        current_admin_subcommand_usage review
        exit 0
        ;;
      *)
        echo "Unknown argument for current-admin review: $1" >&2
        exit 1
        ;;
    esac
  done

  if [ -n "$input_path" ] && [ -n "$batch_name" ]; then
    echo "Use either --input or --batch-name for current-admin review" >&2
    exit 1
  fi

  resolve_current_admin_review_target "$input_path" "$batch_name"
  local review_path="$CURRENT_ADMIN_REVIEW_TARGET_PATH"
  if [ -n "$decision_file" ]; then
    decision_file="$(normalize_python_workspace_path "$decision_file")"
  else
    decision_file="$CURRENT_ADMIN_REVIEW_TARGET_DECISION_TEMPLATE"
  fi
  if [ -n "$log_decisions_path" ]; then
    log_decisions_path="$(normalize_python_workspace_path "$log_decisions_path")"
  else
    log_decisions_path="$(current_admin_decision_log_dir)/${CURRENT_ADMIN_REVIEW_TARGET_BATCH_NAME}.decision-log.json"
  fi

  resolve_review_artifact_context "$review_path"
  local -a promote_args=(
    "$VENV_PYTHON"
    scripts/promote_current_admin_review_to_queue.py
    --input "$review_path"
    --batch "$REVIEW_ARTIFACT_NORMALIZED_PATH"
    --decision-template-output "$decision_file"
    --decision-log-output "$log_decisions_path"
  )
  if [ "$refresh_template" != "true" ]; then
    promote_args+=(--no-backup)
  fi

  run_step "1/2" "Promote AI Decisions" "AI-first review queue refreshed from the canonical review artifact" --output "$CURRENT_ADMIN_REVIEW_TARGET_QUEUE_PATH" -- \
    "${promote_args[@]}"

  local -a queue_count_lines=()
  mapfile -t queue_count_lines < <(
    CURRENT_ADMIN_QUEUE_PATH="$CURRENT_ADMIN_REVIEW_TARGET_QUEUE_PATH" "$VENV_PYTHON" - <<'PY'
import json
import os
from pathlib import Path

path = Path(os.environ["CURRENT_ADMIN_QUEUE_PATH"]).resolve()
payload = json.loads(path.read_text()) if path.exists() else {}
manual_items = payload.get("items") or []
auto_approved = payload.get("auto_approved_items") or []
auto_rejected = payload.get("auto_rejected_items") or []
print(len([item for item in manual_items if isinstance(item, dict)]))
print(len([item for item in auto_approved if isinstance(item, dict)]))
print(len([item for item in auto_rejected if isinstance(item, dict)]))
PY
  )
  local manual_review_count="${queue_count_lines[0]:-0}"

  if [ "${manual_review_count:-0}" -le 0 ]; then
    print_current_admin_review_summary "$review_path" "$decision_file" "$log_decisions_path" "true"
    return 0
  fi

  local -a decision_status_lines=()
  mapfile -t decision_status_lines < <(current_admin_decision_file_status "$review_path" "$decision_file")
  local decision_status="${decision_status_lines[0]:-invalid}"
  if [ "$decision_status" = "mismatch" ]; then
    echo "Decision file does not match the selected review artifact. Use --refresh-template or pass the correct --decision-file." >&2
    exit 1
  fi

  if [ "$decision_status" != "ready" ]; then
    print_current_admin_review_summary "$review_path" "$decision_file" "$(current_admin_decision_log_dir)/placeholder.decision-log.json" "false"
    return 0
  fi

  local -a finalize_args=(
    --review "$review_path"
    --decision-file "$decision_file"
    --log-decisions "$log_decisions_path"
  )
  if [ "$feedback_summary" = "true" ]; then
    finalize_args+=(--feedback-summary)
  fi

  run_current_admin_finalize_review "${finalize_args[@]}"
  print_current_admin_review_summary "$review_path" "$decision_file" "$log_decisions_path" "true"
}

run_current_admin_guarded_apply_flow() {
  local explicit_apply="$1"
  local print_summary="${2:-false}"

  CURRENT_ADMIN_GUARDED_APPLY_STATUS="unknown"

  run_step "1/4" "Build Pre-Commit Review" "Pre-commit review build complete" --output "$CURRENT_ADMIN_APPLY_PRECOMMIT_PATH" -- \
    "$VENV_PYTHON" scripts/build_current_admin_precommit_review.py --input "$CURRENT_ADMIN_APPLY_QUEUE_PATH"

  local precommit_status="missing"
  precommit_status="$(read_precommit_status "$CURRENT_ADMIN_APPLY_PRECOMMIT_PATH")"
  if [ "$precommit_status" = "blocked" ]; then
    CURRENT_ADMIN_GUARDED_APPLY_STATUS="blocked"
    if [ "$print_summary" = "true" ]; then
      print_current_admin_apply_summary \
        "$CURRENT_ADMIN_APPLY_QUEUE_PATH" \
        "$CURRENT_ADMIN_APPLY_PRECOMMIT_PATH" \
        "$CURRENT_ADMIN_APPLY_DRY_RUN_PATH" \
        "$CURRENT_ADMIN_APPLY_IMPORT_APPLY_PATH" \
        "$CURRENT_ADMIN_APPLY_VALIDATION_PATH" \
        "false"
    fi
    return 0
  fi

  run_step "2/4" "Import Dry-Run" "Current-admin import dry-run complete" --output "$CURRENT_ADMIN_APPLY_DRY_RUN_PATH" -- \
    "$VENV_PYTHON" scripts/import_curated_current_admin_batch.py --input "$CURRENT_ADMIN_APPLY_QUEUE_PATH" --output "$CURRENT_ADMIN_APPLY_DRY_RUN_PATH"

  if [ "$explicit_apply" != "true" ]; then
    CURRENT_ADMIN_GUARDED_APPLY_STATUS="dry_run_ready"
    if [ "$print_summary" = "true" ]; then
      print_current_admin_apply_summary \
        "$CURRENT_ADMIN_APPLY_QUEUE_PATH" \
        "$CURRENT_ADMIN_APPLY_PRECOMMIT_PATH" \
        "$CURRENT_ADMIN_APPLY_DRY_RUN_PATH" \
        "$CURRENT_ADMIN_APPLY_IMPORT_APPLY_PATH" \
        "$CURRENT_ADMIN_APPLY_VALIDATION_PATH" \
        "false"
    fi
    return 0
  fi

  run_step "3/4" "Import Apply" "Current-admin import apply complete" --output "$CURRENT_ADMIN_APPLY_IMPORT_APPLY_PATH" -- \
    "$VENV_PYTHON" scripts/import_curated_current_admin_batch.py --input "$CURRENT_ADMIN_APPLY_QUEUE_PATH" --output "$CURRENT_ADMIN_APPLY_IMPORT_APPLY_PATH" --apply --yes

  run_step "4/4" "Validate Import" "Current-admin validation complete" --output "$CURRENT_ADMIN_APPLY_VALIDATION_PATH" -- \
    "$VENV_PYTHON" scripts/validate_current_admin_import.py --input "$CURRENT_ADMIN_APPLY_QUEUE_PATH" --output "$CURRENT_ADMIN_APPLY_VALIDATION_PATH"

  CURRENT_ADMIN_GUARDED_APPLY_STATUS="applied"
  if [ "$print_summary" = "true" ]; then
    print_current_admin_apply_summary \
      "$CURRENT_ADMIN_APPLY_QUEUE_PATH" \
      "$CURRENT_ADMIN_APPLY_PRECOMMIT_PATH" \
      "$CURRENT_ADMIN_APPLY_DRY_RUN_PATH" \
      "$CURRENT_ADMIN_APPLY_IMPORT_APPLY_PATH" \
      "$CURRENT_ADMIN_APPLY_VALIDATION_PATH" \
      "true"
  fi
}

run_current_admin_apply_command() {
  local input_path=""
  local batch_name=""
  local explicit_apply="false"
  local confirmed="false"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --input)
        input_path="${2:-}"
        [ -n "$input_path" ] || { echo "--input requires a value" >&2; exit 1; }
        shift 2
        ;;
      --batch-name)
        batch_name="${2:-}"
        [ -n "$batch_name" ] || { echo "--batch-name requires a value" >&2; exit 1; }
        shift 2
        ;;
      --apply)
        explicit_apply="true"
        shift
        ;;
      --yes)
        confirmed="true"
        shift
        ;;
      -h|--help)
        current_admin_subcommand_usage apply
        exit 0
        ;;
      *)
        echo "Unknown argument for current-admin apply: $1" >&2
        exit 1
        ;;
    esac
  done

  if [ -n "$input_path" ] && [ -n "$batch_name" ]; then
    echo "Use either --input or --batch-name for current-admin apply" >&2
    exit 1
  fi
  if [ "$explicit_apply" = "true" ] && [ "$confirmed" != "true" ]; then
    echo "equitystack current-admin apply --apply requires --yes" >&2
    exit 1
  fi
  if [ "$explicit_apply" != "true" ] && [ "$confirmed" = "true" ]; then
    echo "Use --yes only with --apply for current-admin apply" >&2
    exit 1
  fi

  resolve_current_admin_apply_target "$input_path" "$batch_name"
  run_current_admin_guarded_apply_flow "$explicit_apply" "true"
}

run_legislative_command() {
  local command="${1:-}"
  shift || true

  case "$command" in
    run)
      local review_model="$DEFAULT_MODEL_REVIEW"
      local verifier_model="$DEFAULT_MODEL_VERIFIER"
      local fallback_model="$DEFAULT_MODEL_FALLBACK"
      local timeout=""
      local senior_timeout="$DEFAULT_REVIEW_TIMEOUT_SENIOR"
      local verifier_timeout="$DEFAULT_REVIEW_TIMEOUT_VERIFIER"
      local -a passthrough=()

      while [ "$#" -gt 0 ]; do
        case "$1" in
          --model)
            review_model="${2:-}"
            [ -n "$review_model" ] || { echo "--model requires a value" >&2; exit 1; }
            shift 2
            ;;
          --verifier-model)
            verifier_model="${2:-}"
            [ -n "$verifier_model" ] || { echo "--verifier-model requires a value" >&2; exit 1; }
            shift 2
            ;;
          --fallback-model)
            fallback_model="${2:-}"
            [ -n "$fallback_model" ] || { echo "--fallback-model requires a value" >&2; exit 1; }
            shift 2
            ;;
          --timeout)
            timeout="${2:-}"
            [ -n "$timeout" ] || { echo "--timeout requires a value" >&2; exit 1; }
            shift 2
            ;;
          --senior-timeout)
            senior_timeout="${2:-}"
            [ -n "$senior_timeout" ] || { echo "--senior-timeout requires a value" >&2; exit 1; }
            shift 2
            ;;
          --verifier-timeout)
            verifier_timeout="${2:-}"
            [ -n "$verifier_timeout" ] || { echo "--verifier-timeout requires a value" >&2; exit 1; }
            shift 2
            ;;
          --skip-discovery|--apply-safe-removals|--csv)
            passthrough+=("$1")
            shift
            ;;
          --output-report|--only-future-bill-id)
            passthrough+=("$1" "${2:-}")
            [ -n "${2:-}" ] || { echo "$1 requires a value" >&2; exit 1; }
            shift 2
            ;;
          -h|--help)
            legislative_usage
            exit 0
            ;;
          *)
            echo "Unknown argument for legislative run: $1" >&2
            exit 1
            ;;
        esac
      done

      if [ -n "$timeout" ]; then
        senior_timeout="$timeout"
        verifier_timeout="$timeout"
      fi

      if ! command_has_flag "--csv" "${passthrough[@]}"; then
        passthrough+=(--csv)
      fi
      if ! command_has_flag "--output-report" "${passthrough[@]}"; then
        passthrough+=(--output-report "$(pipeline_report_path)")
      fi

      run_step "1/3" "Daily Review Pipeline" "Legislative pipeline reports refreshed" \
        --output "$(pipeline_report_path)" \
        --output "$(future_bill_ai_review_path)" \
        --output "$(future_bill_manual_queue_path)" \
        --output "$(future_bill_suggestion_path)" \
        -- \
        "$VENV_PYTHON" run_equitystack_pipeline.py \
          --review-model "$review_model" \
          --verifier-model "$verifier_model" \
          --fallback-model "$fallback_model" \
          --senior-timeout "$senior_timeout" \
          --verifier-timeout "$verifier_timeout" \
          "${passthrough[@]}"

      run_step "2/3" "Auto-Triage Review Bundle" "Safe review bundle actions auto-triaged" -- \
        "$VENV_PYTHON" scripts/auto_triage_review_bundle.py --apply --yes --auto-approve-safe-actions

      run_step "3/3" "Rebuild Review Bundle" "Review bundle rebuilt" --output "$(review_bundle_path)" -- \
        "$VENV_PYTHON" scripts/build_review_bundle.py --csv --use-feedback

      print_system_state \
        "REVIEW_READY" \
        "Review the updated bundle and approve or reject actions" \
        "$(cli_hint) legislative review" \
        "SENIOR MODEL: $review_model" \
        "VERIFIER MODEL: $verifier_model" \
        "FALLBACK MODEL: $fallback_model" \
        "SENIOR TIMEOUT: ${senior_timeout}s" \
        "VERIFIER TIMEOUT: ${verifier_timeout}s" \
        "PIPELINE REPORT: $(repo_relative_path "$(pipeline_report_path)")"
      ;;
    review)
      [ "$#" -eq 0 ] || { echo "equitystack legislative review does not accept extra arguments" >&2; exit 1; }
      run_step "1/1" "Review Bundle Actions" "Legislative review session complete" -- \
        "$VENV_PYTHON" scripts/review_bundle_actions.py --non-interactive-summary
      ;;
    apply)
      local dry_run="false"
      local explicit_apply="false"
      local confirmed="false"
      while [ "$#" -gt 0 ]; do
        case "$1" in
          --dry-run)
            dry_run="true"
            shift
            ;;
          --apply)
            explicit_apply="true"
            shift
            ;;
          --yes)
            confirmed="true"
            shift
            ;;
          -h|--help)
            legislative_usage
            exit 0
            ;;
          *)
            echo "Unknown argument for legislative apply: $1" >&2
            exit 1
            ;;
        esac
      done

      if [ "$dry_run" = "true" ] && [ "$explicit_apply" = "true" ]; then
        echo "Use either --dry-run or --apply --yes for legislative apply" >&2
        exit 1
      fi

      if [ "$dry_run" = "true" ]; then
        run_step "1/1" "Dry-Run Apply Review Bundle" "Legislative apply preview complete" --output "$(apply_report_path)" -- \
          "$VENV_PYTHON" scripts/apply_review_bundle.py --csv

        print_system_state \
          "APPLY_READY" \
          "Inspect the dry-run report, then apply approved legislative actions when ready" \
          "$(cli_hint) legislative apply --apply --yes"
      else
        if [ "$explicit_apply" = "true" ] && [ "$confirmed" != "true" ]; then
          echo "equitystack legislative apply --apply requires --yes" >&2
          exit 1
        fi

        run_step "1/4" "Apply Review Bundle" "Approved legislative actions applied" --output "$(apply_report_path)" -- \
          "$VENV_PYTHON" scripts/apply_review_bundle.py --apply --yes --csv

        if apply_report_has_affected_bills; then
          run_step "2/4" "Rerun Affected Future Bills" "Affected future bills rerun" -- \
            "$VENV_PYTHON" scripts/rerun_affected_future_bills.py --from-apply-report "$(apply_report_path)" --csv
        else
          print_step_header "2/4" "Rerun Affected Future Bills"
          printf 'SUCCESS: No affected future bills were recorded. Skipping rerun.\n'
        fi

        run_step "3/4" "Rebuild Review Bundle" "Review bundle rebuilt" --output "$(review_bundle_path)" -- \
          "$VENV_PYTHON" scripts/build_review_bundle.py --csv --use-feedback

        run_step "4/4" "Repair Canonical Review State" "Stale legislative bundle state reconciled" --output "$EQUITYSTACK_PYTHON_DIR/reports/equitystack_bundle_repair_report.json" -- \
          "$VENV_PYTHON" scripts/repair_review_bundle.py --apply --yes

        print_system_state \
          "REVIEW_READY" \
          "Inspect the refreshed review bundle" \
          "$(cli_hint) legislative review"
      fi
      ;;
    import)
      local dry_run="false"
      local explicit_apply="false"
      local confirmed="false"
      while [ "$#" -gt 0 ]; do
        case "$1" in
          --dry-run)
            dry_run="true"
            shift
            ;;
          --apply)
            explicit_apply="true"
            shift
            ;;
          --yes)
            confirmed="true"
            shift
            ;;
          -h|--help)
            legislative_usage
            exit 0
            ;;
          *)
            echo "Unknown argument for legislative import: $1" >&2
            exit 1
            ;;
        esac
      done

      if [ "$dry_run" = "true" ] && [ "$explicit_apply" = "true" ]; then
        echo "Use either --dry-run or --apply --yes for legislative import" >&2
        exit 1
      fi

      if [ "$dry_run" = "true" ]; then
        run_step "1/1" "Dry-Run Import Approved Tracked Bills" "Legislative import preview complete" -- \
          "$VENV_PYTHON" scripts/import_approved_tracked_bills.py --link-imported-bills --enrich-metadata --csv

        print_system_state \
          "IMPORT_READY" \
          "Inspect the dry-run import report, then apply the approved tracked-bill import when ready" \
          "$(cli_hint) legislative import --apply --yes"
      else
        if [ "$explicit_apply" = "true" ] && [ "$confirmed" != "true" ]; then
          echo "equitystack legislative import --apply requires --yes" >&2
          exit 1
        fi

        run_step "1/2" "Import Approved Tracked Bills" "Approved tracked bills imported" -- \
          "$VENV_PYTHON" scripts/import_approved_tracked_bills.py --apply --yes --link-imported-bills --enrich-metadata --csv

        run_step "2/2" "Rebuild Review Bundle" "Review bundle rebuilt" --output "$(review_bundle_path)" -- \
          "$VENV_PYTHON" scripts/build_review_bundle.py --csv --use-feedback

        print_system_state \
          "REVIEW_READY" \
          "Review the new bundle after import" \
          "$(cli_hint) legislative review"
      fi
      ;;
    repair|reconcile)
      run_step "1/1" "Repair Legislative Review Bundle" "Legislative bundle repair complete" --output "$EQUITYSTACK_PYTHON_DIR/reports/equitystack_bundle_repair_report.json" -- \
        "$VENV_PYTHON" scripts/repair_review_bundle.py "$@"
      ;;
    materialize-outcomes)
      run_step "1/1" "Materialize Legislative Outcomes" "Legislative policy_outcomes materialization complete" --output "$EQUITYSTACK_PYTHON_DIR/reports/legislative-policy-outcomes-materialize.dry-run.json" -- \
        "$VENV_PYTHON" scripts/materialize_legislative_policy_outcomes.py "$@"
      ;;
    feedback)
      [ "$#" -eq 0 ] || { echo "equitystack legislative feedback does not accept extra arguments" >&2; exit 1; }
      run_step "1/2" "Analyze Feedback" "Feedback analysis refreshed" -- \
        "$VENV_PYTHON" scripts/analyze_feedback.py

      run_step "2/2" "Rebuild Review Bundle" "Review bundle rebuilt" --output "$(review_bundle_path)" -- \
        "$VENV_PYTHON" scripts/build_review_bundle.py --csv --use-feedback

      print_system_state \
        "REVIEW_READY" \
        "Review the updated feedback-informed bundle" \
        "$(cli_hint) legislative review"
      ;;
    help|-h|--help|"")
      legislative_usage
      ;;
    *)
      echo "Unknown legislative command: $command" >&2
      legislative_usage
      exit 1
      ;;
  esac
}

