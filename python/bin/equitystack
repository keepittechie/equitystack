  local command="${1:-}"
  shift || true
  local -a normalized_args=()
  normalize_impact_path_args normalized_args "$@"
  set -- "${normalized_args[@]}"

  case "$command" in
    evaluate)
      run_step "1/1" "Evaluate Impact Maturation" "Impact maturation review artifact generated" --output "$EQUITYSTACK_PYTHON_DIR/reports/impact_maturation_review.json" -- \
        "$VENV_PYTHON" scripts/evaluate_impact_maturation.py evaluate "$@"
      ;;
    promote)
      run_step "1/1" "Promote Impact Maturation" "Impact maturation promotion complete" --output "$EQUITYSTACK_PYTHON_DIR/reports/impact_maturation_promotion_report.json" -- \
