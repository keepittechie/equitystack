#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
# shellcheck source=bin/lib/equitystack_workflow.sh
source "$SCRIPT_DIR/lib/equitystack_workflow.sh"
initialize_equitystack_environment "$SCRIPT_PATH"
cd "$EQUITYSTACK_PYTHON_DIR"

cli_hint() {
  printf './bin/equitystack'
}

pipeline_report_path() {
  printf '%s/reports/equitystack_pipeline_report.json\n' "$EQUITYSTACK_PYTHON_DIR"
}

review_bundle_path() {
  printf '%s/reports/equitystack_review_bundle.json\n' "$EQUITYSTACK_PYTHON_DIR"
}

apply_report_path() {
  printf '%s/reports/equitystack_apply_report.json\n' "$EQUITYSTACK_PYTHON_DIR"
}

future_bill_ai_review_path() {
  printf '%s/reports/future_bill_link_ai_review.json\n' "$EQUITYSTACK_PYTHON_DIR"
}

future_bill_manual_queue_path() {
  printf '%s/reports/future_bill_link_manual_review_queue.json\n' "$EQUITYSTACK_PYTHON_DIR"
}

future_bill_suggestion_path() {
  printf '%s/reports/future_bill_link_partial_suggestions.json\n' "$EQUITYSTACK_PYTHON_DIR"
}

future_bill_discovery_path() {
  printf '%s/reports/future_bill_candidate_discovery.json\n' "$EQUITYSTACK_PYTHON_DIR"
}

current_admin_reports_dir() {
  printf '%s/reports/current_admin\n' "$EQUITYSTACK_PYTHON_DIR"
}

current_admin_report_path() {
  local batch_name="$1"
  local suffix="$2"
  printf '%s/%s.%s.json\n' "$(current_admin_reports_dir)" "$batch_name" "$suffix"
}

current_admin_decision_log_dir() {
  printf '%s/review_decisions\n' "$(current_admin_reports_dir)"
}

apply_report_has_affected_bills() {
  local report_path
  report_path="$(apply_report_path)"
  if [ ! -f "$report_path" ]; then
    return 1
  fi

  local affected="no"
  affected="$(APPLY_REPORT_PATH="$report_path" "$VENV_PYTHON" - <<'PY'
import json
import os
from pathlib import Path

path = Path(os.environ["APPLY_REPORT_PATH"])
try:
    payload = json.loads(path.read_text())
except Exception:
    print("no")
    raise SystemExit(0)

affected = payload.get("affected_future_bill_ids") or []
print("yes" if affected else "no")
PY
)"
  [ "$affected" = "yes" ]
}

read_precommit_status() {
  local precommit_path="$1"
  if [ ! -f "$precommit_path" ]; then
    printf 'missing\n'
    return 0
  fi

  PRECOMMIT_PATH="$precommit_path" "$VENV_PYTHON" - <<'PY'
import json
import os
from pathlib import Path

path = Path(os.environ["PRECOMMIT_PATH"])
try:
    payload = json.loads(path.read_text())
except Exception:
    print("error")
    raise SystemExit(0)

status = payload.get("readiness_status")
print(status.strip() if isinstance(status, str) and status.strip() else "unknown")
PY
}

resolve_current_admin_context() {
  local input_path="${1:-}"
  local batch_name="${2:-}"
  local -a context_lines=()

  mapfile -t context_lines < <(
    EQUITYSTACK_PYTHON_DIR="$EQUITYSTACK_PYTHON_DIR" \
    CURRENT_ADMIN_INPUT="$input_path" \
    CURRENT_ADMIN_BATCH_NAME="$batch_name" \
    "$VENV_PYTHON" - <<'PY'
import json
import os
from pathlib import Path

python_dir = Path(os.environ["EQUITYSTACK_PYTHON_DIR"]).resolve()
batches_dir = python_dir / "data" / "current_admin_batches"
reports_dir = python_dir / "reports" / "current_admin"
input_arg = os.environ.get("CURRENT_ADMIN_INPUT", "").strip()
batch_name_arg = os.environ.get("CURRENT_ADMIN_BATCH_NAME", "").strip()


def read_batch_name(path: Path) -> str:
    payload = json.loads(path.read_text())
    batch_name = payload.get("batch_name")
    if not isinstance(batch_name, str) or not batch_name.strip():
        raise SystemExit(f"Batch file missing batch_name: {path}")
    return batch_name.strip()


def latest_batch_file() -> Path | None:
    candidates = [path for path in batches_dir.glob("*.json") if path.is_file()]
    if not candidates:
        return None
    return max(candidates, key=lambda path: path.stat().st_mtime)


def find_batch_file_by_name(target: str) -> Path | None:
    for path in sorted(batches_dir.glob("*.json")):
        if not path.is_file():
            continue
        try:
            if read_batch_name(path) == target:
                return path
        except Exception:
            continue
    return None


if input_arg:
    batch_file = Path(input_arg)
    if not batch_file.is_absolute():
        batch_file = (python_dir / batch_file).resolve()
    else:
        batch_file = batch_file.resolve()
    if not batch_file.exists():
        raise SystemExit(f"Batch file not found: {batch_file}")
    resolved_batch_name = read_batch_name(batch_file)
elif batch_name_arg:
    batch_file = find_batch_file_by_name(batch_name_arg)
    if batch_file is None:
        raise SystemExit(f"Could not find a batch file for batch_name={batch_name_arg}")
    resolved_batch_name = batch_name_arg
else:
    batch_file = latest_batch_file()
    if batch_file is None:
        raise SystemExit("No current-admin batch files were found under data/current_admin_batches/")
    resolved_batch_name = read_batch_name(batch_file)

print(batch_file)
print(resolved_batch_name)
print(reports_dir / f"{resolved_batch_name}.normalized.json")
print(reports_dir / f"{resolved_batch_name}.ai-review.json")
print(reports_dir / f"{resolved_batch_name}.manual-review-queue.json")
print(reports_dir / f"{resolved_batch_name}.pre-commit-review.json")
print(reports_dir / f"{resolved_batch_name}.import-dry-run.json")
print(reports_dir / f"{resolved_batch_name}.import-apply.json")
print(reports_dir / f"{resolved_batch_name}.import-validation.json")
PY
  )

  CURRENT_ADMIN_INPUT_PATH="${context_lines[0]}"
  CURRENT_ADMIN_BATCH_NAME="${context_lines[1]}"
  CURRENT_ADMIN_NORMALIZED_PATH="${context_lines[2]}"
  CURRENT_ADMIN_REVIEW_PATH="${context_lines[3]}"
  CURRENT_ADMIN_QUEUE_PATH="${context_lines[4]}"
  CURRENT_ADMIN_PRECOMMIT_PATH="${context_lines[5]}"
  CURRENT_ADMIN_IMPORT_DRY_RUN_PATH="${context_lines[6]}"
  CURRENT_ADMIN_IMPORT_APPLY_PATH="${context_lines[7]}"
  CURRENT_ADMIN_VALIDATION_PATH="${context_lines[8]}"
}

resolve_review_artifact_context() {
  local review_path="${1:-}"
  local -a context_lines=()

  mapfile -t context_lines < <(
    EQUITYSTACK_PYTHON_DIR="$EQUITYSTACK_PYTHON_DIR" \
    REVIEW_ARTIFACT_INPUT="$review_path" \
    "$VENV_PYTHON" - <<'PY'
import json
import os
from pathlib import Path

python_dir = Path(os.environ["EQUITYSTACK_PYTHON_DIR"]).resolve()
reports_dir = python_dir / "reports" / "current_admin"
input_arg = os.environ.get("REVIEW_ARTIFACT_INPUT", "").strip()

if not input_arg:
    raise SystemExit("A review artifact path is required.")

review_file = Path(input_arg)
if not review_file.is_absolute():
    review_file = (python_dir / review_file).resolve()
else:
    review_file = review_file.resolve()

if not review_file.exists():
    raise SystemExit(f"Review artifact not found: {review_file}")

payload = json.loads(review_file.read_text())
batch_name = payload.get("batch_name")
if not isinstance(batch_name, str) or not batch_name.strip():
    raise SystemExit(f"Review artifact missing batch_name: {review_file}")
batch_name = batch_name.strip()

normalized_input = payload.get("input_path")
if not isinstance(normalized_input, str) or not normalized_input.strip():
    raise SystemExit(f"Review artifact missing input_path: {review_file}")

normalized_path = Path(normalized_input)
if not normalized_path.is_absolute():
    normalized_path = (python_dir / normalized_path).resolve()
else:
    normalized_path = normalized_path.resolve()

print(review_file)
print(batch_name)
print(normalized_path)
print(payload.get("requested_model") or payload.get("model") or "")
print(payload.get("verifier_model") or "")
print(payload.get("fallback_model") or "")
print(payload.get("review_mode") or "standard")
print("true" if payload.get("dry_run") else "false")
print(payload.get("senior_timeout_seconds") or payload.get("timeout_seconds") or "")
print(payload.get("verifier_timeout_seconds") or payload.get("timeout_seconds") or "")
print(reports_dir / f"{batch_name}.manual-review-queue.json")
PY
  )

  REVIEW_ARTIFACT_PATH="${context_lines[0]}"
  REVIEW_ARTIFACT_BATCH_NAME="${context_lines[1]}"
  REVIEW_ARTIFACT_NORMALIZED_PATH="${context_lines[2]}"
  REVIEW_ARTIFACT_MODEL="${context_lines[3]}"
  REVIEW_ARTIFACT_VERIFIER_MODEL="${context_lines[4]}"
  REVIEW_ARTIFACT_FALLBACK_MODEL="${context_lines[5]}"
  REVIEW_ARTIFACT_MODE="${context_lines[6]}"
  REVIEW_ARTIFACT_DRY_RUN="${context_lines[7]}"
  REVIEW_ARTIFACT_TIMEOUT="${context_lines[8]}"
  REVIEW_ARTIFACT_VERIFIER_TIMEOUT="${context_lines[9]}"
  REVIEW_ARTIFACT_QUEUE_PATH="${context_lines[10]}"
}

detect_current_admin_state() {
  local precommit_status="${1:-missing}"

  CURRENT_ADMIN_STATE="DISCOVERY_READY"
  CURRENT_ADMIN_NEXT_STEP="Normalize the curated batch"
  CURRENT_ADMIN_NEXT_COMMAND="$(cli_hint) current-admin normalize --input $(repo_relative_path "$CURRENT_ADMIN_INPUT_PATH")"
  CURRENT_ADMIN_BLOCKING_ISSUES=()
  CURRENT_ADMIN_MISSING_ARTIFACTS=()

  if [ -f "$CURRENT_ADMIN_PRECOMMIT_PATH" ] && [ "$precommit_status" = "blocked" ]; then
    CURRENT_ADMIN_STATE="BLOCKED"
    CURRENT_ADMIN_NEXT_STEP="Resolve the blocking issues in the pre-commit review"
    CURRENT_ADMIN_NEXT_COMMAND="$(cli_hint) current-admin pre-commit --input $(repo_relative_path "$CURRENT_ADMIN_QUEUE_PATH")"
    CURRENT_ADMIN_BLOCKING_ISSUES=("pre-commit review is blocked")
    return 0
  fi

  if [ ! -f "$CURRENT_ADMIN_NORMALIZED_PATH" ]; then
    CURRENT_ADMIN_MISSING_ARTIFACTS=("normalized batch")
    return 0
  fi

  if [ ! -f "$CURRENT_ADMIN_REVIEW_PATH" ]; then
    CURRENT_ADMIN_STATE="NORMALIZED"
    CURRENT_ADMIN_NEXT_STEP="Run the operator review against the normalized batch"
    CURRENT_ADMIN_NEXT_COMMAND="$(cli_hint) current-admin review --input $(repo_relative_path "$CURRENT_ADMIN_NORMALIZED_PATH")"
    CURRENT_ADMIN_MISSING_ARTIFACTS=("AI review report")
    return 0
  fi

  if [ ! -f "$CURRENT_ADMIN_QUEUE_PATH" ]; then
    CURRENT_ADMIN_STATE="REVIEW_READY"
    CURRENT_ADMIN_NEXT_STEP="Build the manual review queue"
    CURRENT_ADMIN_NEXT_COMMAND="$(cli_hint) current-admin queue --batch $(repo_relative_path "$CURRENT_ADMIN_NORMALIZED_PATH") --review $(repo_relative_path "$CURRENT_ADMIN_REVIEW_PATH")"
    CURRENT_ADMIN_MISSING_ARTIFACTS=("manual review queue")
    return 0
  fi

  if [ ! -f "$CURRENT_ADMIN_PRECOMMIT_PATH" ]; then
    CURRENT_ADMIN_STATE="QUEUE_READY"
    CURRENT_ADMIN_NEXT_STEP="Generate the pre-commit readiness report"
    CURRENT_ADMIN_NEXT_COMMAND="$(cli_hint) current-admin pre-commit --input $(repo_relative_path "$CURRENT_ADMIN_QUEUE_PATH")"
    CURRENT_ADMIN_MISSING_ARTIFACTS=("pre-commit review")
    return 0
  fi

  if [ ! -f "$CURRENT_ADMIN_IMPORT_APPLY_PATH" ]; then
    CURRENT_ADMIN_STATE="PRECOMMIT_READY"
    CURRENT_ADMIN_NEXT_STEP="Run the import workflow. Start with the dry-run report if you want a non-mutating preview."
    CURRENT_ADMIN_NEXT_COMMAND="$(cli_hint) current-admin import --input $(repo_relative_path "$CURRENT_ADMIN_QUEUE_PATH")"
    if [ ! -f "$CURRENT_ADMIN_IMPORT_DRY_RUN_PATH" ]; then
      CURRENT_ADMIN_MISSING_ARTIFACTS=("import apply report")
    fi
    return 0
  fi

  if [ ! -f "$CURRENT_ADMIN_VALIDATION_PATH" ]; then
    CURRENT_ADMIN_STATE="IMPORT_READY"
    CURRENT_ADMIN_NEXT_STEP="Validate the applied import"
    CURRENT_ADMIN_NEXT_COMMAND="$(cli_hint) current-admin validate --input $(repo_relative_path "$CURRENT_ADMIN_QUEUE_PATH")"
    CURRENT_ADMIN_MISSING_ARTIFACTS=("validation report")
    return 0
  fi

  CURRENT_ADMIN_STATE="COMPLETE"
  CURRENT_ADMIN_NEXT_STEP="Workflow complete. Start the next discovery or review cycle."
  CURRENT_ADMIN_NEXT_COMMAND="$(cli_hint) current-admin discover"
}

print_current_admin_status() {
  local input_path="${1:-}"
  local batch_name="${2:-}"

  resolve_current_admin_context "$input_path" "$batch_name"

  local precommit_status="missing"
  precommit_status="$(read_precommit_status "$CURRENT_ADMIN_PRECOMMIT_PATH")"
  detect_current_admin_state "$precommit_status"

  printf 'BATCH: %s\n' "$CURRENT_ADMIN_BATCH_NAME"
  printf 'BATCH FILE: %s\n' "$(repo_relative_path "$CURRENT_ADMIN_INPUT_PATH")"
  printf 'ARTIFACTS:\n'
  printf '  %-18s %s\n' "Normalized:" "$(artifact_status_text "$CURRENT_ADMIN_NORMALIZED_PATH")"
  printf '  %-18s %s\n' "AI review:" "$(artifact_status_text "$CURRENT_ADMIN_REVIEW_PATH")"
  printf '  %-18s %s\n' "Manual queue:" "$(artifact_status_text "$CURRENT_ADMIN_QUEUE_PATH")"
  printf '  %-18s %s\n' "Pre-commit:" "$(artifact_status_text "$CURRENT_ADMIN_PRECOMMIT_PATH")"
  printf '  %-18s %s\n' "Pre-commit state:" "$precommit_status"
  printf '  %-18s %s\n' "Import dry-run:" "$(artifact_status_text "$CURRENT_ADMIN_IMPORT_DRY_RUN_PATH")"
  printf '  %-18s %s\n' "Import apply:" "$(artifact_status_text "$CURRENT_ADMIN_IMPORT_APPLY_PATH")"
  printf '  %-18s %s\n' "Validation:" "$(artifact_status_text "$CURRENT_ADMIN_VALIDATION_PATH")"

  local -a detail_lines=()
  if [ "${#CURRENT_ADMIN_MISSING_ARTIFACTS[@]}" -gt 0 ]; then
    detail_lines+=("MISSING ARTIFACTS:")
    local missing_artifact=""
    for missing_artifact in "${CURRENT_ADMIN_MISSING_ARTIFACTS[@]}"; do
      detail_lines+=("  - $missing_artifact")
    done
  fi
  if [ "${#CURRENT_ADMIN_BLOCKING_ISSUES[@]}" -gt 0 ]; then
    detail_lines+=("BLOCKING ISSUES:")
    local blocking_issue=""
    for blocking_issue in "${CURRENT_ADMIN_BLOCKING_ISSUES[@]}"; do
      detail_lines+=("  - $blocking_issue")
    done
  fi

  print_system_state "$CURRENT_ADMIN_STATE" "$CURRENT_ADMIN_NEXT_STEP" "$CURRENT_ADMIN_NEXT_COMMAND" "${detail_lines[@]}"
}

run_current_admin_workflow_review() {
  local summary_requested="false"
  local preview_requested="false"
  local -a passthrough=()

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --summary)
        summary_requested="true"
        passthrough+=("$1")
        shift
        ;;
      --preview)
        preview_requested="true"
        passthrough+=("$1")
        shift
        ;;
      -h|--help)
        current_admin_workflow_subcommand_usage review
        exit 0
        ;;
      *)
        passthrough+=("$1")
        shift
        ;;
    esac
  done

  if [ "$summary_requested" = "false" ] && [ "$preview_requested" = "false" ]; then
    passthrough+=(--summary)
  fi

  run_step "1/1" "Generate Decision Template" "Decision template generation complete" -- \
    "$VENV_PYTHON" scripts/generate_current_admin_decision_template.py "${passthrough[@]}"
}

run_current_admin_workflow_finalize() {
  local review_path=""
  local decision_file=""
  local log_decisions_set="false"
  local log_decisions_value=""
  local feedback_summary="false"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --review)
        review_path="${2:-}"
        [ -n "$review_path" ] || { echo "--review requires a value" >&2; exit 1; }
        shift 2
        ;;
      --decision-file)
        decision_file="${2:-}"
        [ -n "$decision_file" ] || { echo "--decision-file requires a value" >&2; exit 1; }
        shift 2
        ;;
      --log-decisions)
        log_decisions_set="true"
        if [ "${2:-}" != "" ] && [[ "${2:-}" != --* ]]; then
          log_decisions_value="${2}"
          shift 2
        else
          log_decisions_value=""
          shift
        fi
        ;;
      --feedback-summary)
        feedback_summary="true"
        shift
        ;;
      -h|--help)
        current_admin_workflow_subcommand_usage finalize
        exit 0
        ;;
      *)
        echo "Unknown argument for current-admin workflow finalize: $1" >&2
        exit 1
        ;;
    esac
  done

  [ -n "$review_path" ] || { echo "--review is required" >&2; exit 1; }
  [ -n "$decision_file" ] || { echo "--decision-file is required" >&2; exit 1; }
  [ "$log_decisions_set" = "true" ] || { echo "--log-decisions is required so decision logging stays explicit" >&2; exit 1; }

  resolve_review_artifact_context "$review_path"

  local review_model="$REVIEW_ARTIFACT_MODEL"
  if [ -z "$review_model" ]; then
    review_model="$DEFAULT_MODEL_REVIEW"
  fi
  local verifier_model="$REVIEW_ARTIFACT_VERIFIER_MODEL"
  if [ -z "$verifier_model" ]; then
    verifier_model="$DEFAULT_MODEL_VERIFIER"
  fi
  local fallback_model="$REVIEW_ARTIFACT_FALLBACK_MODEL"
  if [ -z "$fallback_model" ]; then
    fallback_model="$DEFAULT_MODEL_FALLBACK"
  fi
  local senior_timeout="$REVIEW_ARTIFACT_TIMEOUT"
  if [ -z "$senior_timeout" ]; then
    senior_timeout="$DEFAULT_OLLAMA_TIMEOUT_SENIOR"
  fi
  local verifier_timeout="$REVIEW_ARTIFACT_VERIFIER_TIMEOUT"
  if [ -z "$verifier_timeout" ]; then
    verifier_timeout="$DEFAULT_OLLAMA_TIMEOUT_VERIFIER"
  fi

  local -a finalize_args=(
    "$VENV_PYTHON"
    scripts/review_current_admin_batch_with_ollama.py
    --input "$REVIEW_ARTIFACT_NORMALIZED_PATH"
    --decision-file "$decision_file"
    --summary
    --model "$review_model"
    --verifier-model "$verifier_model"
    --fallback-model "$fallback_model"
    --review-mode "$REVIEW_ARTIFACT_MODE"
    --ollama-url "$DEFAULT_OLLAMA_URL"
    --senior-timeout "$senior_timeout"
    --verifier-timeout "$verifier_timeout"
  )
  if [ "$REVIEW_ARTIFACT_DRY_RUN" = "true" ]; then
    finalize_args+=(--dry-run)
  fi
  if [ -n "$log_decisions_value" ]; then
    finalize_args+=(--log-decisions "$log_decisions_value")
  else
    finalize_args+=(--log-decisions)
  fi

  run_step "1/2" "Replay Review Decisions" "Decision log written against the canonical review artifact" -- \
    "${finalize_args[@]}"

  if [ "$feedback_summary" = "true" ]; then
    run_step "2/2" "Export Feedback Summary" "Feedback summary exported" -- \
      node scripts/export_current_admin_feedback_summary.mjs
  fi

  print_system_state \
    "PRECOMMIT_READY" \
    "Generate the pre-commit artifact from the manual review queue" \
    "$(cli_hint) current-admin pre-commit --input $(repo_relative_path "$REVIEW_ARTIFACT_QUEUE_PATH")" \
    "REVIEW ARTIFACT: $(repo_relative_path "$REVIEW_ARTIFACT_PATH")" \
    "DECISION FILE: $decision_file" \
    "MANUAL QUEUE: $(repo_relative_path "$REVIEW_ARTIFACT_QUEUE_PATH")"
}

print_current_admin_workflow_resume() {
  EQUITYSTACK_PYTHON_DIR="$EQUITYSTACK_PYTHON_DIR" "$VENV_PYTHON" - <<'PY'
import json
import os
from pathlib import Path

python_dir = Path(os.environ["EQUITYSTACK_PYTHON_DIR"]).resolve()
reports_dir = python_dir / "reports" / "current_admin"
decision_dir = reports_dir / "review_decisions"


def newest(paths):
    paths = [path for path in paths if path.is_file()]
    if not paths:
        return None
    return max(paths, key=lambda path: path.stat().st_mtime)


latest_decision = newest(decision_dir.glob("*.json"))
latest_review = newest(reports_dir.glob("*.ai-review.json"))

if latest_decision is not None:
    payload = json.loads(latest_decision.read_text())
    review_path = payload.get("source_review_file") or ""
    session_id = payload.get("session_id") or latest_decision.stem
    session_focus = payload.get("session_focus") or "unspecified"
    generated_at = payload.get("generated_at") or "unknown"
    item_count = len(payload.get("items") or [])
    batch_name = Path(review_path).name.replace(".ai-review.json", "") if review_path else "unknown"

    print(f"LATEST SESSION: {session_id}")
    print(f"SESSION FOCUS: {session_focus}")
    print(f"GENERATED: {generated_at}")
    print(f"ITEMS LOGGED: {item_count}")
    print(f"SOURCE REVIEW: {review_path or 'unknown'}")
    print()
    print("SYSTEM STATE: PRECOMMIT_READY")
    print("NEXT STEP: Generate the pre-commit readiness artifact")
    if batch_name != "unknown":
        queue_path = f"reports/current_admin/{batch_name}.manual-review-queue.json"
        print(f"RECOMMENDED COMMAND: ./bin/equitystack current-admin pre-commit --input {queue_path}")
        print(f"FOLLOW UP: ./bin/equitystack current-admin status --batch-name {batch_name}")
    else:
        print("RECOMMENDED COMMAND: ./bin/equitystack current-admin status")
elif latest_review is not None:
    payload = json.loads(latest_review.read_text())
    batch_name = payload.get("batch_name") or latest_review.name.replace(".ai-review.json", "")
    output_name = latest_review.name.replace(".ai-review.json", ".decision-template.json")

    print(f"LATEST REVIEW ARTIFACT: {latest_review}")
    print(f"BATCH NAME: {batch_name}")
    print()
    print("SYSTEM STATE: REVIEW_READY")
    print("NEXT STEP: Generate a decision template for operator review")
    print(
        "RECOMMENDED COMMAND: "
        "./bin/equitystack current-admin workflow review "
        f"--input reports/current_admin/{latest_review.name} "
        f"--output /tmp/{output_name}"
    )
else:
    print("SYSTEM STATE: DISCOVERY_READY")
    print("NEXT STEP: Start with batch status or discovery")
    print("RECOMMENDED COMMAND: ./bin/equitystack current-admin status")
PY
}

run_current_admin_workflow_start() {
  local input_path=""
  local batch_name=""
  local review_dry_run="false"
  local prefill_suggestions="false"
  local review_model=""
  local verifier_model=""
  local fallback_model=""
  local review_mode=""
  local deep_review="false"
  local ollama_url="$DEFAULT_OLLAMA_URL"
  local timeout=""
  local senior_timeout="$DEFAULT_OLLAMA_TIMEOUT_SENIOR"
  local verifier_timeout="$DEFAULT_OLLAMA_TIMEOUT_VERIFIER"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --input)
        input_path="${2:-}"
        [ -n "$input_path" ] || { echo "--input requires a value" >&2; exit 1; }
        shift 2
        ;;
      --batch-name)
        batch_name="${2:-}"
        [ -n "$batch_name" ] || { echo "--batch-name requires a value" >&2; exit 1; }
        shift 2
        ;;
      --review-dry-run)
        review_dry_run="true"
        shift
        ;;
      --prefill-suggestions)
        prefill_suggestions="true"
        shift
        ;;
      --model)
        review_model="${2:-}"
        [ -n "$review_model" ] || { echo "--model requires a value" >&2; exit 1; }
        shift 2
        ;;
      --verifier-model)
        verifier_model="${2:-}"
        [ -n "$verifier_model" ] || { echo "--verifier-model requires a value" >&2; exit 1; }
        shift 2
        ;;
      --fallback-model)
        fallback_model="${2:-}"
        [ -n "$fallback_model" ] || { echo "--fallback-model requires a value" >&2; exit 1; }
        shift 2
        ;;
      --review-mode)
        review_mode="${2:-}"
        [ -n "$review_mode" ] || { echo "--review-mode requires a value" >&2; exit 1; }
        if [ "$review_mode" != "standard" ] && [ "$review_mode" != "deep" ]; then
          echo "--review-mode must be standard or deep" >&2
          exit 1
        fi
        shift 2
        ;;
      --deep-review)
        deep_review="true"
        shift
        ;;
      --ollama-url)
        ollama_url="${2:-}"
        [ -n "$ollama_url" ] || { echo "--ollama-url requires a value" >&2; exit 1; }
        shift 2
        ;;
      --timeout)
        timeout="${2:-}"
        [ -n "$timeout" ] || { echo "--timeout requires a value" >&2; exit 1; }
        shift 2
        ;;
      --senior-timeout)
        senior_timeout="${2:-}"
        [ -n "$senior_timeout" ] || { echo "--senior-timeout requires a value" >&2; exit 1; }
        shift 2
        ;;
      --verifier-timeout)
        verifier_timeout="${2:-}"
        [ -n "$verifier_timeout" ] || { echo "--verifier-timeout requires a value" >&2; exit 1; }
        shift 2
        ;;
      -h|--help)
        current_admin_workflow_subcommand_usage start
        exit 0
        ;;
      *)
        echo "Unknown argument for current-admin workflow start: $1" >&2
        exit 1
        ;;
    esac
  done

  if [ -z "$review_model" ]; then
    review_model="$DEFAULT_MODEL_REVIEW"
  fi
  if [ -z "$verifier_model" ]; then
    verifier_model="$DEFAULT_MODEL_VERIFIER"
  fi
  if [ -z "$fallback_model" ]; then
    fallback_model="$DEFAULT_MODEL_FALLBACK"
  fi
  if [ -z "$review_mode" ]; then
    review_mode="deep"
  fi
  if [ -n "$timeout" ]; then
    senior_timeout="$timeout"
    verifier_timeout="$timeout"
  fi

  resolve_current_admin_context "$input_path" "$batch_name"

  run_step "1/3" "Normalize Batch" "Normalized current-admin batch created" --output "$CURRENT_ADMIN_NORMALIZED_PATH" -- \
    "$VENV_PYTHON" scripts/normalize_current_admin_batch.py --input "$CURRENT_ADMIN_INPUT_PATH"

  local -a review_args=(
    "$VENV_PYTHON"
    scripts/review_current_admin_batch_with_ollama.py
    --input "$CURRENT_ADMIN_NORMALIZED_PATH"
    --model "$review_model"
    --verifier-model "$verifier_model"
    --fallback-model "$fallback_model"
    --ollama-url "$ollama_url"
    --senior-timeout "$senior_timeout"
    --verifier-timeout "$verifier_timeout"
    --review-mode "$review_mode"
  )
  if [ "$review_dry_run" = "true" ]; then
    review_args+=(--dry-run)
  fi
  if [ "$deep_review" = "true" ]; then
    review_args+=(--deep-review)
  fi

  run_step "2/3" "AI Review" "AI review report created" --output "$CURRENT_ADMIN_REVIEW_PATH" -- \
    "${review_args[@]}"

  local -a queue_args=(
    "$VENV_PYTHON"
    scripts/apply_current_admin_ai_review.py
    --batch "$CURRENT_ADMIN_NORMALIZED_PATH"
    --review "$CURRENT_ADMIN_REVIEW_PATH"
  )
  if [ "$prefill_suggestions" = "true" ]; then
    queue_args+=(--prefill-suggestions)
  fi

  run_step "3/3" "Build Manual Queue" "Manual review queue created" --output "$CURRENT_ADMIN_QUEUE_PATH" -- \
    "${queue_args[@]}"

  print_system_state \
    "REVIEW_READY" \
    "Generate a decision template or inspect batch status" \
    "$(cli_hint) current-admin workflow review --input $(repo_relative_path "$CURRENT_ADMIN_REVIEW_PATH") --output /tmp/${CURRENT_ADMIN_BATCH_NAME}.decision-template.json" \
    "BATCH: $CURRENT_ADMIN_BATCH_NAME" \
    "SENIOR MODEL: $review_model" \
    "VERIFIER MODEL: $verifier_model" \
    "FALLBACK MODEL: $fallback_model" \
    "SENIOR TIMEOUT: ${senior_timeout}s" \
    "VERIFIER TIMEOUT: ${verifier_timeout}s" \
    "OLLAMA URL: $ollama_url"
}

run_current_admin_review_command() {
  local -a passthrough=()
  local has_model="false"
  local has_verifier_model="false"
  local has_fallback_model="false"
  local has_ollama_url="false"
  local has_timeout="false"
  local has_senior_timeout="false"
  local has_verifier_timeout="false"
  local has_review_mode="false"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      -h|--help)
        current_admin_subcommand_usage review
        exit 0
        ;;
      --model|--model=*)
        has_model="true"
        passthrough+=("$1")
        if [ "$1" = "--model" ]; then
          [ -n "${2:-}" ] || { echo "--model requires a value" >&2; exit 1; }
          passthrough+=("$2")
          shift 2
        else
          shift
        fi
        ;;
      --verifier-model|--verifier-model=*)
        has_verifier_model="true"
        passthrough+=("$1")
        if [ "$1" = "--verifier-model" ]; then
          [ -n "${2:-}" ] || { echo "--verifier-model requires a value" >&2; exit 1; }
          passthrough+=("$2")
          shift 2
        else
          shift
        fi
        ;;
      --fallback-model|--fallback-model=*)
        has_fallback_model="true"
        passthrough+=("$1")
        if [ "$1" = "--fallback-model" ]; then
          [ -n "${2:-}" ] || { echo "--fallback-model requires a value" >&2; exit 1; }
          passthrough+=("$2")
          shift 2
        else
          shift
        fi
        ;;
      --ollama-url|--ollama-url=*)
        has_ollama_url="true"
        passthrough+=("$1")
        if [ "$1" = "--ollama-url" ]; then
          [ -n "${2:-}" ] || { echo "--ollama-url requires a value" >&2; exit 1; }
          passthrough+=("$2")
          shift 2
        else
          shift
        fi
        ;;
      --timeout|--timeout=*)
        has_timeout="true"
        passthrough+=("$1")
        if [ "$1" = "--timeout" ]; then
          [ -n "${2:-}" ] || { echo "--timeout requires a value" >&2; exit 1; }
          passthrough+=("$2")
          shift 2
        else
          shift
        fi
        ;;
      --senior-timeout|--senior-timeout=*)
        has_senior_timeout="true"
        passthrough+=("$1")
        if [ "$1" = "--senior-timeout" ]; then
          [ -n "${2:-}" ] || { echo "--senior-timeout requires a value" >&2; exit 1; }
          passthrough+=("$2")
          shift 2
        else
          shift
        fi
        ;;
      --verifier-timeout|--verifier-timeout=*)
        has_verifier_timeout="true"
        passthrough+=("$1")
        if [ "$1" = "--verifier-timeout" ]; then
          [ -n "${2:-}" ] || { echo "--verifier-timeout requires a value" >&2; exit 1; }
          passthrough+=("$2")
          shift 2
        else
          shift
        fi
        ;;
      --review-mode|--review-mode=*|--deep-review)
        has_review_mode="true"
        passthrough+=("$1")
        if [ "$1" = "--review-mode" ]; then
          [ -n "${2:-}" ] || { echo "--review-mode requires a value" >&2; exit 1; }
          passthrough+=("$2")
          shift 2
        else
          shift
        fi
        ;;
      *)
        passthrough+=("$1")
        shift
        ;;
    esac
  done

  if [ "$has_model" = "false" ]; then
    passthrough+=(--model "$DEFAULT_MODEL_REVIEW")
  fi
  if [ "$has_verifier_model" = "false" ]; then
    passthrough+=(--verifier-model "$DEFAULT_MODEL_VERIFIER")
  fi
  if [ "$has_fallback_model" = "false" ]; then
    passthrough+=(--fallback-model "$DEFAULT_MODEL_FALLBACK")
  fi
  if [ "$has_ollama_url" = "false" ]; then
    passthrough+=(--ollama-url "$DEFAULT_OLLAMA_URL")
  fi
  if [ "$has_timeout" = "true" ]; then
    :
  else
    if [ "$has_senior_timeout" = "false" ]; then
      passthrough+=(--senior-timeout "$DEFAULT_OLLAMA_TIMEOUT_SENIOR")
    fi
    if [ "$has_verifier_timeout" = "false" ]; then
      passthrough+=(--verifier-timeout "$DEFAULT_OLLAMA_TIMEOUT_VERIFIER")
    fi
  fi
  if [ "$has_review_mode" = "false" ]; then
    passthrough+=(--review-mode deep)
  fi

  run_step "1/1" "AI Review" "AI review command complete" -- \
    "$VENV_PYTHON" scripts/review_current_admin_batch_with_ollama.py "${passthrough[@]}"
}

run_current_admin_discover_command() {
  local -a passthrough=()
  local has_model="false"
  local has_ollama_url="false"
  local has_timeout="false"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      -h|--help)
        current_admin_subcommand_usage discover
        exit 0
        ;;
      --model|--model=*)
        has_model="true"
        passthrough+=("$1")
        if [ "$1" = "--model" ]; then
          [ -n "${2:-}" ] || { echo "--model requires a value" >&2; exit 1; }
          passthrough+=("$2")
          shift 2
        else
          shift
        fi
        ;;
      --ollama-url|--ollama-url=*)
        has_ollama_url="true"
        passthrough+=("$1")
        if [ "$1" = "--ollama-url" ]; then
          [ -n "${2:-}" ] || { echo "--ollama-url requires a value" >&2; exit 1; }
          passthrough+=("$2")
          shift 2
        else
          shift
        fi
        ;;
      --timeout|--timeout=*)
        has_timeout="true"
        passthrough+=("$1")
        if [ "$1" = "--timeout" ]; then
          [ -n "${2:-}" ] || { echo "--timeout requires a value" >&2; exit 1; }
          passthrough+=("$2")
          shift 2
        else
          shift
        fi
        ;;
      *)
        passthrough+=("$1")
        shift
        ;;
    esac
  done

  if [ "$has_model" = "false" ]; then
    passthrough+=(--model "$DEFAULT_MODEL_CHEAP")
  fi
  if [ "$has_ollama_url" = "false" ]; then
    passthrough+=(--ollama-url "$DEFAULT_OLLAMA_URL")
  fi
  if [ "$has_timeout" = "false" ]; then
    passthrough+=(--timeout "$DEFAULT_OLLAMA_TIMEOUT_VERIFIER")
  fi

  run_step "1/1" "Discover Current-Admin Updates" "Discovery run complete" -- \
    "$VENV_PYTHON" scripts/discover_current_admin_updates.py "${passthrough[@]}"
}

run_current_admin_workflow_command() {
  local command="${1:-}"
  shift || true

  case "$command" in
    start)
      run_current_admin_workflow_start "$@"
      ;;
    review|generate-decision-template)
      run_current_admin_workflow_review "$@"
      ;;
    finalize)
      run_current_admin_workflow_finalize "$@"
      ;;
    resume)
      if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        current_admin_workflow_subcommand_usage resume
        exit 0
      fi
      print_current_admin_workflow_resume
      ;;
    help|-h|--help|"")
      current_admin_workflow_usage
      ;;
    *)
      echo "Unknown current-admin workflow command: $command" >&2
      current_admin_workflow_usage
      exit 1
      ;;
  esac
}

run_legislative_command() {
  local command="${1:-}"
  shift || true

  case "$command" in
    run)
      local review_model="$DEFAULT_MODEL_REVIEW"
      local verifier_model="$DEFAULT_MODEL_VERIFIER"
      local fallback_model="$DEFAULT_MODEL_FALLBACK"
      local timeout=""
      local senior_timeout="$DEFAULT_OLLAMA_TIMEOUT_SENIOR"
      local verifier_timeout="$DEFAULT_OLLAMA_TIMEOUT_VERIFIER"
      local -a passthrough=()

      while [ "$#" -gt 0 ]; do
        case "$1" in
          --model)
            review_model="${2:-}"
            [ -n "$review_model" ] || { echo "--model requires a value" >&2; exit 1; }
            shift 2
            ;;
          --verifier-model)
            verifier_model="${2:-}"
            [ -n "$verifier_model" ] || { echo "--verifier-model requires a value" >&2; exit 1; }
            shift 2
            ;;
          --fallback-model)
            fallback_model="${2:-}"
            [ -n "$fallback_model" ] || { echo "--fallback-model requires a value" >&2; exit 1; }
            shift 2
            ;;
          --timeout)
            timeout="${2:-}"
            [ -n "$timeout" ] || { echo "--timeout requires a value" >&2; exit 1; }
            shift 2
            ;;
          --senior-timeout)
            senior_timeout="${2:-}"
            [ -n "$senior_timeout" ] || { echo "--senior-timeout requires a value" >&2; exit 1; }
            shift 2
            ;;
          --verifier-timeout)
            verifier_timeout="${2:-}"
            [ -n "$verifier_timeout" ] || { echo "--verifier-timeout requires a value" >&2; exit 1; }
            shift 2
            ;;
          --skip-discovery|--apply-safe-removals|--csv)
            passthrough+=("$1")
            shift
            ;;
          --output-report|--only-future-bill-id)
            passthrough+=("$1" "${2:-}")
            [ -n "${2:-}" ] || { echo "$1 requires a value" >&2; exit 1; }
            shift 2
            ;;
          -h|--help)
            legislative_usage
            exit 0
            ;;
          *)
            echo "Unknown argument for legislative run: $1" >&2
            exit 1
            ;;
        esac
      done

      if [ -n "$timeout" ]; then
        senior_timeout="$timeout"
        verifier_timeout="$timeout"
      fi

      if ! command_has_flag "--csv" "${passthrough[@]}"; then
        passthrough+=(--csv)
      fi
      if ! command_has_flag "--output-report" "${passthrough[@]}"; then
        passthrough+=(--output-report "$(pipeline_report_path)")
      fi

      run_step "1/3" "Daily Review Pipeline" "Legislative pipeline reports refreshed" \
        --output "$(pipeline_report_path)" \
        --output "$(future_bill_ai_review_path)" \
        --output "$(future_bill_manual_queue_path)" \
        --output "$(future_bill_suggestion_path)" \
        -- \
        "$VENV_PYTHON" run_equitystack_pipeline.py \
          --review-model "$review_model" \
          --verifier-model "$verifier_model" \
          --fallback-model "$fallback_model" \
          --senior-timeout "$senior_timeout" \
          --verifier-timeout "$verifier_timeout" \
          "${passthrough[@]}"

      run_step "2/3" "Auto-Triage Review Bundle" "Safe review bundle actions auto-triaged" -- \
        "$VENV_PYTHON" scripts/auto_triage_review_bundle.py --apply --yes --auto-approve-safe-actions

      run_step "3/3" "Rebuild Review Bundle" "Review bundle rebuilt" --output "$(review_bundle_path)" -- \
        "$VENV_PYTHON" scripts/build_review_bundle.py --csv --use-feedback

      print_system_state \
        "REVIEW_READY" \
        "Review the updated bundle and approve or reject actions" \
        "$(cli_hint) legislative review" \
        "SENIOR MODEL: $review_model" \
        "VERIFIER MODEL: $verifier_model" \
        "FALLBACK MODEL: $fallback_model" \
        "SENIOR TIMEOUT: ${senior_timeout}s" \
        "VERIFIER TIMEOUT: ${verifier_timeout}s" \
        "PIPELINE REPORT: $(repo_relative_path "$(pipeline_report_path)")"
      ;;
    review)
      [ "$#" -eq 0 ] || { echo "equitystack legislative review does not accept extra arguments" >&2; exit 1; }
      run_step "1/1" "Review Bundle Actions" "Legislative review session complete" -- \
        "$VENV_PYTHON" scripts/review_bundle_actions.py
      ;;
    apply)
      local dry_run="false"
      local explicit_apply="false"
      local confirmed="false"
      while [ "$#" -gt 0 ]; do
        case "$1" in
          --dry-run)
            dry_run="true"
            shift
            ;;
          --apply)
            explicit_apply="true"
            shift
            ;;
          --yes)
            confirmed="true"
            shift
            ;;
          -h|--help)
            legislative_usage
            exit 0
            ;;
          *)
            echo "Unknown argument for legislative apply: $1" >&2
            exit 1
            ;;
        esac
      done

      if [ "$dry_run" = "true" ] && [ "$explicit_apply" = "true" ]; then
        echo "Use either --dry-run or --apply --yes for legislative apply" >&2
        exit 1
      fi

      if [ "$dry_run" = "true" ]; then
        run_step "1/1" "Dry-Run Apply Review Bundle" "Legislative apply preview complete" --output "$(apply_report_path)" -- \
          "$VENV_PYTHON" scripts/apply_review_bundle.py --csv

        print_system_state \
          "APPLY_READY" \
          "Inspect the dry-run report, then apply approved legislative actions when ready" \
          "$(cli_hint) legislative apply --apply --yes"
      else
        if [ "$explicit_apply" = "true" ] && [ "$confirmed" != "true" ]; then
          echo "equitystack legislative apply --apply requires --yes" >&2
          exit 1
        fi

        run_step "1/3" "Apply Review Bundle" "Approved legislative actions applied" --output "$(apply_report_path)" -- \
          "$VENV_PYTHON" scripts/apply_review_bundle.py --apply --yes --csv

        if apply_report_has_affected_bills; then
          run_step "2/3" "Rerun Affected Future Bills" "Affected future bills rerun" -- \
            "$VENV_PYTHON" scripts/rerun_affected_future_bills.py --from-apply-report "$(apply_report_path)" --csv
        else
          print_step_header "2/3" "Rerun Affected Future Bills"
          printf 'SUCCESS: No affected future bills were recorded. Skipping rerun.\n'
        fi

        run_step "3/3" "Rebuild Review Bundle" "Review bundle rebuilt" --output "$(review_bundle_path)" -- \
          "$VENV_PYTHON" scripts/build_review_bundle.py --csv --use-feedback

        print_system_state \
          "REVIEW_READY" \
          "Inspect the refreshed review bundle" \
          "$(cli_hint) legislative review"
      fi
      ;;
    import)
      local dry_run="false"
      local explicit_apply="false"
      local confirmed="false"
      while [ "$#" -gt 0 ]; do
        case "$1" in
          --dry-run)
            dry_run="true"
            shift
            ;;
          --apply)
            explicit_apply="true"
            shift
            ;;
          --yes)
            confirmed="true"
            shift
            ;;
          -h|--help)
            legislative_usage
            exit 0
            ;;
          *)
            echo "Unknown argument for legislative import: $1" >&2
            exit 1
            ;;
        esac
      done

      if [ "$dry_run" = "true" ] && [ "$explicit_apply" = "true" ]; then
        echo "Use either --dry-run or --apply --yes for legislative import" >&2
        exit 1
      fi

      if [ "$dry_run" = "true" ]; then
        run_step "1/1" "Dry-Run Import Approved Tracked Bills" "Legislative import preview complete" -- \
          "$VENV_PYTHON" scripts/import_approved_tracked_bills.py --link-imported-bills --enrich-metadata --csv

        print_system_state \
          "IMPORT_READY" \
          "Inspect the dry-run import report, then apply the approved tracked-bill import when ready" \
          "$(cli_hint) legislative import --apply --yes"
      else
        if [ "$explicit_apply" = "true" ] && [ "$confirmed" != "true" ]; then
          echo "equitystack legislative import --apply requires --yes" >&2
          exit 1
        fi

        run_step "1/2" "Import Approved Tracked Bills" "Approved tracked bills imported" -- \
          "$VENV_PYTHON" scripts/import_approved_tracked_bills.py --apply --yes --link-imported-bills --enrich-metadata --csv

        run_step "2/2" "Rebuild Review Bundle" "Review bundle rebuilt" --output "$(review_bundle_path)" -- \
          "$VENV_PYTHON" scripts/build_review_bundle.py --csv --use-feedback

        print_system_state \
          "REVIEW_READY" \
          "Review the new bundle after import" \
          "$(cli_hint) legislative review"
      fi
      ;;
    feedback)
      [ "$#" -eq 0 ] || { echo "equitystack legislative feedback does not accept extra arguments" >&2; exit 1; }
      run_step "1/2" "Analyze Feedback" "Feedback analysis refreshed" -- \
        "$VENV_PYTHON" scripts/analyze_feedback.py

      run_step "2/2" "Rebuild Review Bundle" "Review bundle rebuilt" --output "$(review_bundle_path)" -- \
        "$VENV_PYTHON" scripts/build_review_bundle.py --csv --use-feedback

      print_system_state \
        "REVIEW_READY" \
        "Review the updated feedback-informed bundle" \
        "$(cli_hint) legislative review"
      ;;
    help|-h|--help|"")
      legislative_usage
      ;;
    *)
      echo "Unknown legislative command: $command" >&2
      legislative_usage
      exit 1
      ;;
  esac
}

run_current_admin_command() {
  local command="${1:-}"
  shift || true

  case "$command" in
    discover)
      run_current_admin_discover_command "$@"
      ;;
    export)
      if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        current_admin_subcommand_usage export
        exit 0
      fi
      run_step "1/1" "Export Discovery Candidates" "Discovery export complete" -- \
        "$VENV_PYTHON" scripts/export_current_admin_discovery_candidates.py "$@"
      ;;
    normalize)
      if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        current_admin_subcommand_usage normalize
        exit 0
      fi
      run_step "1/1" "Normalize Batch" "Normalization complete" -- \
        "$VENV_PYTHON" scripts/normalize_current_admin_batch.py "$@"
      ;;
    review)
      run_current_admin_review_command "$@"
      ;;
    queue)
      if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        current_admin_subcommand_usage queue
        exit 0
      fi
      run_step "1/1" "Build Manual Queue" "Manual review queue build complete" -- \
        "$VENV_PYTHON" scripts/apply_current_admin_ai_review.py "$@"
      ;;
    pre-commit)
      if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        current_admin_subcommand_usage pre-commit
        exit 0
      fi
      run_step "1/1" "Build Pre-Commit Review" "Pre-commit review build complete" -- \
        "$VENV_PYTHON" scripts/build_current_admin_precommit_review.py "$@"
      ;;
    run)
      run_current_admin_workflow_start "$@"
      ;;
    status)
      local input_path=""
      local batch_name=""
      while [ "$#" -gt 0 ]; do
        case "$1" in
          --input)
            input_path="${2:-}"
            [ -n "$input_path" ] || { echo "--input requires a value" >&2; exit 1; }
            shift 2
            ;;
          --batch-name)
            batch_name="${2:-}"
            [ -n "$batch_name" ] || { echo "--batch-name requires a value" >&2; exit 1; }
            shift 2
            ;;
          -h|--help)
            current_admin_subcommand_usage status
            exit 0
            ;;
          *)
            echo "Unknown argument for current-admin status: $1" >&2
            current_admin_subcommand_usage status
            exit 1
            ;;
        esac
      done
      print_current_admin_status "$input_path" "$batch_name"
      ;;
    workflow)
      run_current_admin_workflow_command "${1:-help}" "${@:2}"
      ;;
    import)
      if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        current_admin_subcommand_usage import
        exit 0
      fi
      run_step "1/1" "Import Curated Batch" "Current-admin import command complete" -- \
        "$VENV_PYTHON" scripts/import_curated_current_admin_batch.py "$@"
      ;;
    validate)
      if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        current_admin_subcommand_usage validate
        exit 0
      fi
      run_step "1/1" "Validate Import" "Current-admin validation complete" -- \
        "$VENV_PYTHON" scripts/validate_current_admin_import.py "$@"
      ;;
    help|-h|--help|"")
      current_admin_usage
      ;;
    *)
      echo "Unknown current-admin command: $command" >&2
      current_admin_usage
      exit 1
      ;;
  esac
}

main_usage() {
  cat <<EOF
Usage:
  equitystack legislative <command> [args]
  equitystack current-admin <command> [args]
  equitystack admin-reset-operational-state [--dry-run | --apply --yes]

Shared runtime defaults:
  verifier AI:      $DEFAULT_MODEL_VERIFIER
  review AI:        $DEFAULT_MODEL_REVIEW
  fallback AI:      $DEFAULT_MODEL_FALLBACK
  executor model:   $DEFAULT_MODEL_EXECUTOR
  Ollama server:    $DEFAULT_OLLAMA_URL
  senior timeout:   ${DEFAULT_OLLAMA_TIMEOUT_SENIOR}s
  verifier timeout: ${DEFAULT_OLLAMA_TIMEOUT_VERIFIER}s

Legislative commands:
  run        Run the daily review-first pipeline, auto-triage safe actions, rebuild the bundle
  review     Open the legislative review CLI
  apply      Apply approved legislative actions, rerun affected bills when needed, rebuild the bundle
  import     Import approved tracked-bill seed rows, rebuild the bundle
  feedback   Refresh feedback analysis and rebuild the bundle

Current-admin commands:
  discover   Run read-only discovery for current-administration updates
  export     Export selected discovery suggestions into a draft batch
  normalize  Normalize a curated batch file
  review     Run advisory Ollama review on a normalized batch
  queue      Build the manual review queue from normalized batch plus AI review
  run        Run normalize, review, and queue for one batch
  status     Show current-admin artifact state and recommended next step
  workflow   Guided wrapper around the canonical current-admin artifact flow
  pre-commit Generate the import guardrail artifact
  import     Dry-run or apply a curated batch import
  validate   Validate imported current-administration records

Current-admin workflow subcommands:
  workflow start        Run normalize, review, and queue for one batch
  workflow review       Generate a decision template from a review or worklist artifact
  workflow finalize     Log explicit operator decisions against a canonical review artifact
  workflow resume       Show the latest current-admin session and recommended next step

Operational maintenance:
  admin-reset-operational-state   Archive non-canonical run-state artifacts for a fresh walkthrough

Examples:
  $(cli_hint) legislative run
  $(cli_hint) legislative run --model qwen3.5:27b
  $(cli_hint) current-admin status
  $(cli_hint) admin-reset-operational-state --dry-run
  $(cli_hint) current-admin workflow start --input data/current_admin_batches/<batch-file>.json
  $(cli_hint) current-admin workflow review --input reports/current_admin/<batch-name>.ai-review.json --output /tmp/<batch-name>.decision-template.json
EOF
}

admin_reset_operational_state_usage() {
  cat <<EOF
Usage:
  equitystack admin-reset-operational-state [--dry-run | --apply --yes]

Archives operational run-state artifacts for a clean walkthrough baseline.

This reset affects only:
  - operator history
  - recommendation feedback history
  - current-admin report artifacts
  - legislative report artifacts
  - EquityStack log files

This reset does NOT touch:
  - database content
  - canonical policy data
  - source files

Examples:
  $(cli_hint) admin-reset-operational-state --dry-run
  $(cli_hint) admin-reset-operational-state --apply --yes
EOF
}

legislative_usage() {
  cat <<EOF
Usage:
  equitystack legislative <command> [args]

Commands:
  run        Run the daily pipeline, auto-triage safe actions, and rebuild the review bundle
  review     Open the legislative review CLI
  apply      Dry-run or apply approved legislative actions
  import     Dry-run or apply approved tracked-bill seed rows
  feedback   Refresh feedback analysis and rebuild the bundle

Run options:
  --model <name>                Override the senior review model for the daily pipeline
  --verifier-model <name>       Override the 9B-style verifier model for draft/assist stages
  --fallback-model <name>       Override the fallback reviewer model used after senior-review failure
  --timeout <seconds>           Legacy alias that sets both senior and verifier timeouts
  --senior-timeout <seconds>    Override the 27B review timeout
  --verifier-timeout <seconds>  Override the 9B verifier/fallback timeout
  --skip-discovery              Pass through to run_equitystack_pipeline.py
  --apply-safe-removals         Pass through to run_equitystack_pipeline.py
  --only-future-bill-id <id>    Limit the pipeline to one or more future bills
  --output-report <path>        Override the pipeline report path
  --csv                         Ensure supporting CSV reports are written

Apply / import options:
  legislative apply --dry-run
  legislative apply --apply --yes
  legislative import --dry-run
  legislative import --apply --yes
EOF
}

current_admin_usage() {
  cat <<EOF
Usage:
  equitystack current-admin <command> [args]

Commands:
  discover   Wrapper for scripts/discover_current_admin_updates.py
  export     Wrapper for scripts/export_current_admin_discovery_candidates.py
  normalize  Wrapper for scripts/normalize_current_admin_batch.py
  review     Wrapper for scripts/review_current_admin_batch_with_ollama.py
  queue      Wrapper for scripts/apply_current_admin_ai_review.py
  run        Run normalize, review, and queue for one batch
  status     Show current-admin batch state and recommended next step
  workflow   Guided artifact-first operator workflow helpers
  pre-commit Wrapper for scripts/build_current_admin_precommit_review.py
  import     Wrapper for scripts/import_curated_current_admin_batch.py
  validate   Wrapper for scripts/validate_current_admin_import.py

Defaults:
  current-admin review and workflow decision steps default to:
    senior-model   $DEFAULT_MODEL_REVIEW
    verifier-model $DEFAULT_MODEL_VERIFIER
    fallback-model $DEFAULT_MODEL_FALLBACK
    senior-timeout ${DEFAULT_OLLAMA_TIMEOUT_SENIOR}s
    verifier-timeout ${DEFAULT_OLLAMA_TIMEOUT_VERIFIER}s
    ollama-url     $DEFAULT_OLLAMA_URL

  current-admin discovery defaults to:
    model       $DEFAULT_MODEL_VERIFIER
    timeout     ${DEFAULT_OLLAMA_TIMEOUT_VERIFIER}s
    ollama-url  $DEFAULT_OLLAMA_URL
EOF
}

current_admin_workflow_usage() {
  cat <<EOF
Usage:
  equitystack current-admin workflow <command> [args]

Commands:
  start                      Run normalize, review, and queue for one batch
  review                     Generate a decision template from a review or worklist artifact
  finalize                   Log explicit operator decisions against a canonical review artifact
  resume                     Show the latest current-admin session and recommended next step
EOF
}

current_admin_workflow_subcommand_usage() {
  local subcommand="$1"
  case "$subcommand" in
    start)
      cat <<EOF
Usage:
  equitystack current-admin workflow start [--input <batch-file> | --batch-name <batch-name>] [--review-dry-run] [--prefill-suggestions] [--model <senior-name>] [--verifier-model <name>] [--fallback-model <name>] [--timeout <seconds>] [--senior-timeout <seconds>] [--verifier-timeout <seconds>] [--ollama-url <url>] [--deep-review | --review-mode <standard|deep>]

Runs the existing safe pre-import workflow:
  normalize -> review -> queue

This does not import records or write to the database.
EOF
      ;;
    review|generate-decision-template)
      cat <<EOF
Usage:
  equitystack current-admin workflow review --input <ai-review-or-worklist.json> [--output <decision-template.json>] [filters]

Runs:
  python3 scripts/generate_current_admin_decision_template.py [args]
EOF
      ;;
    finalize)
      cat <<EOF
Usage:
  equitystack current-admin workflow finalize --review <ai-review.json> --decision-file <decisions.json> --log-decisions [path] [--feedback-summary]

Replays the canonical review settings from the source AI review artifact and writes a decision log.
This does not import records or write to the database.
EOF
      ;;
    resume)
      cat <<EOF
Usage:
  equitystack current-admin workflow resume

Shows the latest current-admin review session and the likely next operator step.
EOF
      ;;
    *)
      current_admin_workflow_usage
      ;;
  esac
}

current_admin_subcommand_usage() {
  local subcommand="$1"
  case "$subcommand" in
    discover)
      cat <<EOF
Usage:
  equitystack current-admin discover [args]

Runs:
  python3 scripts/discover_current_admin_updates.py [args]

Wrapper defaults:
  --model $DEFAULT_MODEL_VERIFIER
  --timeout $DEFAULT_OLLAMA_TIMEOUT_VERIFIER
  --ollama-url $DEFAULT_OLLAMA_URL
EOF
      ;;
    export)
      cat <<EOF
Usage:
  equitystack current-admin export [args]

Runs:
  python3 scripts/export_current_admin_discovery_candidates.py [args]
EOF
      ;;
    normalize)
      cat <<EOF
Usage:
  equitystack current-admin normalize [args]

Runs:
  python3 scripts/normalize_current_admin_batch.py [args]
EOF
      ;;
    review)
      cat <<EOF
Usage:
  equitystack current-admin review [args]

Runs:
  python3 scripts/review_current_admin_batch_with_ollama.py [args]

Wrapper defaults:
  --model $DEFAULT_MODEL_REVIEW
  --verifier-model $DEFAULT_MODEL_VERIFIER
  --fallback-model $DEFAULT_MODEL_FALLBACK
  --senior-timeout $DEFAULT_OLLAMA_TIMEOUT_SENIOR
  --verifier-timeout $DEFAULT_OLLAMA_TIMEOUT_VERIFIER
  --review-mode deep
  --ollama-url $DEFAULT_OLLAMA_URL
EOF
      ;;
    queue)
      cat <<EOF
Usage:
  equitystack current-admin queue [args]

Runs:
  python3 scripts/apply_current_admin_ai_review.py [args]
EOF
      ;;
    run)
      current_admin_workflow_subcommand_usage start
      ;;
    status)
      cat <<EOF
Usage:
  equitystack current-admin status [--input <batch-file> | --batch-name <batch-name>]

Shows artifact presence, current workflow state, blocking issues, and the recommended next command.
EOF
      ;;
    import)
      cat <<EOF
Usage:
  equitystack current-admin import [args]

Runs:
  python3 scripts/import_curated_current_admin_batch.py [args]

Import stays dry-run by default. Database writes still require --apply --yes.
EOF
      ;;
    pre-commit)
      cat <<EOF
Usage:
  equitystack current-admin pre-commit [args]

Runs:
  python3 scripts/build_current_admin_precommit_review.py [args]
EOF
      ;;
    validate)
      cat <<EOF
Usage:
  equitystack current-admin validate [args]

Runs:
  python3 scripts/validate_current_admin_import.py [args]
EOF
      ;;
    *)
      current_admin_usage
      ;;
  esac
}

case "${1:-}" in
  ""|-h|--help|help)
    main_usage
    ;;
  admin-reset-operational-state)
    shift
    reset_success_message="Operational reset preview complete"
    reset_step_title="Preview Operational Reset"
    if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
      admin_reset_operational_state_usage
      exit 0
    fi
    for arg in "$@"; do
      if [ "$arg" = "--apply" ]; then
        reset_success_message="Operational artifacts archived for a fresh walkthrough"
        reset_step_title="Reset Operational State"
        break
      fi
    done
    run_step "1/1" "$reset_step_title" "$reset_success_message" -- \
      "$VENV_PYTHON" scripts/admin_reset_operational_state.py "$@"
    ;;
  legislative)
    shift
    run_legislative_command "${1:-help}" "${@:2}"
    ;;
  current-admin)
    shift
    run_current_admin_command "${1:-help}" "${@:2}"
    ;;
  run|review|apply|import|feedback)
    run_legislative_command "$@"
    ;;
  *)
    echo "Unknown command: ${1:-}" >&2
    main_usage
    exit 1
    ;;
esac
