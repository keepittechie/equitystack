run_current_admin_command() {
  local command="${1:-}"
  shift || true

  case "$command" in
    discover)
      run_current_admin_discover_command "$@"
      ;;
    gen-batch|generate-batch)
      run_current_admin_gen_batch_command "$@"
      ;;
    export)
      if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        current_admin_subcommand_usage export
        exit 0
      fi
      local -a export_args=()
      normalize_current_admin_path_args export_args "$@"
      run_step "1/1" "Export Discovery Candidates" "Discovery export complete" -- \
        "$VENV_PYTHON" scripts/export_current_admin_discovery_candidates.py "${export_args[@]}"
      ;;
    normalize)
      if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        current_admin_subcommand_usage normalize
        exit 0
      fi
      local -a normalize_args=()
      normalize_current_admin_path_args normalize_args "$@"
      run_step "1/1" "Normalize Batch" "Normalization complete" -- \
        "$VENV_PYTHON" scripts/normalize_current_admin_batch.py "${normalize_args[@]}"
      ;;
    review)
      run_current_admin_operator_review_command "$@"
      ;;
    ai-review)
      run_current_admin_review_command "$@"
      ;;
    queue)
      if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        current_admin_subcommand_usage queue
        exit 0
      fi
      local -a queue_args=()
      normalize_current_admin_path_args queue_args "$@"
      run_step "1/1" "Build Manual Queue" "Manual review queue build complete" -- \
        "$VENV_PYTHON" scripts/apply_current_admin_ai_review.py "${queue_args[@]}"
      ;;
    promote-review)
      if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        current_admin_subcommand_usage promote-review
        exit 0
      fi
      local -a promote_args=()
      normalize_current_admin_path_args promote_args "$@"
      run_step "1/1" "Promote Review To Queue" "Current-admin review promotion complete" -- \
        "$VENV_PYTHON" scripts/promote_current_admin_review_to_queue.py "${promote_args[@]}"
      ;;
    pre-commit)
      if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        current_admin_subcommand_usage pre-commit
        exit 0
      fi
      local -a precommit_args=()
      normalize_current_admin_path_args precommit_args "$@"
      run_step "1/1" "Build Pre-Commit Review" "Pre-commit review build complete" -- \
        "$VENV_PYTHON" scripts/build_current_admin_precommit_review.py "${precommit_args[@]}"
      ;;
    run)
      run_current_admin_run_command "$@"
      ;;
    apply)
      run_current_admin_apply_command "$@"
      ;;
    status)
      local input_path=""
      local batch_name=""
      local output_json="false"
      local focus="all"
      local focus_requested="false"
      local reason=""
      local confidence_bucket=""
      local unresolved_only="false"
      local readiness=""
      local schema_blocked_only="false"
      local judgment_required_only="false"
      local quality_focus="all"
      local manual_review_only="false"
      local calibration_all_batches="false"
      local simulation_preset="slightly-relaxed"
      local simulation_focus="all"
      local include_deltas="false"
      local confidence_auto_approve_threshold=""
      local confidence_manual_review_floor=""
      local allow_high_confidence_flagged_items_to_stay_blocked=""
      local treat_unclear_as_always_manual_review=""
      local treat_weak_evidence_as_always_manual_review=""
      local treat_conflicting_sources_as_always_manual_review=""
      local treat_date_uncertain_as_always_manual_review=""
      local treat_ambiguous_subject_as_always_manual_review=""
      local treat_model_manual_review_as_always_manual_review=""
      local evidence_focus="all"
      local evidence_quality_label=""
      local source_grounding_label=""
      local impact_directness_hint=""
      local evidence_item_id=""
      local include_items="false"
      local comparison_baseline=""
      local comparison_enriched=""
      local paired_experiment_name=""
      while [ "$#" -gt 0 ]; do
        case "$1" in
          --input)
            input_path="${2:-}"
            [ -n "$input_path" ] || { echo "--input requires a value" >&2; exit 1; }
            shift 2
            ;;
          --batch-name)
            batch_name="${2:-}"
            [ -n "$batch_name" ] || { echo "--batch-name requires a value" >&2; exit 1; }
            shift 2
            ;;
          --json)
            output_json="true"
            shift
            ;;
          --focus)
            focus="${2:-}"
            [ -n "$focus" ] || { echo "--focus requires a value" >&2; exit 1; }
            case "$focus" in
              all|blocked|incomplete|finalize-safe|apply-safe|manual-review|calibration|simulation|evidence-pack|comparison|paired-experiment) ;;
              *)
                echo "--focus must be one of: all, blocked, incomplete, finalize-safe, apply-safe, manual-review, calibration, simulation, evidence-pack, comparison, paired-experiment" >&2
                exit 1
                ;;
            esac
            focus_requested="true"
            shift 2
            ;;
          --paired-experiment)
            focus="paired-experiment"
            focus_requested="true"
            shift
            ;;
          --experiment-name)
            paired_experiment_name="${2:-}"
            [ -n "$paired_experiment_name" ] || { echo "--experiment-name requires a value" >&2; exit 1; }
            focus="paired-experiment"
            focus_requested="true"
            shift 2
            ;;
          --simulation)
            focus="simulation"
            focus_requested="true"
            shift
            ;;
          --evidence-pack)
            focus="evidence-pack"
            focus_requested="true"
            shift
            ;;
          --compare-review-runs)
            focus="comparison"
            focus_requested="true"
            shift
            ;;
          --baseline)
            comparison_baseline="${2:-}"
            [ -n "$comparison_baseline" ] || { echo "--baseline requires a value" >&2; exit 1; }
            comparison_baseline="$(normalize_python_workspace_path "$comparison_baseline")"
            focus="comparison"
            focus_requested="true"
            shift 2
            ;;
          --enriched)
            comparison_enriched="${2:-}"
            [ -n "$comparison_enriched" ] || { echo "--enriched requires a value" >&2; exit 1; }
            comparison_enriched="$(normalize_python_workspace_path "$comparison_enriched")"
            focus="comparison"
            focus_requested="true"
            shift 2
            ;;
          --evidence-focus)
            evidence_focus="${2:-}"
            [ -n "$evidence_focus" ] || { echo "--evidence-focus requires a value" >&2; exit 1; }
            case "$evidence_focus" in
              all|single-source-official|outcome-evidence-present|policy-intent-only|weak-outcome-evidence|multi-source-grounding) ;;
              *)
                echo "--evidence-focus must be one of: all, single-source-official, outcome-evidence-present, policy-intent-only, weak-outcome-evidence, multi-source-grounding" >&2
                exit 1
                ;;
            esac
            focus="evidence-pack"
            focus_requested="true"
            shift 2
            ;;
          --evidence-quality-label)
            evidence_quality_label="${2:-}"
            [ -n "$evidence_quality_label" ] || { echo "--evidence-quality-label requires a value" >&2; exit 1; }
            focus="evidence-pack"
            focus_requested="true"
            shift 2
            ;;
          --source-grounding-label)
            source_grounding_label="${2:-}"
            [ -n "$source_grounding_label" ] || { echo "--source-grounding-label requires a value" >&2; exit 1; }
            focus="evidence-pack"
            focus_requested="true"
            shift 2
            ;;
          --impact-directness-hint)
            impact_directness_hint="${2:-}"
            [ -n "$impact_directness_hint" ] || { echo "--impact-directness-hint requires a value" >&2; exit 1; }
            focus="evidence-pack"
            focus_requested="true"
            shift 2
            ;;
          --item-id)
            evidence_item_id="${2:-}"
            [ -n "$evidence_item_id" ] || { echo "--item-id requires a value" >&2; exit 1; }
            focus="evidence-pack"
            focus_requested="true"
            shift 2
            ;;
          --include-items)
            include_items="true"
            focus="evidence-pack"
            focus_requested="true"
            shift
            ;;
          --preset)
            simulation_preset="${2:-}"
            [ -n "$simulation_preset" ] || { echo "--preset requires a value" >&2; exit 1; }
            case "$simulation_preset" in
              strict-current|slightly-relaxed|moderate-relaxed|confidence-only-test) ;;
              *)
                echo "--preset must be one of: strict-current, slightly-relaxed, moderate-relaxed, confidence-only-test" >&2
                exit 1
                ;;
            esac
            focus="simulation"
            focus_requested="true"
            shift 2
            ;;
          --simulation-focus)
            simulation_focus="${2:-}"
            [ -n "$simulation_focus" ] || { echo "--simulation-focus requires a value" >&2; exit 1; }
            case "$simulation_focus" in
              all|threshold-sensitive|evidence-blocked|flag-blocked|threshold-only-promotions) ;;
              *)
                echo "--simulation-focus must be one of: all, threshold-sensitive, evidence-blocked, flag-blocked, threshold-only-promotions" >&2
                exit 1
                ;;
            esac
            focus="simulation"
            focus_requested="true"
            shift 2
            ;;
          --include-deltas)
            include_deltas="true"
            if [ "$focus" != "comparison" ]; then
              focus="simulation"
            fi
            focus_requested="true"
            shift
            ;;
          --include-item-deltas)
            include_deltas="true"
            focus="comparison"
            focus_requested="true"
            shift
            ;;
          --confidence-auto-approve-threshold)
            confidence_auto_approve_threshold="${2:-}"
            [ -n "$confidence_auto_approve_threshold" ] || { echo "--confidence-auto-approve-threshold requires a value" >&2; exit 1; }
            focus="simulation"
            focus_requested="true"
            shift 2
            ;;
          --confidence-manual-review-floor)
            confidence_manual_review_floor="${2:-}"
            [ -n "$confidence_manual_review_floor" ] || { echo "--confidence-manual-review-floor requires a value" >&2; exit 1; }
            focus="simulation"
            focus_requested="true"
            shift 2
            ;;
          --allow-high-confidence-flagged-items-to-stay-blocked)
            allow_high_confidence_flagged_items_to_stay_blocked="${2:-}"
            [ -n "$allow_high_confidence_flagged_items_to_stay_blocked" ] || { echo "--allow-high-confidence-flagged-items-to-stay-blocked requires a value" >&2; exit 1; }
            focus="simulation"
            focus_requested="true"
            shift 2
            ;;
          --treat-unclear-as-always-manual-review)
            treat_unclear_as_always_manual_review="${2:-}"
            [ -n "$treat_unclear_as_always_manual_review" ] || { echo "--treat-unclear-as-always-manual-review requires a value" >&2; exit 1; }
            focus="simulation"
            focus_requested="true"
            shift 2
            ;;
          --treat-weak-evidence-as-always-manual-review)
            treat_weak_evidence_as_always_manual_review="${2:-}"
            [ -n "$treat_weak_evidence_as_always_manual_review" ] || { echo "--treat-weak-evidence-as-always-manual-review requires a value" >&2; exit 1; }
            focus="simulation"
            focus_requested="true"
            shift 2
            ;;
          --treat-conflicting-sources-as-always-manual-review)
            treat_conflicting_sources_as_always_manual_review="${2:-}"
            [ -n "$treat_conflicting_sources_as_always_manual_review" ] || { echo "--treat-conflicting-sources-as-always-manual-review requires a value" >&2; exit 1; }
            focus="simulation"
            focus_requested="true"
            shift 2
            ;;
          --treat-date-uncertain-as-always-manual-review)
            treat_date_uncertain_as_always_manual_review="${2:-}"
            [ -n "$treat_date_uncertain_as_always_manual_review" ] || { echo "--treat-date-uncertain-as-always-manual-review requires a value" >&2; exit 1; }
            focus="simulation"
            focus_requested="true"
            shift 2
            ;;
          --treat-ambiguous-subject-as-always-manual-review)
            treat_ambiguous_subject_as_always_manual_review="${2:-}"
            [ -n "$treat_ambiguous_subject_as_always_manual_review" ] || { echo "--treat-ambiguous-subject-as-always-manual-review requires a value" >&2; exit 1; }
            focus="simulation"
            focus_requested="true"
            shift 2
            ;;
          --treat-model-manual-review-as-always-manual-review)
            treat_model_manual_review_as_always_manual_review="${2:-}"
            [ -n "$treat_model_manual_review_as_always_manual_review" ] || { echo "--treat-model-manual-review-as-always-manual-review requires a value" >&2; exit 1; }
            focus="simulation"
            focus_requested="true"
            shift 2
            ;;
          --calibration)
            focus="calibration"
            focus_requested="true"
            shift
            ;;
          --quality-focus)
            quality_focus="${2:-}"
            [ -n "$quality_focus" ] || { echo "--quality-focus requires a value" >&2; exit 1; }
            case "$quality_focus" in
              all|low-confidence-heavy|weak-evidence-heavy|unclear-heavy|high-manual-review|structurally-valid-but-decision-thin) ;;
              *)
                echo "--quality-focus must be one of: all, low-confidence-heavy, weak-evidence-heavy, unclear-heavy, high-manual-review, structurally-valid-but-decision-thin" >&2
                exit 1
                ;;
            esac
            focus="calibration"
            focus_requested="true"
            shift 2
            ;;
          --manual-review-only)
            manual_review_only="true"
            if [ "$focus" != "simulation" ]; then
              focus="calibration"
            fi
            focus_requested="true"
            shift
            ;;
          --all-batches)
            calibration_all_batches="true"
            if [ "$focus" != "simulation" ] && [ "$focus" != "evidence-pack" ] && [ "$focus" != "comparison" ] && [ "$focus" != "paired-experiment" ]; then
              focus="calibration"
            fi
            focus_requested="true"
            shift
            ;;
          --manual-review)
            focus="manual-review"
            focus_requested="true"
            shift
            ;;
          --blocked)
            focus="blocked"
            focus_requested="true"
            shift
            ;;
          --incomplete)
            focus="incomplete"
            focus_requested="true"
            shift
            ;;
          --finalize-safe)
            focus="finalize-safe"
            focus_requested="true"
            shift
            ;;
          --apply-safe)
            focus="apply-safe"
            focus_requested="true"
            shift
            ;;
          --reason)
            reason="${2:-}"
            [ -n "$reason" ] || { echo "--reason requires a value" >&2; exit 1; }
            case "$reason" in
              schema|conflicting-sources|weak-evidence|unclear|low-confidence|manual-review-requested|ambiguous-subject|date-uncertain) ;;
              *)
                echo "--reason must be one of: schema, conflicting-sources, weak-evidence, unclear, low-confidence, manual-review-requested, ambiguous-subject, date-uncertain" >&2
                exit 1
                ;;
            esac
            focus="manual-review"
            focus_requested="true"
            shift 2
            ;;
          --confidence-bucket)
            confidence_bucket="${2:-}"
            [ -n "$confidence_bucket" ] || { echo "--confidence-bucket requires a value" >&2; exit 1; }
            case "$confidence_bucket" in
              0.00-0.59|0.60-0.74|0.75-0.84|0.85+) ;;
              *)
                echo "--confidence-bucket must be one of: 0.00-0.59, 0.60-0.74, 0.75-0.84, 0.85+" >&2
                exit 1
                ;;
            esac
            focus="manual-review"
            focus_requested="true"
            shift 2
            ;;
          --unresolved-only)
            unresolved_only="true"
            if [ "$focus" != "calibration" ]; then
              focus="manual-review"
            fi
            focus_requested="true"
            shift
            ;;
          --readiness)
            readiness="${2:-}"
            [ -n "$readiness" ] || { echo "--readiness requires a value" >&2; exit 1; }
            case "$readiness" in
              needs-artifact-repair|needs-evidence-verification|needs-operator-judgment|ready-for-operator-decision) ;;
              *)
                echo "--readiness must be one of: needs-artifact-repair, needs-evidence-verification, needs-operator-judgment, ready-for-operator-decision" >&2
                exit 1
                ;;
            esac
            focus="manual-review"
            focus_requested="true"
            shift 2
            ;;
          --schema-blocked-only)
            schema_blocked_only="true"
            focus="manual-review"
            focus_requested="true"
            shift
            ;;
          --judgment-required-only)
            judgment_required_only="true"
            focus="manual-review"
            focus_requested="true"
            shift
            ;;
          -h|--help)
            current_admin_subcommand_usage status
            exit 0
            ;;
          *)
            echo "Unknown argument for current-admin status: $1" >&2
            current_admin_subcommand_usage status
            exit 1
            ;;
        esac
      done
      if [ -n "$input_path" ]; then
        input_path="$(normalize_python_workspace_path "$input_path")"
      fi
      if [ "$focus_requested" = "true" ]; then
        output_json="true"
      fi
      print_current_admin_status "$input_path" "$batch_name" "$output_json" "$focus" "$reason" "$confidence_bucket" "$unresolved_only" "$readiness" "$schema_blocked_only" "$judgment_required_only" "$quality_focus" "$manual_review_only" "$calibration_all_batches" "$simulation_preset" "$simulation_focus" "$include_deltas" "$confidence_auto_approve_threshold" "$confidence_manual_review_floor" "$allow_high_confidence_flagged_items_to_stay_blocked" "$treat_unclear_as_always_manual_review" "$treat_weak_evidence_as_always_manual_review" "$treat_conflicting_sources_as_always_manual_review" "$treat_date_uncertain_as_always_manual_review" "$treat_ambiguous_subject_as_always_manual_review" "$treat_model_manual_review_as_always_manual_review" "$evidence_focus" "$evidence_quality_label" "$source_grounding_label" "$impact_directness_hint" "$evidence_item_id" "$include_items" "$comparison_baseline" "$comparison_enriched" "$paired_experiment_name"
      ;;
    workflow)
      run_current_admin_workflow_command "${1:-help}" "${@:2}"
      ;;
    import)
      if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        current_admin_subcommand_usage import
        exit 0
      fi
      local -a import_args=()
      normalize_current_admin_path_args import_args "$@"
      run_step "1/1" "Import Curated Batch" "Current-admin import command complete" -- \
        "$VENV_PYTHON" scripts/import_curated_current_admin_batch.py "${import_args[@]}"
      ;;
    validate)
      if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        current_admin_subcommand_usage validate
        exit 0
      fi
      local -a validate_args=()
      normalize_current_admin_path_args validate_args "$@"
      run_step "1/1" "Validate Import" "Current-admin validation complete" -- \
        "$VENV_PYTHON" scripts/validate_current_admin_import.py "${validate_args[@]}"
      ;;
    help|-h|--help|"")
      current_admin_usage
      ;;
    *)
      echo "Unknown current-admin command: $command" >&2
      current_admin_usage
      exit 1
      ;;
  esac
}

main_usage() {
  cat <<EOF
Usage:
  equitystack legislative <command> [args]
  equitystack current-admin <command> [args]
  equitystack impact <command> [args]
  equitystack operator <command> [args]
  equitystack admin-reset-operational-state [--dry-run | --apply --yes]

Shared runtime defaults:
  verifier AI:      $DEFAULT_MODEL_VERIFIER
  review AI:        $DEFAULT_MODEL_REVIEW
  fallback AI:      $DEFAULT_MODEL_FALLBACK
  executor model:   $DEFAULT_MODEL_EXECUTOR
  LLM endpoint:     $DEFAULT_OLLAMA_URL
  senior timeout:   ${DEFAULT_OLLAMA_TIMEOUT_SENIOR}s
  verifier timeout: ${DEFAULT_OLLAMA_TIMEOUT_VERIFIER}s

Legislative commands:
  run        Run the daily review-first pipeline, auto-triage safe actions, rebuild the bundle
  review     Open the legislative review CLI
  apply      Apply approved legislative actions, rerun affected bills when needed, rebuild the bundle
  import     Import approved tracked-bill seed rows, rebuild the bundle
  feedback   Refresh feedback analysis and rebuild the bundle

Current-admin commands:
  discover   Run read-only discovery for current-administration updates
  gen-batch  Generate a canonical current-admin batch from discovery candidates
  export     Export selected discovery suggestions into a draft batch
  normalize  Normalize a curated batch file
  ai-review  Run conservative OpenAI Batch review on a normalized batch
  queue      Build the manual review queue from normalized batch plus AI review
  run        Discover and generate the next batch by default, then normalize, review, and queue it
  review     Generate or finalize operator decisions for a review artifact
  apply      Run pre-commit, import dry-run, optional apply, and validation
  status     Show current-admin artifact state and recommended next step
  workflow   Guided wrapper around the canonical current-admin artifact flow
  pre-commit Generate the import guardrail artifact
  import     Dry-run or apply a curated batch import
  validate   Validate imported current-administration records

Current-admin workflow subcommands:
  workflow start        Run normalize, review, and queue for one batch
  workflow review       Generate a decision template from a review or worklist artifact
  workflow finalize     Log explicit operator decisions against a canonical review artifact
  workflow resume       Show the latest current-admin session and recommended next step

Impact maturation commands:
  evaluate   Build a read-only impact maturation review artifact
  promote    Promote approved safe forward impact transitions
  backfill-outcome-sources  Audit optional safe promise_outcome_sources links
  sync-current-admin-outcomes  Sync promise_outcomes into policy_outcomes
  audit-historical-duplicates  Audit likely duplicate/variant historical policies
  audit-policy-coverage-gaps  Generate Missing Policy Report by decade/category
  audit-outcome-temporal-attribution  Audit outcome timing signals without changing scoring
  report-outcome-time  Report unified policy_outcomes by year, decade, and administration
  report-final-black-impact-score  Compute final Black Impact Score per president
  certify-production-data  End-to-end read-only data model and scoring certification
  validate-integrity  Validate attribution consistency and policy_outcomes drift risks
  complete-certification-readiness  Apply guarded certification readiness backfills
  backfill-policy-time-intent  Dry-run or apply safe policy time and intent backfills
  curate-policy-intent  Manually classify missing historical policy intent
  curate-sources  Manually attach operator-provided sources to policy outcomes

Operational maintenance:
  operator cleanup-stale-workflows  Mark stale operator workflow sessions inactive without deleting history
  admin-reset-operational-state   Archive non-canonical run-state artifacts for a fresh walkthrough

Examples:
  $(cli_hint) legislative run
  $(cli_hint) legislative run --model "$DEFAULT_MODEL_REVIEW"
  $(cli_hint) impact evaluate
  $(cli_hint) impact promote --dry-run
  $(cli_hint) impact audit-historical-duplicates
  $(cli_hint) impact audit-policy-coverage-gaps
  $(cli_hint) impact audit-outcome-temporal-attribution
  $(cli_hint) impact report-outcome-time
  $(cli_hint) impact report-final-black-impact-score
  $(cli_hint) impact certify-production-data
  $(cli_hint) impact validate-integrity
  $(cli_hint) impact complete-certification-readiness
  $(cli_hint) impact backfill-policy-time-intent
  $(cli_hint) impact curate-policy-intent --non-interactive --limit 10
  $(cli_hint) impact curate-sources --non-interactive --limit 10
  $(cli_hint) current-admin run
  $(cli_hint) current-admin status
  $(cli_hint) operator cleanup-stale-workflows --dry-run
  $(cli_hint) admin-reset-operational-state --dry-run
  $(cli_hint) current-admin workflow start --input data/current_admin_batches/<batch-file>.json
  $(cli_hint) current-admin review --input reports/current_admin/<batch-name>.ai-review.json
EOF
}

impact_usage() {
  cat <<EOF
Usage:
  equitystack impact <command> [args]

Commands:
  evaluate   Build reports/impact_maturation_review.json from pending/review-ready artifacts
  promote    Validate and promote approved safe forward transitions
  backfill-outcome-sources
             Audit and optionally insert safe promise_outcome_sources links
  sync-current-admin-outcomes
             Dry-run or apply current-admin promise_outcomes into policy_outcomes
  audit-historical-duplicates
             Read-only audit for likely duplicate/variant historical policies
  audit-policy-coverage-gaps
             Read-only Missing Policy Report by decade and major historical policy category
  audit-outcome-temporal-attribution
             Audit outcome timing signals and optional backfill readiness
  audit-source-quality
             Audit source authority tiers, domains, duplicates, and outcome coverage
  audit-outcome-source-gaps
             Prioritize policy_outcomes missing sources for manual curation
  report-outcome-time
             Read-only report for policy_outcomes time dimension and date validation
  report-policy-intent
             Read-only report for policy intent vs outcome alignment
  report-final-black-impact-score
             Read-only final Black Impact Score per president from unified policy_outcomes
  certify-production-data
             End-to-end read-only production data model and scoring certification audit
  validate-integrity
             Read-only attribution consistency and policy_outcomes integrity validation
  complete-certification-readiness
             Dry-run or apply guarded production certification readiness backfills
  audit-policy-intent-gaps
             Build a read-only queue of policies missing policy intent classification
  backfill-policy-time-intent
             Dry-run or apply high-confidence policy time and intent backfills
  curate-policy-intent
             Manually classify missing historical policy intent without overwriting existing values
  curate-sources
             Manually attach operator-provided sources to current-admin policy outcomes

Examples:
  $(cli_hint) impact evaluate
  $(cli_hint) impact evaluate --input reports/current_admin/<batch>.manual-review-queue.json
  $(cli_hint) impact promote --dry-run
  $(cli_hint) impact promote --apply --yes
  $(cli_hint) impact promote --apply --yes --approve-safe
  $(cli_hint) impact backfill-outcome-sources
  $(cli_hint) impact backfill-outcome-sources --apply --yes
  $(cli_hint) impact sync-current-admin-outcomes
  $(cli_hint) impact sync-current-admin-outcomes --apply --yes
  $(cli_hint) impact audit-historical-duplicates
  $(cli_hint) impact audit-policy-coverage-gaps
  $(cli_hint) impact audit-outcome-temporal-attribution
  $(cli_hint) impact audit-source-quality
  $(cli_hint) impact audit-outcome-source-gaps
  $(cli_hint) impact report-outcome-time
  $(cli_hint) impact report-policy-intent
  $(cli_hint) impact report-final-black-impact-score
  $(cli_hint) impact certify-production-data
  $(cli_hint) impact validate-integrity
  $(cli_hint) impact complete-certification-readiness
  $(cli_hint) impact audit-policy-intent-gaps
  $(cli_hint) impact backfill-policy-time-intent
  $(cli_hint) impact backfill-policy-time-intent --apply --yes
  $(cli_hint) impact curate-policy-intent --non-interactive --limit 10
  $(cli_hint) impact curate-policy-intent --only-policy-id 157 --category equity_expanding --summary "..." --source-reference "..." --apply --yes
  $(cli_hint) impact curate-sources --non-interactive --limit 10
  $(cli_hint) impact curate-sources --only-policy-outcome-id 6 --source-title "..." --source-url "https://..." --apply --yes

Safety:
  Allowed transitions are impact_pending -> impact_review_ready,
  impact_review_ready -> impact_scored, and impact_scored -> impact_verified.
  Backward movement is blocked. Outcomes are inserted only for impact_scored
  or impact_verified transitions, and existing outcome rows are preserved.
  Outcome-source backfill is dry-run by default and only inserts
  safe_auto_link candidates when --apply --yes is explicit.
  Current-admin policy outcome sync is insert-only and preserves existing
  unified policy_outcomes rows.
  Historical duplicate audit is read-only and never merges or deletes policies.
  Outcome temporal attribution audit is dry-run by default and will not write
  dates unless suitable date/provenance columns exist and --apply --yes is explicit.
  Source quality audit is read-only and never edits source rows or joins.
  Integrity validation is read-only and reports attribution/source/coverage
  warnings without modifying policy_outcomes.
  Outcome time reporting is read-only and never mutates policy_outcomes.
  Policy intent reporting is read-only and never infers missing intent.
  Policy time/intent backfill is dry-run by default, updates only NULL
  fields, preserves existing values, and requires --apply --yes.
  Manual policy-intent curation is dry-run by default, targets only
  policies with NULL policy_intent_category, and requires --apply --yes.
  Manual source curation never auto-discovers sources. It only attaches
  operator-provided URLs, avoids duplicate URL creation, rejects low/unverified
  source quality, and requires --apply --yes for writes.
EOF
}

operator_usage() {
  cat <<EOF
Usage:
  equitystack operator <command> [args]

Commands:
  cleanup-stale-workflows   Mark stale operator workflow sessions inactive without deleting history

Cleanup examples:
  $(cli_hint) operator cleanup-stale-workflows --dry-run
  $(cli_hint) operator cleanup-stale-workflows --apply --yes
  $(cli_hint) operator cleanup-stale-workflows --session-id current-admin:current-admin-wrapper-test --apply --yes

Safety:
  Cleanup never deletes workflow session files. It marks selected active sessions
  inactive and adds archivedAt, archivedReason, archivedBy, and cleanupMetadata.
  Default selection includes obvious test sessions, older duplicate active sessions,
  and older blocked sessions. Use --exclude-session to keep a matching session.
EOF
}

