#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
VENV_PYTHON="$PROJECT_DIR/venv/bin/python3"
LOG_DIR="$PROJECT_DIR/logs"

if [ ! -x "$VENV_PYTHON" ]; then
  VENV_PYTHON="$(command -v python3)"
fi

mkdir -p "$LOG_DIR"

LOG_FILE="$LOG_DIR/equitystack-$(date +%F).log"

log() {
  echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" | tee -a "$LOG_FILE"
}

run_cmd() {
  log "Running: $*"
  "$@" 2>&1 | tee -a "$LOG_FILE"
}

read_precommit_status() {
  local precommit_path="$1"
  if [ ! -f "$precommit_path" ]; then
    return 1
  fi

  PRECOMMIT_PATH="$precommit_path" "$VENV_PYTHON" - <<'PY'
import json
import os
from pathlib import Path

path = Path(os.environ["PRECOMMIT_PATH"])
payload = json.loads(path.read_text())
status = payload.get("readiness_status")
if isinstance(status, str) and status.strip():
    print(status.strip())
PY
}

apply_report_has_affected_bills() {
  "$VENV_PYTHON" - <<'PY'
import json
from pathlib import Path

path = Path("reports/equitystack_apply_report.json")
if not path.exists():
    raise SystemExit(1)

payload = json.loads(path.read_text())
affected = payload.get("affected_future_bill_ids") or []
raise SystemExit(0 if affected else 1)
PY
}

resolve_current_admin_context() {
  local input_path="${1:-}"
  local batch_name="${2:-}"

  CURRENT_ADMIN_INPUT="$input_path" CURRENT_ADMIN_BATCH_NAME="$batch_name" "$VENV_PYTHON" - <<'PY'
import json
import os
from pathlib import Path

python_dir = Path.cwd()
batches_dir = python_dir / "data" / "current_admin_batches"
reports_dir = python_dir / "reports" / "current_admin"
input_arg = os.environ.get("CURRENT_ADMIN_INPUT", "").strip()
batch_name_arg = os.environ.get("CURRENT_ADMIN_BATCH_NAME", "").strip()


def read_batch_name(path: Path) -> str:
    payload = json.loads(path.read_text())
    batch_name = payload.get("batch_name")
    if not isinstance(batch_name, str) or not batch_name.strip():
        raise SystemExit(f"Batch file missing batch_name: {path}")
    return batch_name.strip()


def latest_batch_file() -> Path | None:
    candidates = [path for path in batches_dir.glob("*.json") if path.is_file()]
    if not candidates:
        return None
    return max(candidates, key=lambda path: path.stat().st_mtime)


def find_batch_file_by_name(batch_name: str) -> Path | None:
    for path in sorted(batches_dir.glob("*.json")):
        if not path.is_file():
            continue
        try:
            if read_batch_name(path) == batch_name:
                return path
        except Exception:
            continue
    return None


if input_arg:
    batch_file = Path(input_arg)
    if not batch_file.is_absolute():
        batch_file = (python_dir / batch_file).resolve()
    else:
        batch_file = batch_file.resolve()
    if not batch_file.exists():
        raise SystemExit(f"Batch file not found: {batch_file}")
    resolved_batch_name = read_batch_name(batch_file)
elif batch_name_arg:
    batch_file = find_batch_file_by_name(batch_name_arg)
    if batch_file is None:
        raise SystemExit(f"Could not find a batch file for batch_name={batch_name_arg}")
    resolved_batch_name = batch_name_arg
else:
    batch_file = latest_batch_file()
    if batch_file is None:
        raise SystemExit("No current-admin batch files were found under data/current_admin_batches/")
    resolved_batch_name = read_batch_name(batch_file)

normalized = reports_dir / f"{resolved_batch_name}.normalized.json"
review = reports_dir / f"{resolved_batch_name}.ai-review.json"
queue = reports_dir / f"{resolved_batch_name}.manual-review-queue.json"
import_dry_run = reports_dir / f"{resolved_batch_name}.import-dry-run.json"
import_apply = reports_dir / f"{resolved_batch_name}.import-apply.json"
validation = reports_dir / f"{resolved_batch_name}.import-validation.json"
precommit = reports_dir / f"{resolved_batch_name}.pre-commit-review.json"

for value in (
    batch_file,
    resolved_batch_name,
    normalized,
    review,
    queue,
    precommit,
    import_dry_run,
    import_apply,
    validation,
):
    print(value)
PY
}

main_usage() {
  cat <<'EOF'
Usage:
  equitystack legislative <command> [args]
  equitystack current-admin <command> [args]

Legacy legislative shortcuts:
  equitystack run
  equitystack review
  equitystack apply
  equitystack import
  equitystack feedback

Legislative commands:
  run        Run the daily review-first pipeline
  review     Review pending legislative bundle actions
  apply      Apply approved legislative actions, rerun affected bills, rebuild bundle
  import     Import approved tracked-bill seed rows, rebuild bundle
  feedback   Refresh feedback analysis and rebuild bundle

Current-admin commands:
  discover   Run read-only discovery for current-administration updates
  export     Export selected discovery suggestions into a draft batch
  normalize  Normalize a curated batch file
  review     Run advisory Ollama review on a normalized batch
  queue      Build the manual review queue from normalized batch + AI review
  run        Run normalize, review, and queue for one batch
  status     Show current-admin batch state and recommended next step
  workflow   Guided wrapper around the canonical current-admin artifact flow
  pre-commit Generate a read-only import guardrail artifact
  import     Dry-run or apply a curated batch import
  validate   Validate imported current-administration records

Most days:
  equitystack legislative run
  equitystack legislative review
  equitystack legislative apply

Current-admin updates:
  equitystack current-admin status
  equitystack current-admin workflow start --input data/current_admin_batches/<batch-file>.json
  equitystack current-admin workflow start --input data/current_admin_batches/<batch-file>.json --deep-review
  equitystack current-admin pre-commit --input reports/current_admin/<batch-name>.manual-review-queue.json
  equitystack current-admin import --input reports/current_admin/<batch-name>.manual-review-queue.json
  equitystack current-admin validate --input reports/current_admin/<batch-name>.manual-review-queue.json

Use "equitystack legislative help" or "equitystack current-admin help" for workflow-specific help.
EOF
}

