      ;;
  esac
}

run_current_admin_command() {
  local command="${1:-}"
  shift || true

  case "$command" in
    discover)
      run_current_admin_discover_command "$@"
      ;;
    gen-batch|generate-batch)
      run_current_admin_gen_batch_command "$@"
      ;;
    export)
      if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        current_admin_subcommand_usage export
        exit 0
      fi
      local -a export_args=()
      normalize_current_admin_path_args export_args "$@"
      run_step "1/1" "Export Discovery Candidates" "Discovery export complete" -- \
        "$VENV_PYTHON" scripts/export_current_admin_discovery_candidates.py "${export_args[@]}"
      ;;
    normalize)
      if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        current_admin_subcommand_usage normalize
        exit 0
      fi
      local -a normalize_args=()
      normalize_current_admin_path_args normalize_args "$@"
      run_step "1/1" "Normalize Batch" "Normalization complete" -- \
        "$VENV_PYTHON" scripts/normalize_current_admin_batch.py "${normalize_args[@]}"
      ;;
    outcome-evidence)
      if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        current_admin_subcommand_usage outcome-evidence
        exit 0
      fi
      local -a outcome_evidence_args=()
      normalize_current_admin_path_args outcome_evidence_args "$@"
      run_step "1/1" "Collect Outcome Evidence" "Current-admin outcome evidence collection complete" -- \
        "$VENV_PYTHON" scripts/discover_current_admin_outcome_evidence.py "${outcome_evidence_args[@]}"
      ;;
    review)
      run_current_admin_operator_review_command "$@"
      ;;
    ai-review)
      run_current_admin_review_command "$@"
      ;;
    deep-review)
      if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        current_admin_subcommand_usage deep-review
        exit 0
      fi
      run_current_admin_deep_review_command "$@"
      ;;
    pre-commit)
      if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        current_admin_subcommand_usage pre-commit
        exit 0
      fi
      local -a precommit_args=()
      normalize_current_admin_path_args precommit_args "$@"
      run_step "1/1" "Build Pre-Commit Review" "Pre-commit review build complete" -- \
        "$VENV_PYTHON" scripts/build_current_admin_precommit_review.py "${precommit_args[@]}"
      ;;
    run)
      run_current_admin_run_command "$@"
      ;;
    apply)
      run_current_admin_apply_command "$@"
      ;;
    status)
      local input_path=""
      local batch_name=""
      local output_json="false"
      local focus="all"
      local focus_requested="false"
      local reason=""
      local confidence_bucket=""
      local unresolved_only="false"
      local readiness=""
      local schema_blocked_only="false"
      local judgment_required_only="false"
      local quality_focus="all"
      local manual_review_only="false"
      local calibration_all_batches="false"
      local simulation_preset="slightly-relaxed"
      local simulation_focus="all"
      local include_deltas="false"
      local confidence_auto_approve_threshold=""
      local confidence_manual_review_floor=""
      local allow_high_confidence_flagged_items_to_stay_blocked=""
      local treat_unclear_as_always_manual_review=""
      local treat_weak_evidence_as_always_manual_review=""
      local treat_conflicting_sources_as_always_manual_review=""
      local treat_date_uncertain_as_always_manual_review=""
      local treat_ambiguous_subject_as_always_manual_review=""
      local treat_model_manual_review_as_always_manual_review=""
      local evidence_focus="all"
      local evidence_quality_label=""
      local source_grounding_label=""
      local impact_directness_hint=""
      local evidence_item_id=""
      local include_items="false"
      local comparison_baseline=""
      local comparison_enriched=""
      local paired_experiment_name=""
      while [ "$#" -gt 0 ]; do
        case "$1" in
          --input)
            input_path="${2:-}"
            [ -n "$input_path" ] || { echo "--input requires a value" >&2; exit 1; }
            shift 2
            ;;
          --batch-name)
            batch_name="${2:-}"
            [ -n "$batch_name" ] || { echo "--batch-name requires a value" >&2; exit 1; }
            shift 2
            ;;
          --json)
            output_json="true"
            shift
            ;;
          --focus)
            focus="${2:-}"
            [ -n "$focus" ] || { echo "--focus requires a value" >&2; exit 1; }
            case "$focus" in
              all|blocked|incomplete|finalize-safe|apply-safe|manual-review|calibration|simulation|evidence-pack|comparison|paired-experiment) ;;
              *)
                echo "--focus must be one of: all, blocked, incomplete, finalize-safe, apply-safe, manual-review, calibration, simulation, evidence-pack, comparison, paired-experiment" >&2
                exit 1
                ;;
            esac
            focus_requested="true"
            shift 2
            ;;
          --paired-experiment)
            focus="paired-experiment"
            focus_requested="true"
            shift
            ;;
          --experiment-name)
            paired_experiment_name="${2:-}"
            [ -n "$paired_experiment_name" ] || { echo "--experiment-name requires a value" >&2; exit 1; }
            focus="paired-experiment"
            focus_requested="true"
            shift 2
            ;;
          --simulation)
            focus="simulation"
            focus_requested="true"
            shift
            ;;
          --evidence-pack)
            focus="evidence-pack"
            focus_requested="true"
            shift
            ;;
          --compare-review-runs)
            focus="comparison"
            focus_requested="true"
            shift
            ;;
          --baseline)
            comparison_baseline="${2:-}"
            [ -n "$comparison_baseline" ] || { echo "--baseline requires a value" >&2; exit 1; }
            comparison_baseline="$(normalize_python_workspace_path "$comparison_baseline")"
            focus="comparison"
            focus_requested="true"
            shift 2
            ;;
          --enriched)
            comparison_enriched="${2:-}"
            [ -n "$comparison_enriched" ] || { echo "--enriched requires a value" >&2; exit 1; }
            comparison_enriched="$(normalize_python_workspace_path "$comparison_enriched")"
            focus="comparison"
            focus_requested="true"
            shift 2
            ;;
          --evidence-focus)
            evidence_focus="${2:-}"
            [ -n "$evidence_focus" ] || { echo "--evidence-focus requires a value" >&2; exit 1; }
            case "$evidence_focus" in
              all|single-source-official|outcome-evidence-present|policy-intent-only|weak-outcome-evidence|multi-source-grounding) ;;
              *)
                echo "--evidence-focus must be one of: all, single-source-official, outcome-evidence-present, policy-intent-only, weak-outcome-evidence, multi-source-grounding" >&2
                exit 1
                ;;
            esac
            focus="evidence-pack"
            focus_requested="true"
            shift 2
            ;;
          --evidence-quality-label)
            evidence_quality_label="${2:-}"
            [ -n "$evidence_quality_label" ] || { echo "--evidence-quality-label requires a value" >&2; exit 1; }
            focus="evidence-pack"
            focus_requested="true"
            shift 2
            ;;
          --source-grounding-label)
            source_grounding_label="${2:-}"
            [ -n "$source_grounding_label" ] || { echo "--source-grounding-label requires a value" >&2; exit 1; }
            focus="evidence-pack"
            focus_requested="true"
            shift 2
            ;;
          --impact-directness-hint)
            impact_directness_hint="${2:-}"
            [ -n "$impact_directness_hint" ] || { echo "--impact-directness-hint requires a value" >&2; exit 1; }
            focus="evidence-pack"
            focus_requested="true"
            shift 2
            ;;
          --item-id)
            evidence_item_id="${2:-}"
            [ -n "$evidence_item_id" ] || { echo "--item-id requires a value" >&2; exit 1; }
            focus="evidence-pack"
            focus_requested="true"
            shift 2
            ;;
          --include-items)
            include_items="true"
            focus="evidence-pack"
            focus_requested="true"
            shift
            ;;
          --preset)
            simulation_preset="${2:-}"
            [ -n "$simulation_preset" ] || { echo "--preset requires a value" >&2; exit 1; }
            case "$simulation_preset" in
              strict-current|slightly-relaxed|moderate-relaxed|confidence-only-test) ;;
              *)
                echo "--preset must be one of: strict-current, slightly-relaxed, moderate-relaxed, confidence-only-test" >&2
                exit 1
                ;;
            esac
            focus="simulation"
            focus_requested="true"
            shift 2
            ;;
          --simulation-focus)
            simulation_focus="${2:-}"
            [ -n "$simulation_focus" ] || { echo "--simulation-focus requires a value" >&2; exit 1; }
            case "$simulation_focus" in
              all|threshold-sensitive|evidence-blocked|flag-blocked|threshold-only-promotions) ;;
              *)
                echo "--simulation-focus must be one of: all, threshold-sensitive, evidence-blocked, flag-blocked, threshold-only-promotions" >&2
                exit 1
                ;;
            esac
            focus="simulation"
            focus_requested="true"
            shift 2
            ;;
          --include-deltas)
            include_deltas="true"
            if [ "$focus" != "comparison" ]; then
              focus="simulation"
            fi
            focus_requested="true"
            shift
            ;;
          --include-item-deltas)
            include_deltas="true"
            focus="comparison"
            focus_requested="true"
            shift
            ;;
          --confidence-auto-approve-threshold)
            confidence_auto_approve_threshold="${2:-}"
            [ -n "$confidence_auto_approve_threshold" ] || { echo "--confidence-auto-approve-threshold requires a value" >&2; exit 1; }
            focus="simulation"
            focus_requested="true"
            shift 2
            ;;
          --confidence-manual-review-floor)
            confidence_manual_review_floor="${2:-}"
            [ -n "$confidence_manual_review_floor" ] || { echo "--confidence-manual-review-floor requires a value" >&2; exit 1; }
            focus="simulation"
            focus_requested="true"
            shift 2
            ;;
          --allow-high-confidence-flagged-items-to-stay-blocked)
            allow_high_confidence_flagged_items_to_stay_blocked="${2:-}"
            [ -n "$allow_high_confidence_flagged_items_to_stay_blocked" ] || { echo "--allow-high-confidence-flagged-items-to-stay-blocked requires a value" >&2; exit 1; }
            focus="simulation"
            focus_requested="true"
            shift 2
            ;;
          --treat-unclear-as-always-manual-review)
            treat_unclear_as_always_manual_review="${2:-}"
            [ -n "$treat_unclear_as_always_manual_review" ] || { echo "--treat-unclear-as-always-manual-review requires a value" >&2; exit 1; }
            focus="simulation"
            focus_requested="true"
            shift 2
            ;;
          --treat-weak-evidence-as-always-manual-review)
            treat_weak_evidence_as_always_manual_review="${2:-}"
            [ -n "$treat_weak_evidence_as_always_manual_review" ] || { echo "--treat-weak-evidence-as-always-manual-review requires a value" >&2; exit 1; }
            focus="simulation"
            focus_requested="true"
            shift 2
            ;;
          --treat-conflicting-sources-as-always-manual-review)
            treat_conflicting_sources_as_always_manual_review="${2:-}"
            [ -n "$treat_conflicting_sources_as_always_manual_review" ] || { echo "--treat-conflicting-sources-as-always-manual-review requires a value" >&2; exit 1; }
            focus="simulation"
            focus_requested="true"
            shift 2
            ;;
          --treat-date-uncertain-as-always-manual-review)
            treat_date_uncertain_as_always_manual_review="${2:-}"
            [ -n "$treat_date_uncertain_as_always_manual_review" ] || { echo "--treat-date-uncertain-as-always-manual-review requires a value" >&2; exit 1; }
            focus="simulation"
            focus_requested="true"
            shift 2
            ;;
          --treat-ambiguous-subject-as-always-manual-review)
            treat_ambiguous_subject_as_always_manual_review="${2:-}"
            [ -n "$treat_ambiguous_subject_as_always_manual_review" ] || { echo "--treat-ambiguous-subject-as-always-manual-review requires a value" >&2; exit 1; }
            focus="simulation"
            focus_requested="true"
            shift 2
            ;;
          --treat-model-manual-review-as-always-manual-review)
            treat_model_manual_review_as_always_manual_review="${2:-}"
            [ -n "$treat_model_manual_review_as_always_manual_review" ] || { echo "--treat-model-manual-review-as-always-manual-review requires a value" >&2; exit 1; }
            focus="simulation"
            focus_requested="true"
            shift 2
            ;;
          --calibration)
            focus="calibration"
            focus_requested="true"
            shift
            ;;
          --quality-focus)
            quality_focus="${2:-}"
            [ -n "$quality_focus" ] || { echo "--quality-focus requires a value" >&2; exit 1; }
            case "$quality_focus" in
              all|low-confidence-heavy|weak-evidence-heavy|unclear-heavy|high-manual-review|structurally-valid-but-decision-thin) ;;
              *)
                echo "--quality-focus must be one of: all, low-confidence-heavy, weak-evidence-heavy, unclear-heavy, high-manual-review, structurally-valid-but-decision-thin" >&2
                exit 1
                ;;
            esac
            focus="calibration"
            focus_requested="true"
            shift 2
            ;;
          --manual-review-only)
            manual_review_only="true"
            if [ "$focus" != "simulation" ]; then
              focus="calibration"
            fi
            focus_requested="true"
            shift
            ;;
          --all-batches)
            calibration_all_batches="true"
            if [ "$focus" != "simulation" ] && [ "$focus" != "evidence-pack" ] && [ "$focus" != "comparison" ] && [ "$focus" != "paired-experiment" ]; then
              focus="calibration"
            fi
            focus_requested="true"
            shift
            ;;
          --manual-review)
            focus="manual-review"
            focus_requested="true"
            shift
            ;;
          --blocked)
            focus="blocked"
            focus_requested="true"
            shift
            ;;
          --incomplete)
            focus="incomplete"
            focus_requested="true"
            shift
            ;;
          --finalize-safe)
            focus="finalize-safe"
            focus_requested="true"
            shift
            ;;
          --apply-safe)
            focus="apply-safe"
            focus_requested="true"
            shift
            ;;
          --reason)
            reason="${2:-}"
            [ -n "$reason" ] || { echo "--reason requires a value" >&2; exit 1; }
            case "$reason" in
              schema|conflicting-sources|weak-evidence|unclear|low-confidence|manual-review-requested|ambiguous-subject|date-uncertain) ;;
              *)
                echo "--reason must be one of: schema, conflicting-sources, weak-evidence, unclear, low-confidence, manual-review-requested, ambiguous-subject, date-uncertain" >&2
                exit 1
                ;;
            esac
            focus="manual-review"
            focus_requested="true"
            shift 2
            ;;
          --confidence-bucket)
            confidence_bucket="${2:-}"
            [ -n "$confidence_bucket" ] || { echo "--confidence-bucket requires a value" >&2; exit 1; }
            case "$confidence_bucket" in
              0.00-0.59|0.60-0.74|0.75-0.84|0.85+) ;;
              *)
                echo "--confidence-bucket must be one of: 0.00-0.59, 0.60-0.74, 0.75-0.84, 0.85+" >&2
                exit 1
                ;;
            esac
            focus="manual-review"
            focus_requested="true"
            shift 2
            ;;
          --unresolved-only)
            unresolved_only="true"
            if [ "$focus" != "calibration" ]; then
              focus="manual-review"
            fi
            focus_requested="true"
            shift
            ;;
          --readiness)
            readiness="${2:-}"
            [ -n "$readiness" ] || { echo "--readiness requires a value" >&2; exit 1; }
            case "$readiness" in
              needs-artifact-repair|needs-evidence-verification|needs-operator-judgment|ready-for-operator-decision) ;;
              *)
                echo "--readiness must be one of: needs-artifact-repair, needs-evidence-verification, needs-operator-judgment, ready-for-operator-decision" >&2
                exit 1
                ;;
            esac
            focus="manual-review"
            focus_requested="true"
            shift 2
            ;;
          --schema-blocked-only)
            schema_blocked_only="true"
            focus="manual-review"
            focus_requested="true"
            shift
            ;;
          --judgment-required-only)
            judgment_required_only="true"
            focus="manual-review"
            focus_requested="true"
            shift
            ;;
          -h|--help)
            current_admin_subcommand_usage status
            exit 0
            ;;
          *)
            echo "Unknown argument for current-admin status: $1" >&2
            current_admin_subcommand_usage status
            exit 1
            ;;
        esac
      done
      if [ -n "$input_path" ]; then
        input_path="$(normalize_python_workspace_path "$input_path")"
      fi
      if [ "$focus_requested" = "true" ]; then
        output_json="true"
      fi
      print_current_admin_status "$input_path" "$batch_name" "$output_json" "$focus" "$reason" "$confidence_bucket" "$unresolved_only" "$readiness" "$schema_blocked_only" "$judgment_required_only" "$quality_focus" "$manual_review_only" "$calibration_all_batches" "$simulation_preset" "$simulation_focus" "$include_deltas" "$confidence_auto_approve_threshold" "$confidence_manual_review_floor" "$allow_high_confidence_flagged_items_to_stay_blocked" "$treat_unclear_as_always_manual_review" "$treat_weak_evidence_as_always_manual_review" "$treat_conflicting_sources_as_always_manual_review" "$treat_date_uncertain_as_always_manual_review" "$treat_ambiguous_subject_as_always_manual_review" "$treat_model_manual_review_as_always_manual_review" "$evidence_focus" "$evidence_quality_label" "$source_grounding_label" "$impact_directness_hint" "$evidence_item_id" "$include_items" "$comparison_baseline" "$comparison_enriched" "$paired_experiment_name"
      ;;
    import)
      if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        current_admin_subcommand_usage import
        exit 0
      fi
      local -a import_args=()
      normalize_current_admin_path_args import_args "$@"
      run_step "1/1" "Import Curated Batch" "Current-admin import command complete" -- \
        "$VENV_PYTHON" scripts/import_curated_current_admin_batch.py "${import_args[@]}"
      ;;
    validate)
      if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
        current_admin_subcommand_usage validate
        exit 0
      fi
      local -a validate_args=()
      normalize_current_admin_path_args validate_args "$@"
      run_step "1/1" "Validate Import" "Current-admin validation complete" -- \
        "$VENV_PYTHON" scripts/validate_current_admin_import.py "${validate_args[@]}"
      ;;
    help|-h|--help|"")
      current_admin_usage
      ;;
    *)
      echo "Unknown current-admin command: $command" >&2
      current_admin_usage
      exit 1
      ;;
  esac
}

main_usage() {
  cat <<EOF
Usage:
  equitystack weekly-run
  equitystack review
  equitystack legislative <command> [args]
  equitystack current-admin <command> [args]
  equitystack impact <command> [args]
  equitystack operator <command> [args]
  equitystack admin-reset-operational-state [--dry-run | --apply --yes]

Shared runtime defaults:
  verifier AI:      $DEFAULT_MODEL_VERIFIER
  review AI:        $DEFAULT_MODEL_REVIEW
  fallback AI:      $DEFAULT_MODEL_FALLBACK
  executor model:   $DEFAULT_MODEL_EXECUTOR
  OpenAI base URL:  $DEFAULT_OPENAI_BASE_URL
  senior timeout:   ${DEFAULT_REVIEW_TIMEOUT_SENIOR}s
  verifier timeout: ${DEFAULT_REVIEW_TIMEOUT_VERIFIER}s

Legislative commands:
  run        Run the daily review-first pipeline, auto-triage safe actions, rebuild the bundle
  review     Open the legislative review CLI
  apply      Apply approved legislative actions, rerun affected bills when needed, rebuild the bundle
  import     Import approved tracked-bill seed rows, rebuild the bundle
  repair     Reconcile stale legislative bundle and manual-review-queue state
  feedback   Refresh feedback analysis and rebuild the bundle

Current-admin commands:
  discover   Run read-only discovery for current-administration updates
  gen-batch  Generate a canonical current-admin batch from discovery candidates
  export     Export selected discovery suggestions into a draft batch
  normalize  Normalize a curated batch file
  ai-review  Run the standard single-pass OpenAI Batch review on a normalized batch
  deep-review
             Run the deeper paired AI review path for ambiguous current-admin records
  outcome-evidence
             Read-only implementation and outcome evidence collection for existing current-admin rows
  run        Canonical full automation entrypoint with exception-only manual handoff
  review     Exception-only recovery surface for the remaining borderline rows
  apply      Run pre-commit, import dry-run, optional apply, and validation
  status     Show current-admin artifact state and recommended next step
  pre-commit Generate the import guardrail artifact
  import     Dry-run or apply a curated batch import
  validate   Validate imported current-administration records

Impact maturation commands:
  evaluate   Build a read-only impact maturation review artifact; optional strict supplemental auto-approval stays dry-run at evaluate time
  promote    Promote approved safe forward impact transitions
  backfill-outcome-sources  Audit optional safe canonical policy_outcome_sources links
  sync-current-admin-outcomes  Sync promise_outcomes into policy_outcomes
  audit-historical-duplicates  Audit likely duplicate/variant historical policies
  audit-policy-coverage-gaps  Generate Missing Policy Report by decade/category
  audit-outcome-temporal-attribution  Audit outcome timing signals without changing scoring
  report-outcome-time  Report unified policy_outcomes by year, decade, and administration
  report-final-black-impact-score  Compute final Black Impact Score per president
  certify-production-data  End-to-end read-only data model and scoring certification
  validate-integrity  Validate attribution consistency and policy_outcomes drift risks
  complete-certification-readiness  Apply guarded certification readiness backfills
  backfill-policy-time-intent  Dry-run or apply safe policy time and intent backfills
  curate-policy-intent  Manually classify missing historical policy intent
  curate-sources  Manually attach operator-provided sources to policy outcomes
  preview-current-admin-outcome-enrichment  Report-only preview of future current-admin policy_outcomes enrichment
  apply-current-admin-outcome-enrichment  Strict validator-gated enrichment dry-run/apply for current-admin outcomes
  discover-judicial-candidates  Scaffold-only judicial impact discovery
  import-judicial-batch  Scaffold-only judicial impact ingestion validation
  materialize-judicial-outcomes  Scaffold-only judicial policy_outcomes preview
  judicial-run  Scaffold-only canonical judicial discovery alias
  judicial-review  Scaffold-only canonical judicial review alias
  judicial-apply  Scaffold-only canonical judicial apply-preview alias

Operational maintenance:
  weekly-run   Run the low-touch weekly operator check and summary
  review       Show the compact manual task queue
  operator cleanup-stale-workflows  Mark stale operator workflow sessions inactive without deleting history
  admin-reset-operational-state   Archive non-canonical run-state artifacts for a fresh walkthrough

Examples:
  $(cli_hint) weekly-run
  $(cli_hint) review
  $(cli_hint) legislative run
  $(cli_hint) legislative run --model "$DEFAULT_MODEL_REVIEW"
  $(cli_hint) impact evaluate
  $(cli_hint) impact promote --dry-run
  $(cli_hint) impact audit-historical-duplicates
  $(cli_hint) impact audit-policy-coverage-gaps
  $(cli_hint) impact audit-outcome-temporal-attribution
  $(cli_hint) impact report-outcome-time
  $(cli_hint) impact report-final-black-impact-score
  $(cli_hint) impact certify-production-data
  $(cli_hint) impact validate-integrity
  $(cli_hint) impact complete-certification-readiness
  $(cli_hint) impact backfill-policy-time-intent
  $(cli_hint) impact preview-current-admin-outcome-enrichment --input reports/current_admin/<batch>.normalized.json --outcome-evidence reports/current_admin/<batch>.outcome-evidence.json
  $(cli_hint) impact apply-current-admin-outcome-enrichment --input reports/current_admin/<batch>.normalized.json --outcome-evidence reports/current_admin/<batch>.outcome-evidence.json --impact-evaluation reports/current_admin/<batch>.impact-evaluate.json --dry-run
  $(cli_hint) impact judicial-run
  $(cli_hint) impact curate-policy-intent --non-interactive --limit 10
  $(cli_hint) impact curate-sources --non-interactive --limit 10
  $(cli_hint) current-admin run
  $(cli_hint) current-admin run --stop-after impact-evaluate
  $(cli_hint) current-admin status
  $(cli_hint) current-admin outcome-evidence --input reports/current_admin/<batch>.normalized.json
  $(cli_hint) current-admin deep-review --input reports/current_admin/<batch-name>.normalized.json
  $(cli_hint) operator cleanup-stale-workflows --dry-run
  $(cli_hint) admin-reset-operational-state --dry-run
  $(cli_hint) current-admin review --input reports/current_admin/<batch-name>.ai-review.json
EOF
}

impact_usage() {
  cat <<EOF
Usage:
  equitystack impact <command> [args]

Commands:
  evaluate   Build reports/impact_maturation_review.json from pending/review-ready artifacts
  promote    Validate and promote approved safe forward transitions
  backfill-outcome-sources
             Audit and optionally insert safe canonical policy_outcome_sources links
  sync-current-admin-outcomes
             Dry-run or apply current-admin promise_outcomes into policy_outcomes
  audit-historical-duplicates
             Read-only audit for likely duplicate/variant historical policies
  audit-policy-coverage-gaps
             Read-only Missing Policy Report by decade and major historical policy category
  audit-outcome-temporal-attribution
             Audit outcome timing signals and optional backfill readiness
  audit-source-quality
             Audit source authority tiers, domains, duplicates, and outcome coverage
  audit-outcome-source-gaps
             Prioritize policy_outcomes missing sources for manual curation
  report-outcome-time
             Read-only report for policy_outcomes time dimension and date validation
  report-policy-intent
             Read-only report for policy intent vs outcome alignment
  report-final-black-impact-score
             Read-only final Black Impact Score per president from unified policy_outcomes
  certify-production-data
             End-to-end read-only production data model and scoring certification audit
  validate-integrity
             Read-only attribution consistency and policy_outcomes integrity validation
  complete-certification-readiness
             Dry-run or apply guarded production certification readiness backfills
  audit-policy-intent-gaps
             Build a read-only queue of policies missing policy intent classification
  backfill-policy-time-intent
             Dry-run or apply high-confidence policy time and intent backfills
  curate-policy-intent
             Manually classify missing historical policy intent without overwriting existing values
  curate-sources
             Manually attach operator-provided sources to current-admin policy outcomes
  preview-current-admin-outcome-enrichment
             Report-only preview of future current-admin policy_outcomes enrichment
  apply-current-admin-outcome-enrichment
             Strict validator-gated current-admin outcome enrichment dry-run/apply
  discover-judicial-candidates
             Scaffold-only judicial impact discovery; no scoring or writes
  import-judicial-batch
             Scaffold-only judicial impact ingestion validation; apply disabled
  materialize-judicial-outcomes
             Scaffold-only judicial policy_outcomes materialization preview; apply disabled
  judicial-run
             Scaffold-only canonical judicial discovery alias
  judicial-review
             Scaffold-only canonical judicial review alias
  judicial-apply
             Scaffold-only canonical judicial apply-preview alias

Examples:
  $(cli_hint) impact evaluate
  $(cli_hint) impact evaluate --input reports/current_admin/<batch>.normalized.json
  $(cli_hint) impact evaluate --input reports/current_admin/<batch>.normalized.json --outcome-evidence reports/current_admin/<batch>.outcome-evidence.json
  $(cli_hint) impact evaluate --input reports/current_admin/<batch>.normalized.json --outcome-evidence reports/current_admin/<batch>.outcome-evidence.json --auto-approve-safe-supplemental --dry-run
  $(cli_hint) impact promote --dry-run
  $(cli_hint) impact promote --apply --yes
  $(cli_hint) impact promote --apply --yes --approve-safe
  $(cli_hint) impact backfill-outcome-sources
  $(cli_hint) impact backfill-outcome-sources --apply --yes
  $(cli_hint) impact sync-current-admin-outcomes
  $(cli_hint) impact sync-current-admin-outcomes --apply --yes
  $(cli_hint) impact audit-historical-duplicates
  $(cli_hint) impact audit-policy-coverage-gaps
  $(cli_hint) impact audit-outcome-temporal-attribution
  $(cli_hint) impact audit-source-quality
  $(cli_hint) impact audit-outcome-source-gaps
  $(cli_hint) impact report-outcome-time
  $(cli_hint) impact report-policy-intent
  $(cli_hint) impact report-final-black-impact-score
  $(cli_hint) impact certify-production-data
  $(cli_hint) impact validate-integrity
  $(cli_hint) impact complete-certification-readiness
  $(cli_hint) impact audit-policy-intent-gaps
  $(cli_hint) impact backfill-policy-time-intent
  $(cli_hint) impact backfill-policy-time-intent --apply --yes
  $(cli_hint) impact preview-current-admin-outcome-enrichment --input reports/current_admin/<batch>.normalized.json --outcome-evidence reports/current_admin/<batch>.outcome-evidence.json
  $(cli_hint) impact apply-current-admin-outcome-enrichment --input reports/current_admin/<batch>.normalized.json --outcome-evidence reports/current_admin/<batch>.outcome-evidence.json --impact-evaluation reports/current_admin/<batch>.impact-evaluate.json --dry-run
  $(cli_hint) impact judicial-run
  $(cli_hint) impact judicial-review --input reports/judicial_impact_candidates.json
  $(cli_hint) impact judicial-apply --input reports/judicial_impact_candidates.json
  $(cli_hint) impact curate-policy-intent --non-interactive --limit 10
  $(cli_hint) impact curate-policy-intent --only-policy-id 157 --category equity_expanding --summary "..." --source-reference "..." --apply --yes
  $(cli_hint) impact curate-sources --non-interactive --limit 10
  $(cli_hint) impact curate-sources --only-policy-outcome-id 6 --source-title "..." --source-url "https://..." --apply --yes

Safety:
  Allowed transitions are impact_pending -> impact_review_ready,
  impact_review_ready -> impact_scored, and impact_scored -> impact_verified.
  Backward movement is blocked. Outcomes are inserted only for impact_scored
  or impact_verified transitions, and existing outcome rows are preserved.
  Outcome-source backfill is dry-run by default and only inserts
  safe_auto_link candidates when --apply --yes is explicit.
  Current-admin policy outcome sync is insert-only and preserves existing
  unified policy_outcomes rows.
  Historical duplicate audit is read-only and never merges or deletes policies.
  Outcome temporal attribution audit is dry-run by default and will not write
  dates unless suitable date/provenance columns exist and --apply --yes is explicit.
  Source quality audit is read-only and never edits source rows or joins.
  Integrity validation is read-only and reports attribution/source/coverage
  warnings without modifying policy_outcomes.
  Outcome time reporting is read-only and never mutates policy_outcomes.
  Policy intent reporting is read-only and never infers missing intent.
  Policy time/intent backfill is dry-run by default, updates only NULL
  fields, preserves existing values, and requires --apply --yes.
  Manual policy-intent curation is dry-run by default, targets only
  policies with NULL policy_intent_category, and requires --apply --yes.
  Manual source curation never auto-discovers sources. It only attaches
  operator-provided URLs, avoids duplicate URL creation, rejects low/unverified
  source quality, and requires --apply --yes for writes.
  Supplemental current-admin outcome-evidence can auto-approve only the
  strict validator-gated impact_pending -> impact_review_ready path.
  `impact promote --apply --yes` still refuses any supplemental transition
  that was not explicitly approved during `impact evaluate`.
  Current-admin policy_outcome enrichment is dry-run by default and only
  applies validator-approved, outcome-oriented evidence rows when
  `--apply --yes` is explicit.
  Judicial impact commands are scaffold-only and do not contribute to scoring
  or perform database writes in this rollout.
EOF
}

operator_usage() {
  cat <<EOF
Usage:
  equitystack operator <command> [args]

Commands:
  cleanup-stale-workflows   Mark stale operator workflow sessions inactive without deleting history

Cleanup examples:
  $(cli_hint) operator cleanup-stale-workflows --dry-run
  $(cli_hint) operator cleanup-stale-workflows --apply --yes
  $(cli_hint) operator cleanup-stale-workflows --session-id current-admin:current-admin-wrapper-test --apply --yes

Safety:
  Cleanup never deletes workflow session files. It marks selected active sessions
  inactive and adds archivedAt, archivedReason, archivedBy, and cleanupMetadata.
  Default selection includes obvious test sessions, older duplicate active sessions,
  and older blocked sessions. Use --exclude-session to keep a matching session.
EOF
}

admin_reset_operational_state_usage() {
  cat <<EOF
Usage:
  equitystack admin-reset-operational-state [--dry-run | --apply --yes]

Archives operational run-state artifacts for a clean walkthrough baseline.

This reset affects only:
  - operator history
  - recommendation feedback history
  - current-admin report artifacts
  - legislative report artifacts
  - EquityStack log files

This reset does NOT touch:
  - database content
  - canonical policy data
  - source files

Examples:
  $(cli_hint) admin-reset-operational-state --dry-run
  $(cli_hint) admin-reset-operational-state --apply --yes
EOF
}

legislative_usage() {
  cat <<EOF
Usage:
  equitystack legislative <command> [args]

Commands:
  run        Run the daily pipeline, auto-triage safe actions, and rebuild the review bundle
  review     Open the legislative review CLI
  apply      Dry-run or apply approved legislative actions
  import     Dry-run or apply approved tracked-bill seed rows
  repair     Dry-run or apply canonical review-bundle/manual-queue repair for stale actions
  materialize-outcomes
             Dry-run or apply safe tracked_bills into unified policy_outcomes
  feedback   Refresh feedback analysis and rebuild the bundle

Run options:
  --model <name>                Override the senior review model for the daily pipeline
  --verifier-model <name>       Override the verifier model for draft/assist stages
  --fallback-model <name>       Override the fallback reviewer model used after senior-review failure
  --timeout <seconds>           Legacy alias that sets both senior and verifier timeouts
  --senior-timeout <seconds>    Override the senior review timeout
  --verifier-timeout <seconds>  Override the verifier/fallback timeout
  --skip-discovery              Pass through to run_equitystack_pipeline.py
  --apply-safe-removals         Pass through to run_equitystack_pipeline.py
  --only-future-bill-id <id>    Limit the pipeline to one or more future bills
  --output-report <path>        Override the pipeline report path
  --csv                         Ensure supporting CSV reports are written

Apply / import options:
  legislative apply --dry-run
  legislative apply --apply --yes
  legislative import --dry-run
  legislative import --apply --yes
  legislative repair --dry-run
  legislative repair --apply --yes
  legislative materialize-outcomes
  legislative materialize-outcomes --apply --yes
EOF
}

current_admin_usage() {
  cat <<EOF
Usage:
  equitystack current-admin <command> [args]

Commands:
  discover   Wrapper for scripts/discover_current_admin_updates.py
  gen-batch  Wrapper for scripts/generate_current_admin_batch_from_discovery.py
  export     Wrapper for scripts/export_current_admin_discovery_candidates.py
  normalize  Wrapper for scripts/normalize_current_admin_batch.py
  ai-review  Run the standard single-pass OpenAI Batch review on a normalized batch
  deep-review
             Run the deeper paired AI review path for ambiguous current-admin records
  outcome-evidence
             Read-only implementation and outcome evidence collection for existing current-admin rows
  run        Discover and generate the next batch by default, then normalize, review, and promote the AI-first queue
  review     Promote AI decisions and ask for operator input only on the remaining borderline rows
  apply      Run pre-commit, import dry-run, optional apply, and validation
  status     Show current-admin batch state and recommended next step
  pre-commit Wrapper for scripts/build_current_admin_precommit_review.py
  import     Wrapper for scripts/import_curated_current_admin_batch.py
  validate   Wrapper for scripts/validate_current_admin_import.py

Defaults:
  current-admin ai-review, current-admin deep-review, and current-admin run default to:
    openai-model   $DEFAULT_CURRENT_ADMIN_REVIEW_MODEL
    verifier-model $DEFAULT_CURRENT_ADMIN_VERIFIER_MODEL
    fallback-model $DEFAULT_CURRENT_ADMIN_FALLBACK_MODEL
    openai-base-url $DEFAULT_CURRENT_ADMIN_OPENAI_BASE_URL

  current-admin discovery defaults to:
    model       $DEFAULT_MODEL_VERIFIER
    timeout     ${DEFAULT_REVIEW_TIMEOUT_VERIFIER}s
    openai-base-url $DEFAULT_CURRENT_ADMIN_OPENAI_BASE_URL
    live sources python/config/current_admin_sources.json (unless --disable-default-sources is passed)

  current-admin outcome-evidence defaults to:
    source config python/config/current_admin_outcome_sources.json
    activation   active but read-only
    writes       artifacts only, no database changes

Path handling:
  Current-admin path flags accept python-rooted paths like data/... or reports/... .
  The installed ~/bin/equitystack wrapper also accepts repo-rooted paths like
  python/data/... or python/reports/... and normalizes them automatically.

OpenAI Batch lifecycle:
  Use current-admin ai-review --input <normalized-or-ai-review.json> with:
    --batch-status   show local metadata plus remote status when available
    --batch-poll     poll an existing batch without resubmitting
    --batch-fetch    fetch output/error files without resubmitting
    --batch-inspect  show local readiness and validation counts
    --batch-resume   poll, fetch, and rebuild the canonical review artifact when ready
EOF
}

current_admin_subcommand_usage() {
  local subcommand="$1"
  case "$subcommand" in
    discover)
      cat <<EOF
Usage:
  equitystack current-admin discover [args]

Runs:
  python3 scripts/discover_current_admin_updates.py [args]

Wrapper defaults:
  --model $DEFAULT_MODEL_VERIFIER
  --timeout $DEFAULT_REVIEW_TIMEOUT_VERIFIER
  --openai-base-url $DEFAULT_CURRENT_ADMIN_OPENAI_BASE_URL

By default discovery also loads configured live sources from:
  python/config/current_admin_sources.json
Pass --disable-default-sources to inspect only explicit --feed-url/--feed-json inputs.
EOF
      ;;
    export)
      cat <<EOF
Usage:
  equitystack current-admin export [args]

Runs:
  python3 scripts/export_current_admin_discovery_candidates.py [args]
EOF
      ;;
    gen-batch|generate-batch)
      cat <<EOF
Usage:
  equitystack current-admin gen-batch [--input <discovery-report.json>] [selection flags | --all-candidates] [--batch-name <batch-name>] [--output <batch.json>]

Runs:
  python3 scripts/generate_current_admin_batch_from_discovery.py [args]

This generates a canonical current-admin batch ready for current-admin run --input.
EOF
      ;;
    normalize)
      cat <<EOF
Usage:
  equitystack current-admin normalize [args]

Runs:
  python3 scripts/normalize_current_admin_batch.py [args]
EOF
      ;;
    outcome-evidence)
      cat <<EOF
Usage:
  equitystack current-admin outcome-evidence [--input <normalized.json|manual-review-queue.json>] [--source-config <path>] [--feed-url <rss>] [--feed-json <path>] [--csv [path]]

Runs:
  python3 scripts/discover_current_admin_outcome_evidence.py [args]

This is the read-only evidence collector used by the automated current-admin run flow:
  - active and read-only
  - writes JSON/CSV artifacts only
  - never writes current-admin rows or policy_outcomes
  - can also be run directly for debugging or batch-specific review
EOF
      ;;
    review)
      cat <<EOF
Usage:
  equitystack current-admin review [--input <ai-review.json> | --batch-name <batch-name>] [--decision-file <decision-template.json>] [--refresh-template] [--log-decisions [path]] [--feedback-summary]

Promotes AI-approved and AI-rejected rows first, then asks for operator decisions only on the remaining manual-review slice.
If no borderline items remain, review completes without requiring a decision file edit.
This is the exception-only recovery surface, not the default happy path.
EOF
      ;;
    ai-review)
      cat <<EOF
Usage:
  equitystack current-admin ai-review [args]

Runs:
  python3 scripts/review_current_admin_batch_with_openai_batch.py [args]

Wrapper defaults:
  --model $DEFAULT_CURRENT_ADMIN_REVIEW_MODEL
  --verifier-model $DEFAULT_CURRENT_ADMIN_VERIFIER_MODEL
  --fallback-model $DEFAULT_CURRENT_ADMIN_FALLBACK_MODEL
  --senior-timeout $DEFAULT_REVIEW_TIMEOUT_SENIOR
  --verifier-timeout $DEFAULT_REVIEW_TIMEOUT_VERIFIER
  --review-mode standard
  --openai-base-url $DEFAULT_CURRENT_ADMIN_OPENAI_BASE_URL

Lifecycle flags:
  --batch-status   Show local Batch metadata and remote status when possible; no resubmit.
  --batch-poll     Poll the existing batch from local metadata; no resubmit.
  --batch-fetch    Download available output/error JSONL files; no resubmit.
  --batch-inspect  Show concise readiness and validation counts.
  --batch-resume   Poll/fetch/rebuild the canonical .ai-review.json when possible; no resubmit.

Evidence packaging:
  --evidence-preview  Build and print the model-facing .evidence-pack.json sidecar without submitting review.

For a deeper paired AI review, use:
  equitystack current-admin deep-review [args]
EOF
      ;;
    deep-review)
      cat <<EOF
Usage:
  equitystack current-admin deep-review [args]

Runs:
  python3 scripts/current_admin_paired_evaluation.py --paired-experiment [args]

This is the deeper AI review path for ambiguous batches or rows flagged for deeper review.
It runs paired baseline vs enriched evidence-pack review artifacts instead of the standard single-pass review.
EOF
      ;;
    run)
      cat <<EOF
Usage:
  equitystack current-admin run [--input <batch-file> | --batch-name <batch-name>] [--discovery-dry-run] [--discovery-output <report.json>] [--output <batch.json>] [--output-name <batch-name>] [--full-auto] [--stop-after <review|apply|impact-evaluate|impact-promote|enrichment>] [--no-auto-apply] [--no-impact-automation] [review args]

Default path without --input:
  discover -> gen-batch -> normalize -> AI review -> AI-first queue promotion
  -> exception-only manual stop OR guarded import path
  -> outcome-evidence -> impact evaluate -> impact promote
  -> outcome enrichment -> current-admin outcome sync

Manual path with --input:
  normalize -> AI review -> AI-first queue promotion
  -> same exception-only automation tail

Batch-scoped automation artifacts are written under:
  reports/current_admin/<batch>.outcome-evidence.json
  reports/current_admin/<batch>.impact-evaluate.json
  reports/current_admin/<batch>.impact-promote-dry-run.json
  reports/current_admin/<batch>.impact-promote-apply.json
  reports/current_admin/<batch>.outcome-enrichment-preview.json
  reports/current_admin/<batch>.outcome-enrichment-dry-run.json
  reports/current_admin/<batch>.outcome-enrichment-apply.json
  reports/current_admin/<batch>.automation-report.json
  reports/current_admin/<batch>.exception-queue.json
EOF
      ;;
    apply)
      cat <<EOF
Usage:
  equitystack current-admin apply [--input <manual-review-queue.json> | --batch-name <batch-name>] [--apply --yes]

Runs the guarded operator apply path:
  pre-commit -> import dry-run -> optional import apply -> validate

Database writes still require --apply --yes.
EOF
      ;;
    status)
      cat <<EOF
Usage:
  equitystack current-admin status [--input <batch-file> | --batch-name <batch-name>] [--json] [--focus <all|blocked|incomplete|finalize-safe|apply-safe|manual-review|calibration|simulation|evidence-pack|comparison|paired-experiment>]

Shows artifact presence, current workflow state, blocking issues, and the recommended next command.
Use --json for the sidecar-derived OpenAI Batch read model. --focus and the aliases
--blocked, --incomplete, --finalize-safe, and --apply-safe imply JSON output.
Use --manual-review or --focus manual-review for the manual-review read model. Manual-review
filters: --reason <schema|conflicting-sources|weak-evidence|unclear|low-confidence|manual-review-requested|ambiguous-subject|date-uncertain>,
--confidence-bucket <0.00-0.59|0.60-0.74|0.75-0.84|0.85+>, --unresolved-only,
--readiness <needs-artifact-repair|needs-evidence-verification|needs-operator-judgment|ready-for-operator-decision>,
--schema-blocked-only, --judgment-required-only.
Use --calibration or --focus calibration for rule-based calibration diagnostics.
Calibration filters: --quality-focus <all|low-confidence-heavy|weak-evidence-heavy|unclear-heavy|high-manual-review|structurally-valid-but-decision-thin>,
--manual-review-only, --unresolved-only, --all-batches.
Use --simulation or --focus simulation for read-only threshold simulations.
Simulation filters: --preset <strict-current|slightly-relaxed|moderate-relaxed|confidence-only-test>,
--simulation-focus <all|threshold-sensitive|evidence-blocked|flag-blocked|threshold-only-promotions>,
--include-deltas, --manual-review-only, --all-batches.
Simulation overrides: --confidence-auto-approve-threshold <float>, --confidence-manual-review-floor <float>,
--allow-high-confidence-flagged-items-to-stay-blocked <true|false>,
--treat-unclear-as-always-manual-review <true|false>,
--treat-weak-evidence-as-always-manual-review <true|false>,
--treat-conflicting-sources-as-always-manual-review <true|false>,
--treat-date-uncertain-as-always-manual-review <true|false>,
--treat-ambiguous-subject-as-always-manual-review <true|false>,
--treat-model-manual-review-as-always-manual-review <true|false>.
Use --evidence-pack or --focus evidence-pack for evidence-pack/source-grounding diagnostics.
Evidence-pack filters: --evidence-focus <all|single-source-official|outcome-evidence-present|policy-intent-only|weak-outcome-evidence|multi-source-grounding>,
--evidence-quality-label <label>, --source-grounding-label <label>,
--impact-directness-hint <hint>, --item-id <stable-item-id>, --include-items, --all-batches.
Use --compare-review-runs or --focus comparison for baseline-vs-enriched review quality comparison.
Comparison inputs: --baseline <ai-review.json> --enriched <ai-review.json>.
Comparison filters: --batch-name <name>, --include-item-deltas.
Use --paired-experiment or --focus paired-experiment for paired evaluation tracking.
Paired-experiment filters: --batch-name <name>, --experiment-name <name>.

Relative --input paths may be given as data/... or python/data/...
EOF
      ;;
    import)
      cat <<EOF
Usage:
  equitystack current-admin import [args]

Runs:
  python3 scripts/import_curated_current_admin_batch.py [args]

Import stays dry-run by default. Database writes still require --apply --yes.
EOF
      ;;
    pre-commit)
      cat <<EOF
Usage:
  equitystack current-admin pre-commit [args]

Runs:
  python3 scripts/build_current_admin_precommit_review.py [args]
EOF
      ;;
    validate)
      cat <<EOF
Usage:
  equitystack current-admin validate [args]

Runs:
  python3 scripts/validate_current_admin_import.py [args]
EOF
      ;;
    *)
      current_admin_usage
      ;;
  esac
}

case "${1:-}" in
  ""|-h|--help|help)
    main_usage
    ;;
  weekly-run)
    shift
    run_step "1/1" "EquityStack Weekly Run" "Weekly operator report complete" --output "$EQUITYSTACK_PYTHON_DIR/reports/operator/weekly-run.latest.json" -- \
      "$VENV_PYTHON" scripts/operator_weekly_report.py weekly-run "$@"
    ;;
  review)
    shift
    run_step "1/1" "EquityStack Review Queue" "Operator review queue complete" --output "$EQUITYSTACK_PYTHON_DIR/reports/operator/review.latest.json" -- \
      "$VENV_PYTHON" scripts/operator_weekly_report.py review "$@"
    ;;
  admin-reset-operational-state)
    shift
    reset_success_message="Operational reset preview complete"
    reset_step_title="Preview Operational Reset"
    if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
      admin_reset_operational_state_usage
      exit 0
    fi
    for arg in "$@"; do
      if [ "$arg" = "--apply" ]; then
        reset_success_message="Operational artifacts archived for a fresh walkthrough"
        reset_step_title="Reset Operational State"
        break
      fi
    done
    run_step "1/1" "$reset_step_title" "$reset_success_message" -- \
      "$VENV_PYTHON" scripts/admin_reset_operational_state.py "$@"
    ;;
  legislative)
    shift
    run_legislative_command "${1:-help}" "${@:2}"
    ;;
  impact)
    shift
    run_impact_command "${1:-help}" "${@:2}"
    ;;
  operator)
    shift
    run_operator_command "${1:-help}" "${@:2}"
    ;;
  current-admin)
    shift
    run_current_admin_command "${1:-help}" "${@:2}"
    ;;
  run|review|apply|import|feedback)
    run_legislative_command "$@"
    ;;
  *)
    echo "Unknown command: ${1:-}" >&2
    main_usage
    exit 1
    ;;
esac
